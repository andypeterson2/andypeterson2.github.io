---
import { siteConfig } from '../config/site';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';
import '../styles/base.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  hideChrome?: boolean;
}

const { title, description, ogImage, hideChrome = false } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const isPreviewDeploy = import.meta.env.PREVIEW_DEPLOY === 'true';
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const windowTitle = title || siteConfig.title;

// Auto-generate breadcrumbs from URL path
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
interface Crumb { label: string; href?: string }
const breadcrumbs: Crumb[] = [];

if (!isHome) {
  const segments = pathname.split('/').filter(Boolean);
  for (let i = 0; i < segments.length; i++) {
    const isLast = i === segments.length - 1;
    const href = '/' + segments.slice(0, i + 1).join('/') + '/';
    const label = isLast && title
      ? title
      : segments[i].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    breadcrumbs.push({ label, href: isLast ? undefined : href });
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {isPreviewDeploy && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- system.css — System 6 UI framework -->
    <link rel="stylesheet" href="/lib/ui-kit/v1.1/vendor/system.css" />
    <link rel="stylesheet" href="https://unpkg.com/@sakun/system.css" />
    <slot name="head" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: siteConfig.displayName,
      url: canonicalUrl.href,
      jobTitle: 'Quantum Researcher',
      sameAs: [siteConfig.github, siteConfig.linkedin].filter(Boolean),
    })} />

    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
    )}

    <!-- Error boundary -->
    <script is:inline>
      window.addEventListener('error', function(e) {
        var el = document.getElementById('error-boundary');
        if (el) { el.style.display = 'block'; el.textContent = 'Something went wrong. Please refresh.'; }
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div id="error-boundary" class="error-boundary" role="alert" style="display:none"></div>

    <slot name="topbar" />

    {hideChrome ? (
      <slot />
    ) : (
      <div class="desktop-area">
        <div class="desktop">
          <div class="ui-navbar-wrapper">
            <Nav />
          </div>
          <div class="window site-window">
            <div class="title-bar">
              <h1 class="title">{windowTitle}</h1>
            </div>
            <slot name="details-bar" />
            <div class="window-pane" id="main-content">
              <slot />
            </div>
          </div>
        </div>
      </div>
    )}

    <button id="back-to-top" class="btn back-to-top" aria-label="Back to top" type="button">
      &uarr; Top
    </button>

    <script>
      const btn = document.getElementById('back-to-top');
      if (btn) {
        const pane = document.querySelector('.window-pane');
        const scrollTarget = pane || window;
        const getScroll = () => pane ? pane.scrollTop : window.scrollY;
        (pane || window).addEventListener('scroll', () => {
          btn.classList.toggle('visible', getScroll() > 400);
        });
        btn.addEventListener('click', () => {
          (pane || window).scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 8px 16px;
    background: #000;
    color: #fff;
    z-index: 9999;
    text-decoration: none;
  }
  .skip-link:focus {
    top: 0;
  }
  .error-boundary {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 300;
    padding: 6px 12px;
    background: #000;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 16px;
    text-align: center;
  }
  html {
    background: #000;
  }
  /* ── Classic Mac monitor canvas: 4:3 aspect ratio, rounded corners ── */
  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: #eee url('/bg-pattern.svg') repeat;
    background-size: 2.5vw 2.5vw;
    image-rendering: pixelated;
    border: 0.5vw solid #000;
    border-radius: 1.25vw;
    overflow: hidden;
    box-sizing: border-box;
  }
  .desktop-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .desktop {
    width: 100%;
    max-width: min(90vw, 1280px);
    aspect-ratio: 512 / 384;
    max-height: 90vh;
    overflow: hidden;
    background: #fff;
    display: flex;
    flex-direction: column;
    border-radius: 0 0 1vw 1vw;
  }
  .ui-navbar-wrapper {
    flex-shrink: 0;
  }
  .ui-navbar-wrapper .site-navbar {
    border-bottom: 2px solid #000;
  }
  .site-window {
    min-width: 0;
    display: flex;
    flex: 1;
    min-height: 0;
  }
  .site-window .title-bar {
    border: 2px solid #000;
  }
  .bare-window,
  .bare-window::before,
  .bare-window::after {
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }
  .site-window .window-pane {
    overflow-y: auto;
    flex: 1;
    padding: 0 var(--space-6) var(--space-6);
    font-size: 16px;
    font-family: var(--font-sans);
    letter-spacing: 0;
    display: flex;
    flex-direction: column;
  }
  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
  }
  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Mobile: full-screen, no canvas frame ── */
  @media (max-width: 768px), (max-aspect-ratio: 3/4) {
    body {
      display: flex;
      border: none;
      border-radius: 0;
    }
    .desktop-area { align-items: stretch; flex-direction: column; }
    .desktop {
      max-width: 100%;
      aspect-ratio: auto;
      max-height: none;
      border-radius: 0;
    }
    .site-window { border-left: none; border-right: none; }
    .site-window .window-pane { max-height: none; }
  }
</style>
