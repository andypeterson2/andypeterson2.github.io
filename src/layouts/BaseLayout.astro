---
import { siteConfig } from '../config/site';
import '../styles/tokens.css';
import '../styles/base.css';
import ServerConnectModal from '../components/ServerConnectModal.astro';
import {
  buildBreadcrumbs,
  buildDetailsSegments,
  renderSegment,
  type Crumb,
} from '../lib/breadcrumbs';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
  /** Full-bleed app pages (e.g. the CV editor): skip the portal chrome, keep head/SEO. */
  bare?: boolean;
}

const { title, description, ogImage, breadcrumbs: customBreadcrumbs, bare } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const isPreviewDeploy = import.meta.env.PREVIEW_DEPLOY === 'true';
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const windowTitle = title || siteConfig.title;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
const breadcrumbs = buildBreadcrumbs(pathname, title, customBreadcrumbs);
const detailsSegments = buildDetailsSegments(breadcrumbs, isHome);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="description" content={pageDescription} />
    {isPreviewDeploy && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- system.css — System 6 UI framework -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/@sakun/system.css@0.1.11/dist/system.css"
      crossorigin="anonymous"
      integrity="sha384-rwwdSfFF9LapWjf16N2Gtcd61dN6gtugqy9A72EU+IlLyrRH3qpyb0T686o8cqh0"
    />
    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      crossorigin="anonymous"
      integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+"
    />
    <slot name="head" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: siteConfig.displayName,
        url: canonicalUrl.href,
        jobTitle: 'Quantum Researcher',
        sameAs: [siteConfig.github, siteConfig.linkedin].filter(Boolean),
      })}
    />

    {
      plausibleDomain && (
        <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
      )
    }

    <!-- Error boundary removed — app pages handle errors via their own UI -->
  </head>
  <body class={bare ? 'is-bare' : undefined}>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Desktop menubar (>768px) -->
    <nav class="site-menubar" aria-label="Main navigation">
      <ul role="menubar">
        <li role="menuitem" class="heart-item">
          <a href="/"
            ><img src="/icons/heart.svg" alt="Home" class="heart-icon" width="36" height="36" /></a
          >
        </li>
        <li role="menuitem"><a href="/about">About</a></li>
        <li role="menuitem"><a href="/projects/">Projects</a></li>
      </ul>
    </nav>

    <!-- Mobile site navigation (≤768px): one floating hamburger, the same on every
         page — including full-bleed app pages like the editor (it is not hidden in
         bare mode). -->
    <nav class="mobile-nav" aria-label="Site navigation">
      <button
        type="button"
        class="mobile-nav-btn"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="mobile-nav-menu"
        aria-label="Site navigation"
      >
        <span aria-hidden="true">☰</span>
      </button>
      <ul id="mobile-nav-menu" class="mobile-nav-menu" hidden>
        <li>
          <a href="/"
            ><img src="/icons/heart.svg" alt="" class="mnav-heart" width="18" height="18" /> Home</a
          >
        </li>
        <li><a href="/about/">About</a></li>
        <li><a href="/projects/">Projects</a></li>
      </ul>
    </nav>

    <div class="site-canvas">
      <div class="window site-window">
        <div class="title-bar">
          <h1 class="title">{windowTitle}</h1>
        </div>
        <div class="details-bar">
          {
            detailsSegments.map((seg) => {
              const r = renderSegment(seg);
              if (r.isHeart) {
                return (
                  <a href={r.href} class={r.class}>
                    <img src="/icons/heart_light.svg" alt="Home" class="crumb-heart-icon" />
                  </a>
                );
              }
              return r.tag === 'a' ? (
                <a href={r.href} class={r.class}>
                  {r.text}
                </a>
              ) : (
                <span class={r.class}>{r.text}</span>
              );
            })
          }
        </div>
        <slot name="details-bar" />
        <div class="window-pane site-pane" id="main-content">
          <slot />
        </div>
      </div>
    </div>

    <button id="back-to-top" class="btn back-to-top" aria-label="Back to top" type="button">
      &uarr; Top
    </button>

    <script>
      // Mobile floating nav — a hamburger that toggles a small menu.
      const navBtn = document.querySelector('.mobile-nav-btn') as HTMLButtonElement | null;
      const navMenu = document.getElementById('mobile-nav-menu');
      if (navBtn && navMenu) {
        const setOpen = (open: boolean) => {
          navBtn.setAttribute('aria-expanded', String(open));
          navMenu.hidden = !open;
        };
        navBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          setOpen(navBtn.getAttribute('aria-expanded') !== 'true');
        });
        // A press anywhere else, or Escape, closes it.
        document.addEventListener('click', (e) => {
          if (!navMenu.hidden && !(e.target instanceof Node && navMenu.contains(e.target)))
            setOpen(false);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !navMenu.hidden) {
            setOpen(false);
            navBtn.focus();
          }
        });
      }

      // Back to top
      const btn = document.getElementById('back-to-top');
      if (btn) {
        const pane = document.querySelector('.site-pane');
        const scrollTarget = pane || window;
        const getScroll = () => (pane ? pane.scrollTop : window.scrollY);
        (pane || window).addEventListener('scroll', () => {
          btn.classList.toggle('visible', getScroll() > 400);
        });
        btn.addEventListener('click', () => {
          (pane || window).scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>

    <ServerConnectModal />
  </body>
</html>

<style is:global>
  /* Full-bleed app pages (bare): hide the portal chrome, strip the window frame,
     let the page fill the viewport. The <h1> stays for SEO/a11y (sr-only). */
  body.is-bare .site-menubar,
  body.is-bare .details-bar,
  body.is-bare #back-to-top {
    display: none !important;
  }
  /* The floating site-nav is deliberately NOT hidden in bare mode — it is the one
     consistent way back out of a full-bleed app page like the editor. */

  body.is-bare .site-canvas {
    max-width: none;
    padding: 0;
    margin: 0;
  }

  body.is-bare .site-window {
    border: 0;
    box-shadow: none;
    margin: 0;
    background: none;
  }

  body.is-bare .title-bar {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  body.is-bare .window-pane,
  body.is-bare .site-pane {
    padding: 0;
    margin: 0;
    max-width: none;
  }

  /* Mobile: no scrollbar chrome anywhere. Scrolling still works — the bars just
     don't paint (the System-6 patterned bars are heavy on a phone). */
  @media (width <= 768px) {
    * {
      scrollbar-width: none;
    }
    *::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }
  }
</style>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 8px 16px;
    background: #000;
    color: #fff;
    z-index: 9999;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 0;
  }

  html {
    background: #000;
  }

  body {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #eee url('/bg-pattern.svg') repeat;
    background-size: 2.5vw 2.5vw;
    image-rendering: pixelated;
    border: 0.5vw solid #000;
    border-radius: 1.25vw;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Desktop nav (>768px) ── */
  .site-menubar {
    width: 100%;
    padding: 0.5vh 1.25vw;
    font-size: clamp(0.875rem, 1.96vw, 1.5rem);
    border-bottom: 3px solid #000;
    background: #fff;
    box-sizing: border-box;
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0.75vw 0.75vw 0 0;
  }

  .site-menubar > ul {
    display: flex;
    gap: 1.875vw;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .site-menubar a {
    text-decoration: none;
    color: inherit;
  }

  .heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .heart-item:hover .heart-icon {
    filter: invert(1);
  }

  /* ── Canvas area behind the window ── */
  .site-canvas {
    flex: 1;
    display: flex;
    padding: 0.5vw 2vw;
    box-sizing: border-box;
    min-height: 0;
  }

  /* ── Inner window ── */
  .site-window {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
    border-width: 2px;
    border-right-width: 4px;
    border-bottom-width: 4px;
  }

  .site-window .title-bar .title {
    font-size: clamp(18px, 2.67vw, 42px);
  }

  .site-window .details-bar {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.75vw;
    padding: 0.3vh 2vw 0;
    font-family: var(--font-ui);
    font-size: clamp(12px, 1.78vw, 24px);
  }

  .site-window .details-bar .crumb-sep {
    font-weight: 700;
  }

  .site-window .details-bar .crumb-link {
    color: #000;
    text-decoration: none;
  }

  .site-window .details-bar .crumb-link:hover {
    background: #000;
    color: #fff;
  }

  .site-window .details-bar .crumb-heart {
    display: inline-flex;
    align-items: center;
  }

  .site-window .details-bar .crumb-heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .site-window .details-bar .crumb-heart:hover .crumb-heart-icon {
    filter: invert(1);
  }

  .site-window .separator {
    height: 1px;
    background: #000;
    flex-shrink: 0;
    margin-top: 0.25vh;
  }

  .site-pane {
    flex: 1;
    overflow-y: auto;
    padding: 1vw 4vw;
  }

  /* ── Mobile floating nav: hidden on desktop (the .site-menubar serves there) ── */
  .mobile-nav {
    display: none;
  }
  .mobile-nav-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    font-size: 22px;
    line-height: 1;
    color: #000;
    background: #fff;
    border: 2px solid #000;
    border-radius: 8px;
    box-shadow: 2px 2px 0 #000;
    cursor: pointer;
  }
  .mobile-nav-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #000;
  }
  .mobile-nav-menu {
    list-style: none;
    margin: 6px 0 0;
    padding: 4px;
    min-width: 172px;
    background: #fff;
    border: 2px solid #000;
    box-shadow: 3px 3px 0 rgb(0 0 0 / 35%);
    font-family: var(--font-ui);
  }
  .mobile-nav-menu[hidden] {
    display: none;
  }
  .mobile-nav-menu a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    color: #000;
    text-decoration: none;
    font-size: 16px;
  }
  .mobile-nav-menu a:hover,
  .mobile-nav-menu a:focus-visible {
    background: #000;
    color: #fff;
  }
  .mobile-nav-menu a:hover .mnav-heart,
  .mobile-nav-menu a:focus-visible .mnav-heart {
    filter: invert(1);
  }
  .mnav-heart {
    width: 18px;
    height: 18px;
    display: block;
  }

  /* ── Back to top ── */
  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Switch at 768px ── */
  @media (width <= 768px) {
    .site-menubar {
      display: none;
    }

    .mobile-nav {
      display: block;
      position: fixed;
      top: 10px;
      left: 10px;
      z-index: 300;
    }

    body {
      border: none;
      border-radius: 0;
    }

    .site-canvas {
      padding: 0;
    }

    .site-window {
      border-left: none;
      border-right: none;
      border-radius: 0;
    }

    /* Breadcrumbs on touch screens: the links were bare inline text ~12–18px
       tall with only ~3px between them (the home heart was 12×12px). Pad each
       crumb out, add a font floor, and let a long trail wrap instead of
       overflowing. Applies site-wide since the bar is shared chrome. */
    .site-window .details-bar {
      flex-wrap: wrap;
      gap: 2px 6px;
      font-size: clamp(14px, 3.6vw, 18px);
    }

    .site-window .details-bar .crumb-link {
      padding: 9px 5px;
    }

    .site-window .details-bar .crumb-heart-icon {
      width: 1.35em;
      height: 1.35em;
    }
  }
</style>
