---
import { siteConfig } from '../config/site';
import '../styles/tokens.css';
import '../styles/base.css';

interface Crumb { label: string; href?: string }

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
}

const { title, description, ogImage, breadcrumbs: customBreadcrumbs } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const isPreviewDeploy = import.meta.env.PREVIEW_DEPLOY === 'true';
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const windowTitle = title || siteConfig.title;

// Auto-generate breadcrumbs from URL path (unless custom ones provided)
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
let breadcrumbs: Crumb[] = [];

if (customBreadcrumbs) {
  breadcrumbs = customBreadcrumbs;
} else if (!isHome) {
  const segments = pathname.split('/').filter(Boolean);
  for (let i = 0; i < segments.length; i++) {
    const isLast = i === segments.length - 1;
    const href = '/' + segments.slice(0, i + 1).join('/') + '/';
    const label = isLast && title
      ? title
      : segments[i].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    breadcrumbs.push({ label, href: isLast ? undefined : href });
  }
}

// Details bar text
const detailsSegments = isHome
  ? [{ text: '~', bold: false, href: '/', isHeart: true }, { text: '/', bold: true }]
  : [
      { text: '~', bold: false, href: '/', isHeart: true },
      ...breadcrumbs.flatMap((crumb, i) => [
        { text: '/', bold: true },
        { text: crumb.label.toLowerCase(), bold: false, href: crumb.href },
      ]),
    ];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {isPreviewDeploy && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- system.css — System 6 UI framework -->
    <link rel="stylesheet" href="https://unpkg.com/@sakun/system.css" />
    <slot name="head" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: siteConfig.displayName,
      url: canonicalUrl.href,
      jobTitle: 'Quantum Researcher',
      sameAs: [siteConfig.github, siteConfig.linkedin].filter(Boolean),
    })} />

    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
    )}

    <!-- Error boundary -->
    <script is:inline>
      window.addEventListener('error', function(e) {
        var el = document.getElementById('error-boundary');
        if (el) { el.style.display = 'block'; el.textContent = 'Something went wrong. Please refresh.'; }
      });
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div id="error-boundary" class="error-boundary" role="alert" style="display:none"></div>

    <!-- Desktop menubar (>768px) -->
    <nav class="site-menubar" aria-label="Main navigation">
      <ul role="menu-bar">
        <li role="menu-item" class="heart-item">
          <a href="/"><img src="/icons/heart.svg" alt="Home" class="heart-icon" width="36" height="36" /></a>
        </li>
        <li role="menu-item"><a href="/projects/">Projects</a></li>
        <li role="menu-item"><a href="/contact">Contact</a></li>
      </ul>
    </nav>

    <!-- Mobile header (≤768px) -->
    <div class="mobile-header" aria-label="Mobile navigation">
      <a href="/" class="mobile-heart">
        <img src="/icons/heart.svg" alt="Home" width="40" height="40" class="mobile-heart-icon" />
      </a>
      <select class="mobile-nav-select" aria-label="Navigate to">
        <option value="">Navigate...</option>
        <option value="/projects/">Projects</option>
        <option value="/contact/">Contact</option>
      </select>
    </div>

    <div class="site-canvas">
      <div class="window site-window">
        <div class="title-bar">
          <h1 class="title">{windowTitle}</h1>
        </div>
        <div class="details-bar">
          {detailsSegments.map((seg) =>
            seg.bold
              ? <span class="crumb-sep">{seg.text}</span>
              : seg.isHeart
                ? <a href={seg.href} class="crumb-link crumb-heart"><img src="/icons/heart_light.svg" alt="Home" class="crumb-heart-icon" /></a>
                : seg.href
                  ? <a href={seg.href} class="crumb-link">{seg.text}</a>
                  : <span>{seg.text}</span>
          )}
        </div>
        <div class="window-pane site-pane" id="main-content">
          <slot />
        </div>
      </div>
    </div>

    <button id="back-to-top" class="btn back-to-top" aria-label="Back to top" type="button">
      &uarr; Top
    </button>

    <script>
      // Mobile nav select
      const sel = document.querySelector('.mobile-nav-select') as HTMLSelectElement | null;
      if (sel) {
        sel.addEventListener('change', () => {
          if (sel.value) window.location.href = sel.value;
        });
      }

      // Back to top
      const btn = document.getElementById('back-to-top');
      if (btn) {
        const pane = document.querySelector('.site-pane');
        const scrollTarget = pane || window;
        const getScroll = () => pane ? pane.scrollTop : window.scrollY;
        (pane || window).addEventListener('scroll', () => {
          btn.classList.toggle('visible', getScroll() > 400);
        });
        btn.addEventListener('click', () => {
          (pane || window).scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>

    <!-- Backend connect: Server nav item + modal (only on pages with site-backend-service meta) -->
    <script is:inline>
    (function() {
      var sm = document.querySelector('meta[name="site-backend-service"]');
      var pm = document.querySelector('meta[name="site-backend-port"]');
      if (!sm) return;

      var service = sm.getAttribute("content") || "";
      var defaultPort = parseInt((pm && pm.getAttribute("content")) || "8080") || 8080;
      if (!service) return;

      var connState = { connected: false };
      var serverLi = null;
      var serverSubUl = null;
      var modalOverlay = null;
      var hostInput = null;
      var portInput = null;
      var widget = null;

      function init() {
        var ul = document.querySelector('.site-menubar ul[role="menu-bar"]');
        if (!ul) return;

        // Server nav item
        serverLi = document.createElement("li");
        serverLi.setAttribute("role", "menu-item");
        serverLi.setAttribute("aria-haspopup", "false");
        serverLi.style.cursor = "pointer";
        serverLi.className = "server-nav-item";

        var label = document.createElement("span");
        label.textContent = "Server";
        label.style.pointerEvents = "none";
        serverLi.appendChild(label);

        var dot = document.createElement("span");
        dot.className = "sn-dot";
        serverLi.appendChild(dot);

        // Submenu (shown when connected)
        serverSubUl = document.createElement("ul");
        serverSubUl.setAttribute("role", "menu");
        serverSubUl.style.display = "none";

        var reconnLi = document.createElement("li");
        reconnLi.setAttribute("role", "menu-item");
        var reconnA = document.createElement("a");
        reconnA.href = "#";
        reconnA.textContent = "Re-connect";
        reconnA.addEventListener("click", function(e) { e.preventDefault(); e.stopPropagation(); openModal(); });
        reconnLi.appendChild(reconnA);
        serverSubUl.appendChild(reconnLi);

        var disconnLi = document.createElement("li");
        disconnLi.setAttribute("role", "menu-item");
        var disconnA = document.createElement("a");
        disconnA.href = "#";
        disconnA.textContent = "Disconnect";
        disconnA.addEventListener("click", function(e) { e.preventDefault(); e.stopPropagation(); doDisconnect(); });
        disconnLi.appendChild(disconnA);
        serverSubUl.appendChild(disconnLi);

        serverLi.appendChild(serverSubUl);

        serverLi.addEventListener("click", function(e) {
          if (!connState.connected) { e.preventDefault(); e.stopPropagation(); openModal(); }
        });

        ul.appendChild(serverLi);

        // Also add to mobile nav
        var mobileSelect = document.querySelector('.mobile-nav-select');
        if (mobileSelect) {
          var opt = document.createElement("option");
          opt.value = "__server__";
          opt.textContent = "Server...";
          mobileSelect.appendChild(opt);
          mobileSelect.addEventListener("change", function() {
            if (mobileSelect.value === "__server__") {
              mobileSelect.value = "";
              openModal();
            }
          });
        }

        buildModal();
        dispatchReady();
      }

      function buildModal() {
        modalOverlay = document.createElement("div");
        modalOverlay.className = "sn-modal-overlay";
        modalOverlay.style.display = "none";

        var dialog = document.createElement("div");
        dialog.className = "sn-modal";
        dialog.setAttribute("role", "dialog");
        dialog.setAttribute("aria-label", "Connect to server");

        dialog.innerHTML =
          '<div class="sn-modal-header">Connect to Server</div>' +
          '<form class="sn-connect-form">' +
            '<div class="sn-form-row"><label for="sn-host">Host</label><input id="sn-host" type="text" placeholder="localhost" value="localhost" spellcheck="false" autocomplete="off"></div>' +
            '<div class="sn-form-row"><label for="sn-port">Port</label><input id="sn-port" type="number" placeholder="' + defaultPort + '" value="' + defaultPort + '" min="1" max="65535"></div>' +
          '</form>' +
          '<div class="sn-modal-footer">' +
            '<button type="button" class="sn-btn" id="sn-cancel">Cancel</button>' +
            '<button type="button" class="sn-btn sn-btn-primary" id="sn-connect">Connect</button>' +
          '</div>';

        modalOverlay.appendChild(dialog);
        document.body.appendChild(modalOverlay);

        hostInput = dialog.querySelector("#sn-host");
        portInput = dialog.querySelector("#sn-port");

        dialog.querySelector("#sn-cancel").addEventListener("click", closeModal);
        dialog.querySelector("#sn-connect").addEventListener("click", doConnect);
        dialog.querySelector("form").addEventListener("submit", function(e) { e.preventDefault(); doConnect(); });
        modalOverlay.addEventListener("click", function(e) { if (e.target === modalOverlay) closeModal(); });
        document.addEventListener("keydown", function(e) { if (e.key === "Escape" && modalOverlay.style.display !== "none") closeModal(); });
      }

      function openModal() {
        if (!modalOverlay) return;
        modalOverlay.style.display = "";
        if (hostInput) setTimeout(function() { hostInput.focus(); hostInput.select(); }, 50);
      }

      function closeModal() {
        if (modalOverlay) modalOverlay.style.display = "none";
      }

      function doConnect() {
        var host = hostInput ? (hostInput.value.trim() || "localhost") : "localhost";
        var port = portInput ? (parseInt(portInput.value) || defaultPort) : defaultPort;
        var url = "http://" + host + ":" + port;
        connState.connected = true;
        updateNav();
        closeModal();
        document.dispatchEvent(new CustomEvent("navbar:connect", { detail: { service: service, host: host, port: port, url: url } }));
      }

      function doDisconnect() {
        connState.connected = false;
        updateNav();
        document.dispatchEvent(new CustomEvent("navbar:disconnect", { detail: { service: service } }));
      }

      function updateNav() {
        if (!serverLi) return;
        var dot = serverLi.querySelector(".sn-dot");
        if (connState.connected) {
          serverLi.setAttribute("aria-haspopup", "true");
          if (serverSubUl) serverSubUl.style.display = "";
          if (dot) dot.classList.add("connected");
        } else {
          serverLi.setAttribute("aria-haspopup", "false");
          if (serverSubUl) serverSubUl.style.display = "none";
          if (dot) dot.classList.remove("connected");
        }
      }

      function dispatchReady() {
        widget = {
          getUrl: function() {
            var h = hostInput ? (hostInput.value.trim() || "localhost") : "localhost";
            var p = portInput ? (parseInt(portInput.value) || defaultPort) : defaultPort;
            return "http://" + h + ":" + p;
          },
          setStatus: function(status) {
            if (status === "connected") connState.connected = true;
            else if (status === "disconnected" || status === "error" || status === "idle") connState.connected = false;
            updateNav();
          }
        };
        document.dispatchEvent(new CustomEvent("navbar:connect-ready", { detail: { service: service, widget: widget } }));
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
      } else {
        init();
      }
    })();
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 8px 16px;
    background: #000;
    color: #fff;
    z-index: 9999;
    text-decoration: none;
  }
  .skip-link:focus {
    top: 0;
  }
  .error-boundary {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 300;
    padding: 6px 12px;
    background: #000;
    color: #fff;
    font-family: var(--font-sans);
    font-size: 16px;
    text-align: center;
  }
  html {
    background: #000;
  }
  body {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #eee url('/bg-pattern.svg') repeat;
    background-size: 2.5vw 2.5vw;
    image-rendering: pixelated;
    border: 0.5vw solid #000;
    border-radius: 1.25vw;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Desktop nav (>768px) ── */
  .site-menubar {
    width: 100%;
    padding: 0.5vh 1.25vw;
    font-size: 1.96vw;
    border-bottom: 3px solid #000;
    background: #fff;
    box-sizing: border-box;
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0.75vw 0.75vw 0 0;
  }

  .site-menubar > ul {
    display: flex;
    gap: 1.875vw;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .site-menubar a {
    text-decoration: none;
    color: inherit;
  }

  .heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .heart-item:hover .heart-icon {
    filter: invert(1);
  }

  /* ── Canvas area behind the window ── */
  .site-canvas {
    flex: 1;
    display: flex;
    padding: 0.5vw 2vw;
    box-sizing: border-box;
    min-height: 0;
  }

  /* ── Inner window ── */
  .site-window {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
    border-width: 2px;
    border-right-width: 4px;
    border-bottom-width: 4px;
  }

  .site-window .title-bar .title {
    font-size: clamp(18px, 2.67vw, 42px);
  }

  .site-window .details-bar {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.75vw;
    padding: 0.3vh 2vw 0;
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(12px, 1.78vw, 24px);
  }

  .site-window .details-bar .crumb-sep {
    font-weight: 700;
  }

  .site-window .details-bar .crumb-link {
    color: #000;
    text-decoration: none;
  }
  .site-window .details-bar .crumb-link:hover {
    background: #000;
    color: #fff;
  }

  .site-window .details-bar .crumb-heart {
    display: inline-flex;
    align-items: center;
  }
  .site-window .details-bar .crumb-heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }
  .site-window .details-bar .crumb-heart:hover .crumb-heart-icon {
    filter: invert(1);
  }

  .site-window .separator {
    height: 1px;
    background: #000;
    flex-shrink: 0;
    margin-top: 0.25vh;
  }

  .site-pane {
    flex: 1;
    overflow-y: auto;
    padding: 1vw 4vw;
  }

  /* ── Mobile header: hidden on desktop ── */
  .mobile-header {
    display: none;
  }

  /* ── Back to top ── */
  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
  }
  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Switch at 768px ── */
  @media (max-width: 768px) {
    .site-menubar {
      display: none;
    }

    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 2vw 4vw;
      box-sizing: border-box;
      background: #fff;
      border-bottom: 2px solid #000;
    }

    .mobile-heart-icon {
      width: 10vw;
      height: 10vw;
      display: block;
    }

    .mobile-nav-select {
      font-size: 4vw;
      height: 10vw;
    }

    body {
      border: none;
      border-radius: 0;
    }

    .site-canvas {
      padding: 0;
    }

    .site-window {
      border-left: none;
      border-right: none;
      border-radius: 0;
    }
  }
</style>

<style is:global>
  /* ── Server nav item (injected by JS) ── */
  .server-nav-item {
    display: flex;
    align-items: center;
    gap: 0.4em;
    cursor: pointer;
  }
  .sn-dot {
    width: 0.45em;
    height: 0.45em;
    border-radius: 50%;
    background: #999;
    opacity: 0.5;
    flex-shrink: 0;
    pointer-events: none;
  }
  .sn-dot.connected {
    background: #22c55e;
    opacity: 1;
    box-shadow: 0 0 5px rgba(34,197,94,0.5);
  }

  /* ── Connect modal (injected by JS) ── */
  .sn-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    animation: sn-fade-in 0.15s ease;
  }
  @keyframes sn-fade-in { from { opacity: 0; } to { opacity: 1; } }
  .sn-modal {
    background: #fff;
    border: 3px solid #000;
    padding: 20px 24px;
    min-width: 320px;
    max-width: 90vw;
    font-family: 'Chicago', 'ChicagoFLF', system-ui, sans-serif;
    animation: sn-slide-in 0.2s ease;
  }
  @keyframes sn-slide-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
  .sn-modal-header {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #333;
    border-bottom: 1px solid #ccc;
    padding-bottom: 12px;
    margin-bottom: 16px;
  }
  .sn-modal-footer {
    border-top: 1px solid #ccc;
    padding-top: 12px;
    margin-top: 16px;
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }
  .sn-connect-form { display: flex; flex-direction: column; gap: 0; }
  .sn-form-row {
    display: grid;
    grid-template-columns: 52px 1fr;
    align-items: center;
    border-bottom: 1px solid #eee;
    padding: 8px 0;
  }
  .sn-form-row:last-child { border-bottom: none; }
  .sn-form-row label {
    font-size: 11px;
    font-weight: 500;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .sn-form-row input {
    width: 100%;
    background: #f5f5f5;
    border: 1px solid #ccc;
    color: #000;
    font-size: 13px;
    padding: 6px 9px;
    outline: none;
    font-family: monospace;
    box-sizing: border-box;
  }
  .sn-form-row input:focus { border-color: #0066cc; }
  .sn-form-row input::-webkit-inner-spin-button,
  .sn-form-row input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
  .sn-form-row input[type=number] { -moz-appearance: textfield; }
  .sn-btn {
    height: 28px;
    padding: 0 16px;
    font-size: 12px;
    border: 2px solid #000;
    cursor: pointer;
    background: #fff;
    color: #000;
    font-family: 'Chicago', 'ChicagoFLF', system-ui, sans-serif;
  }
  .sn-btn:hover { background: #000; color: #fff; }
  .sn-btn-primary { background: #000; color: #fff; }
  .sn-btn-primary:hover { background: #333; }
</style>
