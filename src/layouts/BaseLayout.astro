---
import { siteConfig } from '../config/site';
import '../styles/tokens.css';
import '../styles/base.css';
import ServerConnectModal from '../components/ServerConnectModal.astro';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  breadcrumbs?: Crumb[];
}

const { title, description, ogImage, breadcrumbs: customBreadcrumbs } = Astro.props;
const pageTitle = title ? `${title} | ${siteConfig.title}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const isPreviewDeploy = import.meta.env.PREVIEW_DEPLOY === 'true';
const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const windowTitle = title || siteConfig.title;

// Auto-generate breadcrumbs from URL path (unless custom ones provided)
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = pathname === '/';
let breadcrumbs: Crumb[] = [];

if (customBreadcrumbs) {
  breadcrumbs = customBreadcrumbs;
} else if (!isHome) {
  const segments = pathname.split('/').filter(Boolean);
  for (let i = 0; i < segments.length; i++) {
    const isLast = i === segments.length - 1;
    const href = '/' + segments.slice(0, i + 1).join('/') + '/';
    const label =
      isLast && title
        ? title
        : segments[i].replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    breadcrumbs.push({ label, href: isLast ? undefined : href });
  }
}

// Details bar text
const detailsSegments = isHome
  ? [
      { text: '~', bold: false, href: '/', isHeart: true },
      { text: '/', bold: true },
    ]
  : [
      { text: '~', bold: false, href: '/', isHeart: true },
      ...breadcrumbs.flatMap((crumb, i) => [
        { text: '/', bold: true },
        { text: crumb.label.toLowerCase(), bold: false, href: crumb.href },
      ]),
    ];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    {isPreviewDeploy && <meta name="robots" content="noindex, nofollow" />}
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- system.css — System 6 UI framework -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/@sakun/system.css@0.1.11/dist/system.css"
      crossorigin="anonymous"
      integrity="sha384-rwwdSfFF9LapWjf16N2Gtcd61dN6gtugqy9A72EU+IlLyrRH3qpyb0T686o8cqh0"
    />
    <!-- Bootstrap Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    />
    <slot name="head" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content={siteConfig.title} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: siteConfig.displayName,
        url: canonicalUrl.href,
        jobTitle: 'Quantum Researcher',
        sameAs: [siteConfig.github, siteConfig.linkedin].filter(Boolean),
      })}
    />

    {
      plausibleDomain && (
        <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.js" />
      )
    }

    <!-- Error boundary removed — app pages handle errors via their own UI -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <!-- Desktop menubar (>768px) -->
    <nav class="site-menubar" aria-label="Main navigation">
      <ul role="menu-bar">
        <li role="menu-item" class="heart-item">
          <a href="/"
            ><img src="/icons/heart.svg" alt="Home" class="heart-icon" width="36" height="36" /></a
          >
        </li>
        <li role="menu-item"><a href="/projects/">Projects</a></li>
        <li role="menu-item"><a href="/about">About</a></li>
      </ul>
    </nav>

    <!-- Mobile header (≤768px) -->
    <div class="mobile-header" aria-label="Mobile navigation">
      <a href="/" class="mobile-heart">
        <img src="/icons/heart.svg" alt="Home" width="40" height="40" class="mobile-heart-icon" />
      </a>
      <select class="mobile-nav-select" aria-label="Navigate to">
        <option value="">Navigate...</option>
        <option value="/about/">About</option>
        <option value="/projects/">Projects</option>
      </select>
    </div>

    <div class="site-canvas">
      <div class="window site-window">
        <div class="title-bar">
          <h1 class="title">{windowTitle}</h1>
        </div>
        <div class="details-bar">
          {
            detailsSegments.map((seg) =>
              seg.bold ? (
                <span class="crumb-sep">{seg.text}</span>
              ) : seg.isHeart ? (
                <a href={seg.href} class="crumb-link crumb-heart">
                  <img src="/icons/heart_light.svg" alt="Home" class="crumb-heart-icon" />
                </a>
              ) : seg.href ? (
                <a href={seg.href} class="crumb-link">
                  {seg.text}
                </a>
              ) : (
                <span>{seg.text}</span>
              ),
            )
          }
        </div>
        <slot name="details-bar" />
        <div class="window-pane site-pane" id="main-content">
          <slot />
        </div>
      </div>
    </div>

    <button id="back-to-top" class="btn back-to-top" aria-label="Back to top" type="button">
      &uarr; Top
    </button>

    <script>
      // Mobile nav select
      const sel = document.querySelector('.mobile-nav-select') as HTMLSelectElement | null;
      if (sel) {
        sel.addEventListener('change', () => {
          if (sel.value) window.location.href = sel.value;
        });
      }

      // Back to top
      const btn = document.getElementById('back-to-top');
      if (btn) {
        const pane = document.querySelector('.site-pane');
        const scrollTarget = pane || window;
        const getScroll = () => (pane ? pane.scrollTop : window.scrollY);
        (pane || window).addEventListener('scroll', () => {
          btn.classList.toggle('visible', getScroll() > 400);
        });
        btn.addEventListener('click', () => {
          (pane || window).scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>

    <ServerConnectModal />
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    padding: 8px 16px;
    background: #000;
    color: #fff;
    z-index: 9999;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 0;
  }

  html {
    background: #000;
  }

  body {
    display: flex;
    flex-direction: column;
    height: 100vh;
    background: #eee url('/bg-pattern.svg') repeat;
    background-size: 2.5vw 2.5vw;
    image-rendering: pixelated;
    border: 0.5vw solid #000;
    border-radius: 1.25vw;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* ── Desktop nav (>768px) ── */
  .site-menubar {
    width: 100%;
    padding: 0.5vh 1.25vw;
    font-size: clamp(0.875rem, 1.96vw, 1.5rem);
    border-bottom: 3px solid #000;
    background: #fff;
    box-sizing: border-box;
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0.75vw 0.75vw 0 0;
  }

  .site-menubar > ul {
    display: flex;
    gap: 1.875vw;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .site-menubar a {
    text-decoration: none;
    color: inherit;
  }

  .heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .heart-item:hover .heart-icon {
    filter: invert(1);
  }

  /* ── Canvas area behind the window ── */
  .site-canvas {
    flex: 1;
    display: flex;
    padding: 0.5vw 2vw;
    box-sizing: border-box;
    min-height: 0;
  }

  /* ── Inner window ── */
  .site-window {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 0;
    border-width: 2px;
    border-right-width: 4px;
    border-bottom-width: 4px;
  }

  .site-window .title-bar .title {
    font-size: clamp(18px, 2.67vw, 42px);
  }

  .site-window .details-bar {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.75vw;
    padding: 0.3vh 2vw 0;
    font-family: var(--font-ui);
    font-size: clamp(12px, 1.78vw, 24px);
  }

  .site-window .details-bar .crumb-sep {
    font-weight: 700;
  }

  .site-window .details-bar .crumb-link {
    color: #000;
    text-decoration: none;
  }

  .site-window .details-bar .crumb-link:hover {
    background: #000;
    color: #fff;
  }

  .site-window .details-bar .crumb-heart {
    display: inline-flex;
    align-items: center;
  }

  .site-window .details-bar .crumb-heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .site-window .details-bar .crumb-heart:hover .crumb-heart-icon {
    filter: invert(1);
  }

  .site-window .separator {
    height: 1px;
    background: #000;
    flex-shrink: 0;
    margin-top: 0.25vh;
  }

  .site-pane {
    flex: 1;
    overflow-y: auto;
    padding: 1vw 4vw;
  }

  /* ── Mobile header: hidden on desktop ── */
  .mobile-header {
    display: none;
  }

  /* ── Back to top ── */
  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: 100;
    opacity: 0;
    pointer-events: none;
  }

  .back-to-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Switch at 768px ── */
  @media (width <= 768px) {
    .site-menubar {
      display: none;
    }

    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 2vw 4vw;
      box-sizing: border-box;
      background: #fff;
      border-bottom: 2px solid #000;
    }

    .mobile-heart-icon {
      width: 10vw;
      height: 10vw;
      display: block;
    }

    .mobile-nav-select {
      font-size: clamp(0.875rem, 4vw, 1.5rem);
      height: 10vw;
    }

    body {
      border: none;
      border-radius: 0;
    }

    .site-canvas {
      padding: 0;
    }

    .site-window {
      border-left: none;
      border-right: none;
      border-radius: 0;
    }
  }
</style>
