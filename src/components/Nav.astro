---
import { siteConfig } from '../config/site';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/skills', label: 'Skills' },
  { href: '/resume', label: 'Resume' },
  { href: '/contact', label: 'Contact' },
];
---

<!-- system.css native menu-bar -->
<nav aria-label="Main navigation">
  <ul role="menu-bar" class="site-menu-bar">
    <li role="menu-item" class="menu-brand">
      <a href="/">{siteConfig.firstName}</a>
    </li>
    {links.map(({ href, label }) => (
      <li
        role="menu-item"
        class:list={{ active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }}
      >
        <a
          href={href}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile: hamburger + dropdown -->
  <div class="mobile-bar">
    <a href="/" class="mobile-brand">{siteConfig.firstName}</a>
    <button class="btn mobile-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu" type="button">
      Menu
    </button>
  </div>
  <ul role="menu" id="mobile-menu" class="mobile-menu">
    {links.map(({ href, label }) => (
      <li role="menu-item">
        <a
          href={href}
          class:list={{ active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const menu = document.getElementById('mobile-menu') as HTMLElement;
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = menu.style.display === 'block';
      menu.style.display = open ? 'none' : 'block';
      toggle.setAttribute('aria-expanded', String(!open));
    });
  }
</script>

<style>
  nav {
    border-bottom: 2px solid #000;
  }
  /* system.css menu-bar is already styled — we just adjust spacing */
  .site-menu-bar {
    flex-wrap: wrap;
  }
  .site-menu-bar a {
    text-decoration: none;
    color: inherit;
    display: block;
    padding: 0;
  }
  .site-menu-bar [role="menu-item"].active {
    background: #000;
    color: #fff;
  }
  .menu-brand {
    font-weight: 700;
    margin-right: auto;
  }
  .menu-brand a {
    font-weight: 700;
  }

  /* Mobile nav */
  .mobile-bar {
    display: none;
    align-items: center;
    justify-content: space-between;
    padding: 4px 8px;
  }
  .mobile-brand {
    font-family: Chicago_12, Chicago, Geneva, system-ui, sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #000;
    text-decoration: none;
  }
  .mobile-brand:hover { background: #000; color: #fff; }
  .mobile-menu {
    display: none;
  }
  .mobile-menu a.active {
    background: #000;
    color: #fff;
  }

  @media (max-width: 768px) {
    .site-menu-bar { display: none !important; }
    .mobile-bar { display: flex; }
  }
</style>
