---
import { siteConfig } from '../config/site';
import { projects } from '../data/projects';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav class="ui-navbar site-navbar" aria-label="Main navigation">
  <ul role="menu-bar">
    <li role="menu-item" aria-haspopup="false" class="heart-item">
      <a href="/" aria-current={isActive('/') ? 'page' : undefined} class:list={[{ active: isActive('/') }]}><img src="/icons/heart.svg" alt="Home" class="heart-icon" /></a>
    </li>
    <li role="menu-item" aria-haspopup="false">
      <a href="/about" aria-current={isActive('/about') ? 'page' : undefined} class:list={[{ active: isActive('/about') }]}>About</a>
    </li>
    <li role="menu-item" aria-haspopup="true" tabindex="0">Projects
      <ul role="menu">
        {projects.map((project) => {
          const href = project.appUrl || `/projects/${project.slug}/`;
          return (
            <li role="menu-item">
              <a href={href} aria-current={isActive(href) ? 'page' : undefined} class:list={[{ active: isActive(href) }]}>{project.title}</a>
            </li>
          );
        })}
      </ul>
    </li>
    <li role="menu-item" aria-haspopup="false">
      <a href="/contact" aria-current={isActive('/contact') ? 'page' : undefined} class:list={[{ active: isActive('/contact') }]}>Contact</a>
    </li>
  </ul>
</nav>

<style>
  .site-navbar {
    padding-top: 4px;
    padding-bottom: 4px;
    padding-left: 12px;
    border-bottom: 2px solid #000;
  }
  .site-navbar [role="menu-item"] {
    font-weight: 400;
    margin-top: 2px;
  }
  .site-navbar a.active {
    font-weight: 700;
  }
  .heart-icon {
    width: 24px;
    height: 24px;
    display: block;
  }
  .heart-item:hover .heart-icon {
    filter: invert(1);
  }
</style>
