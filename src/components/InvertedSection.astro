---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<section class:list={['inverted-section', className]}>
  <div class="container">
    <slot />
  </div>
</section>

<style>
  .inverted-section {
    background: #000;
    color: #fff;
    padding: var(--space-8) 0;
    border-top: 2px solid #000;
    border-bottom: 2px solid #000;
  }
  .inverted-section :global(a) { color: #fff; }
  .inverted-section :global(a:hover) { background: #fff; color: #000; }
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }
</style>
