---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<div class:list={['section-label', className]}>
  <div class="section-label-rule"></div>
  <span class="section-label-text">{label}</span>
</div>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }
  .section-label-rule {
    width: 24px;
    height: 1px;
    background: var(--color-text-muted);
    flex-shrink: 0;
  }
  .section-label-text {
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
  }
</style>
