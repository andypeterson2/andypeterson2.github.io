---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className } = Astro.props;
---

<div class:list={['section-label', className]}>
  <div class="section-label-rule"></div>
  <span class="section-label-text">{label}</span>
</div>

<style>
  .section-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }
  .section-label-rule {
    width: 24px;
    height: 2px;
    background: #000;
    flex-shrink: 0;
  }
  .section-label-text {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000;
    white-space: nowrap;
  }
</style>
