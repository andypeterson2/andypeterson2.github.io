<!-- App UI -->
<div id="classifier-app">
  <!-- Top bar -->
  <header class="app-navbar">
    <div class="navbar-left">
      <button id="dataset-menu-btn" class="btn" aria-haspopup="true">Dataset &#9662;</button>
      <div id="dataset-menu" class="dropdown hidden" role="menu">
        <div id="dataset-list"></div>
      </div>
    </div>
    <div class="navbar-right"></div>
  </header>

  <!-- Main layout -->
  <div id="split-layout" class="split-layout">
    <!-- Left column -->
    <aside id="left-col" class="left-col">
      <!-- TRAIN card -->
      <section class="card">
        <h2 class="card-title">Train</h2>
        <label for="model-type">Model</label>
        <select id="model-type"></select>

        <div id="model-info-details" class="hidden">
          <div id="model-info-panel"></div>
        </div>

        <label for="model-name">Name</label>
        <input id="model-name" type="text" placeholder="auto" />

        <label for="epochs">Epochs</label>
        <input id="epochs" type="number" value="10" min="1" />

        <label for="batch-size">Batch size</label>
        <input id="batch-size" type="number" value="64" min="1" />

        <label for="lr">Learning rate</label>
        <input id="lr" type="number" value="0.01" step="0.001" min="0" />

        <details class="advanced-toggle">
          <summary>Advanced</summary>
          <label for="patience">Patience (early stop)</label>
          <input id="patience" type="number" placeholder="disabled" min="1" />

          <label for="val-gap">Val every N batches</label>
          <input id="val-gap" type="number" value="50" min="1" />

          <label for="teacher-select">Distill from</label>
          <select id="teacher-select">
            <option value="">-- none --</option>
          </select>

          <div id="distill-row" class="hidden">
            <label for="distill-weight">Distill weight (alpha)</label>
            <input id="distill-weight" type="number" value="0.5" step="0.1" min="0" max="1" />
          </div>
        </details>

        <button id="train-btn" class="btn btn-primary btn-block">&#9654; Train</button>
      </section>

      <!-- MODELS card -->
      <section class="card">
        <h2 class="card-title">Models</h2>
        <div id="session-models"></div>
        <button id="ensemble-btn" class="btn btn-block hidden">Ensemble</button>
      </section>

      <!-- SAVED card -->
      <section class="card">
        <h2 class="card-title">Saved</h2>
        <div class="row">
          <select id="saved-select"><option value="">-- no saved models --</option></select>
          <button id="refresh-saved-btn" class="btn btn-sm" aria-label="Refresh">&#8635;</button>
        </div>
        <button id="import-btn" class="btn btn-block" disabled>Import</button>
      </section>
    </aside>

    <!-- Resize handle -->
    <div id="resize-h" class="resize-handle"></div>

    <!-- Right column -->
    <main class="right-col">
      <!-- Draw card (image input) -->
      <section class="card" id="canvas-col" style="display:none">
        <h2 class="card-title">Draw</h2>
        <canvas id="draw-canvas" width="280" height="280"></canvas>
        <div class="row">
          <button id="clear-btn" class="btn">Clear</button>
          <button id="predict-btn" class="btn btn-primary">Predict</button>
        </div>
      </section>

      <!-- Tabular input card -->
      <section class="card" id="tabular-col" style="display:none">
        <h2 class="card-title">Predict</h2>
        <div class="feature-inputs"></div>
        <button id="predict-btn-tab" class="btn btn-primary btn-block">Predict</button>
      </section>

      <!-- Predictions -->
      <section class="card">
        <h2 class="card-title">Predictions</h2>
        <table class="app-table">
          <thead><tr><th>Model</th><th>Prediction</th><th>Confidence</th></tr></thead>
          <tbody id="pred-body">
            <tr class="empty-row"><td colspan="3">No prediction yet</td></tr>
          </tbody>
        </table>
      </section>

      <!-- Chart area -->
      <div id="chart-area" class="card hidden">
        <canvas id="train-chart" width="600" height="250"></canvas>
      </div>

      <!-- Evaluation -->
      <section class="card">
        <h2 class="card-title">Evaluation</h2>
        <div id="evaluate-progress" class="hidden">
          <div class="progress-bar" role="progressbar">
            <div id="eval-bar" class="progress-bar-fill"></div>
          </div>
          <span id="eval-status"></span>
        </div>
        <div class="metrics-wrap">
          <table class="app-table metrics-table">
            <thead id="metrics-head"></thead>
            <tbody id="metrics-body">
              <tr class="empty-row"><td>No models trained yet</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>

  <!-- Log drawer -->
  <div id="log-drawer" class="log-drawer">
    <div id="log-handle" class="log-handle" aria-label="Resize log panel">Log</div>
    <pre id="log-terminal" class="log-terminal"></pre>
  </div>
</div>

<!-- Scripts -->
<script is:inline src="/classifiers/js/connection.js"></script>
<script is:inline src="/classifiers/js/sse.js"></script>
<script is:inline src="/classifiers/js/chart.js"></script>
<script is:inline src="/classifiers/js/app.js"></script>

<style>
  /* ── App layout ── */
  #classifier-app {
    display: flex;
    flex-direction: column;
    height: 100%;
    font-size: clamp(9px, 1.2vw, 14px);
  }

  .app-navbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 4px 8px;
    border-bottom: 2px solid #000;
    background: #eee;
    flex-shrink: 0;
  }

  .navbar-left {
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
  }

  .navbar-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* ── Dropdown ── */
  .dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 2px solid #000;
    z-index: 50;
    min-width: 150px;
  }

  .dropdown.hidden {
    display: none;
  }

  :global(.ui-dropdown-item) {
    display: block;
    width: 100%;
    padding: 4px 10px;
    border: none;
    background: none;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
  }

  :global(.ui-dropdown-item:hover),
  :global(.ui-dropdown-item.active) {
    background: #000;
    color: #fff;
  }

  /* ── Split layout ── */
  .split-layout {
    display: flex;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .left-col {
    overflow-y: auto;
    padding: 8px;
    flex-shrink: 0;
    border-right: 2px solid #000;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .right-col {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .resize-handle {
    width: 5px;
    cursor: col-resize;
    background: #ccc;
    flex-shrink: 0;
  }

  .resize-handle:hover {
    background: #999;
  }

  /* ── Cards ── */
  .card {
    border: 2px solid #000;
    padding: 8px 10px;
    background: #fff;
  }

  .card-title {
    font-size: clamp(11px, 1.5vw, 18px);
    font-weight: 700;
    margin: 0 0 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Forms ── */
  label {
    display: block;
    font-size: clamp(9px, 1.1vw, 13px);
    font-weight: 600;
    margin: 4px 0 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  select,
  input[type='number'],
  input[type='text'] {
    width: 100%;
    box-sizing: border-box;
    font-family: inherit;
    font-size: clamp(9px, 1.2vw, 14px);
    padding: 3px 6px;
    border: 1.5px solid #000;
    background: #fff;
  }

  .advanced-toggle summary {
    cursor: pointer;
    font-size: clamp(9px, 1.1vw, 13px);
    font-weight: 600;
    margin: 6px 0 4px;
  }

  /* ── Buttons ── */
  .btn {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1.2vw, 14px);
    padding: 3px 10px;
    border: 2px solid #000;
    background: #fff;
    color: #000;
    cursor: pointer;
  }

  .btn:hover {
    background: #000;
    color: #fff;
  }

  .btn-primary {
    background: #000;
    color: #fff;
  }

  .btn-primary:hover {
    background: #333;
  }

  .btn-danger {
    color: #c00;
  }

  .btn-danger:hover {
    background: #c00;
    color: #fff;
  }

  .btn-block {
    display: block;
    width: 100%;
    margin-top: 6px;
  }

  .btn-sm {
    font-size: clamp(8px, 1vw, 12px);
    padding: 2px 6px;
  }

  .btn:disabled {
    opacity: 0.4;
    cursor: default;
  }

  /* ── Row helper ── */
  .row {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .row select {
    flex: 1;
    min-width: 0;
  }

  /* ── Model rows ── */
  :global(.model-row) {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 0;
    border-bottom: 1px solid #ddd;
    flex-wrap: wrap;
  }

  :global(.model-name) {
    font-weight: 600;
  }

  :global(.model-tag) {
    font-size: clamp(8px, 1vw, 12px);
    padding: 1px 5px;
    border: 1px solid #999;
    color: #666;
  }

  :global(.empty-msg) {
    color: #999;
    font-size: clamp(9px, 1.1vw, 13px);
  }

  /* ── Tables ── */
  .app-table {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(9px, 1.1vw, 13px);
  }

  .app-table th,
  .app-table td {
    padding: 3px 6px;
    border-bottom: 1px solid #ddd;
    text-align: left;
  }

  .app-table th {
    font-weight: 700;
    background: #f5f5f5;
  }

  .metrics-wrap {
    overflow: auto;
    max-height: 300px;
  }

  :global(.corner-cell) {
    min-width: 80px;
    position: sticky;
    left: 0;
    z-index: 3;
    background: #f5f5f5;
  }

  :global(.model-col-head) {
    min-width: 80px;
  }

  :global(.col-model-name) {
    font-weight: 600;
  }

  :global(.metrics-section-row > td) {
    background: #eee;
    color: #666;
    font-size: clamp(8px, 1vw, 11px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 6px;
    border-top: 1px solid #ccc;
  }

  :global(.metric-label) {
    background: #f5f5f5;
    font-size: clamp(8px, 1vw, 12px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    padding: 3px 6px;
    text-align: left;
    position: sticky;
    left: 0;
    z-index: 2;
    border-right: 1px solid #ddd;
  }

  :global(.cfg-cell) {
    color: #666;
  }

  /* ── Colour helpers ── */
  :global(.pred-label) {
    font-weight: 700;
  }

  :global(.pred-model-name) {
    color: #666;
  }

  :global(.conf-high) {
    color: #16a34a;
  }

  :global(.conf-low) {
    color: #999;
  }

  :global(.acc-high) {
    color: #16a34a;
  }

  :global(.acc-med) {
    color: #d97706;
  }

  :global(.acc-low) {
    color: #dc2626;
  }

  /* ── Canvas ── */
  #draw-canvas {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1;
    border: 2px solid #000;
    cursor: crosshair;
    image-rendering: pixelated;
  }

  /* ── Chart ── */
  #chart-area canvas {
    width: 100%;
    display: block;
  }

  /* ── Progress bar ── */
  .progress-bar {
    height: 14px;
    background: #eee;
    border: 1.5px solid #000;
    margin-bottom: 4px;
  }

  .progress-bar-fill {
    height: 100%;
    background: #000;
    width: 0%;
    transition: width 0.2s;
  }

  /* ── Log drawer ── */
  .log-drawer {
    border-top: 2px solid #000;
    background: #fff;
    max-height: 30vh;
    overflow: hidden;
    flex-shrink: 0;
  }

  .log-drawer.open {
    max-height: 50vh;
  }

  .log-handle {
    padding: 2px 8px;
    font-size: clamp(8px, 1vw, 12px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: #eee;
    cursor: pointer;
    border-bottom: 1px solid #ccc;
  }

  .log-terminal {
    font-family: monospace;
    font-size: clamp(8px, 1vw, 12px);
    padding: 4px 8px;
    overflow-y: auto;
    max-height: calc(30vh - 24px);
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
  }

  :global(.log-entry) {
    display: flex;
    gap: 8px;
    line-height: 1.4;
  }

  :global(.log-time) {
    color: #999;
    flex-shrink: 0;
  }

  :global(.log-msg) {
    color: #333;
  }

  :global(.log-ok) {
    color: #16a34a;
  }

  :global(.log-err) {
    color: #dc2626;
  }

  /* ── Hidden helper ── */
  .hidden {
    display: none !important;
  }

  /* ── Mobile ── */
  @media (width <= 768px) {
    .split-layout {
      flex-direction: column;
    }

    .left-col {
      border-right: none;
      border-bottom: 2px solid #000;
      width: 100% !important;
    }

    .resize-handle {
      display: none;
    }
  }
</style>
