---
import ClassifierNavbar from './classifier/ClassifierNavbar.astro';
import ClassifierTrainCard from './classifier/ClassifierTrainCard.astro';
import ClassifierModelsCard from './classifier/ClassifierModelsCard.astro';
import ClassifierResultsPanel from './classifier/ClassifierResultsPanel.astro';
import ClassifierLogDrawer from './classifier/ClassifierLogDrawer.astro';
import '../styles/classifier.css';
---

<div id="classifier-app">
  <ClassifierNavbar />

  <div id="split-layout" class="split-layout">
    <aside id="left-col" class="left-col">
      <ClassifierTrainCard />
      <ClassifierModelsCard />
    </aside>
    <div id="resize-h" class="resize-handle"></div>
    <main class="right-col">
      <ClassifierResultsPanel />
    </main>
  </div>

  <ClassifierLogDrawer />
</div>

<!-- ui-kit runtime: defines the global UIKit (icons.js first — supplies UIKit.ICONS) -->
<script is:inline src="/ui-kit/icons.js"></script>
<script is:inline src="/ui-kit/ui-kit.js"></script>
<script is:inline src="/classifiers/js/connection.js"></script>
<script is:inline src="/classifiers/js/sse.js"></script>
<script is:inline src="/classifiers/js/chart.js"></script>
<!--
  app.js expects two globals the old Flask template used to inject: API_BASE and a
  per-dataset UI_CONFIG. The portal embed has neither (so it previously threw at
  load). Bootstrap them: resolve the gateway base, fetch the dataset list + the
  first dataset's config from the backend, then load app.js.
-->
<script is:inline>
  function bootClassifier() {
    (async function () {
    var base =
      window.ServiceConfig && window.ServiceConfig.serviceBase
        ? window.ServiceConfig.serviceBase('classifiers')
        : '';
    window.API_BASE = base;
    try {
      var datasets = await fetch(base + '/api/datasets').then(function (r) {
        return r.json();
      });
      var name = datasets && datasets[0] && datasets[0].name;
      if (name) {
        var cfg = await fetch(base + '/api/datasets/' + name + '/config').then(function (r) {
          return r.json();
        });
        window.UI_CONFIG = cfg.ui_config;
      }
    } catch (e) {
      console.error('[classifiers] failed to load dataset UI config', e);
    }
    var s = document.createElement('script');
    s.src = '/classifiers/js/app.js';
    s.async = false;
    document.body.appendChild(s);
    })();
  }
  // Defer until service-config.js has loaded (it's loaded later via ServerConnectModal).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootClassifier);
  } else {
    bootClassifier();
  }
</script>

<style>
  #classifier-app {
    display: flex;
    flex-direction: column;
    height: 100%;
    font-size: clamp(9px, 1.2vw, 14px);
  }

  .split-layout {
    display: flex;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .left-col {
    overflow-y: auto;
    padding: 8px;
    flex-shrink: 0;
    border-right: 2px solid #000;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .right-col {
    flex: 1;
    overflow-y: auto;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .resize-handle {
    width: 5px;
    cursor: col-resize;
    background: #ccc;
    flex-shrink: 0;
  }

  .resize-handle:hover {
    background: #999;
  }

  @media (width <= 768px) {
    .split-layout {
      flex-direction: column;
    }

    .left-col {
      border-right: none;
      border-bottom: 2px solid #000;
      width: 100% !important;
    }

    .resize-handle {
      display: none;
    }
  }
</style>
