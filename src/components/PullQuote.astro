---
interface Props {
  cite?: string;
}

const { cite } = Astro.props;
---

<blockquote class="pull-quote">
  <p><slot /></p>
  {cite && <cite>— {cite}</cite>}
</blockquote>

<style>
  .pull-quote {
    margin: var(--space-8) 0;
    padding: var(--space-4) var(--space-6);
    border-left: 4px solid #000;
    border-top: 1px solid #000;
    border-bottom: 1px solid #000;
  }
  .pull-quote p {
    font-size: 16px;
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 0;
  }
  .pull-quote cite {
    display: block;
    margin-top: var(--space-2);
    font-family: Monaco, ui-monospace, monospace;
    font-size: 12px;
    font-style: normal;
    color: #666;
  }
</style>
