---
interface Props {
  variant?: 'default' | 'accent' | 'teal' | 'purple' | 'blue';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;
---

<span class:list={['tag', `tag-${variant}`, className]}>
  <slot />
</span>

<style>
  .tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 500;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .tag-default { color: var(--color-text-muted); }
  .tag-accent { color: var(--color-accent); border-color: var(--color-accent); }
  .tag-teal { color: var(--color-accent-teal); border-color: var(--color-accent-teal); }
  .tag-purple { color: var(--color-accent-purple); border-color: var(--color-accent-purple); }
  .tag-blue { color: var(--color-accent-blue); border-color: var(--color-accent-blue); }
</style>
