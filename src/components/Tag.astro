---
interface Props {
  variant?: 'default' | 'accent';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;
---

<span class:list={['tag', `tag-${variant}`, className]}>
  <slot />
</span>

<style>
  .tag {
    display: inline-block;
    font-family: Chicago_12, Chicago, Geneva, system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    padding: 1px 5px;
    border: 1.5px solid #000;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: #fff;
    color: #000;
  }
  .tag-accent {
    background: #000;
    color: #fff;
  }
</style>
