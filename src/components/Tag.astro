---
interface Props {
  variant?: 'default' | 'accent';
  class?: string;
}

const { variant = 'default', class: className } = Astro.props;
---

<span class:list={['tag', `tag-${variant}`, className]}>
  <slot />
</span>

<style>
  .tag {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 6px;
    border: 2px solid #000;
    font-family: Chicago_12, Chicago, Geneva, system-ui, sans-serif;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: #fff;
    color: #000;
  }
  .tag-default { }
  .tag-accent { background: #000; color: #fff; }
</style>
