---
import { siteConfig } from '../config/site';
const year = new Date().getFullYear();
---

<div class="details-bar footer-bar">
  <span>&copy; {year} {siteConfig.displayName}</span>
  <span class="footer-links">
    {siteConfig.github && <a href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub</a>}
    {siteConfig.linkedin && <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>}
    {siteConfig.email && <a href={`mailto:${siteConfig.email}`}>Email</a>}
    <span class="built-with">Built with Astro</span>
  </span>
</div>

<style>
  .footer-bar {
    padding-top: var(--space-8);
    font-family: var(--font-sans);
    font-size: 13px;
  }
  .footer-links {
    display: flex;
    gap: var(--space-4);
  }
  .footer-links a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: #000;
    text-decoration: underline;
  }
  .footer-links a:hover {
    background: #000;
    color: #fff;
  }
</style>
