---
import { siteConfig } from '../config/site';
const year = new Date().getFullYear();
---

<footer>
  <div class="separator"></div>
  <div class="details-bar">
    <span>&copy; {year} {siteConfig.displayName} &mdash; Built with Astro</span>
    <span class="footer-links">
      {siteConfig.github && <a href={siteConfig.github} target="_blank" rel="noopener noreferrer">GitHub</a>}
      {siteConfig.linkedin && <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>}
      {siteConfig.email && <a href={`mailto:${siteConfig.email}`}>Email</a>}
    </span>
  </div>
</footer>

<style>
  footer {
    margin-top: var(--space-12);
  }
  .footer-links {
    display: flex;
    gap: var(--space-4);
  }
  .footer-links a {
    font-size: 12px;
    color: #000;
    text-decoration: underline;
  }
  .footer-links a:hover {
    background: #000;
    color: #fff;
  }
</style>
