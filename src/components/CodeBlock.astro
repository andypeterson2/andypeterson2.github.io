---
interface Props {
  language?: string;
  filename?: string;
  class?: string;
}

const { language, filename, class: className } = Astro.props;
---

<div class:list={['code-block', className]}>
  {filename && (
    <div class="code-block-header">
      <span class="code-block-filename">{filename}</span>
      {language && <span class="code-block-lang">{language}</span>}
    </div>
  )}
  <pre class="code-block-pre"><code><slot /></code></pre>
</div>

<style>
  .code-block {
    border: 1px solid var(--color-border);
    overflow: hidden;
  }
  .code-block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface-2);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }
  .code-block-filename { color: var(--color-text-muted); }
  .code-block-lang {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .code-block-pre {
    margin: 0;
    padding: var(--space-4);
    background: var(--color-surface);
    border: none;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    overflow-x: auto;
  }
  .code-block-pre code {
    background: none;
    padding: 0;
    border: none;
  }
</style>
