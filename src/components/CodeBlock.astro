---
interface Props {
  language?: string;
  filename?: string;
  class?: string;
}

const { language, filename, class: className } = Astro.props;
---

<div class:list={['standard-dialog', 'code-block', className]}>
  {filename && (
    <div class="code-block-header">
      <span class="code-block-filename">{filename}</span>
      {language && <span class="code-block-lang">{language}</span>}
    </div>
  )}
  <pre class="code-block-pre"><code><slot /></code></pre>
</div>

<style>
  .code-block { padding: 0; overflow: hidden; }
  .code-block-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 8px;
    border-bottom: 2px solid #000;
    font-family: var(--font-mono);
    font-size: 11px;
  }
  .code-block-filename { color: #666; }
  .code-block-lang {
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .code-block-pre {
    margin: 0;
    padding: var(--space-4);
    border: none;
    box-shadow: none;
    font-size: 12px;
    line-height: 1.6;
    overflow-x: auto;
  }
  .code-block-pre code {
    background: none;
    padding: 0;
    border: none;
  }
</style>
