---
interface Props {
  title?: string;
  href?: string;
  class?: string;
}

const { title, href, class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['card', { 'card-link': !!href }, className]} href={href}>
  {title && <h3 class="card-title">{title}</h3>}
  <div class="card-body">
    <slot />
  </div>
</Tag>

<style>
  .card {
    background: #fff;
    border: 2px solid #000;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-family: var(--font-sans);
  }
  .card-link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .card-link:hover {
    background: #000;
    color: #fff;
  }
  .card-link:hover .card-title { color: #fff; }
  .card-link:hover .card-body { color: #fff; }
  .card-title {
    font-family: Chicago_12, Chicago, Geneva, system-ui, sans-serif;
    font-size: 1.2em;
    font-weight: 700;
    color: #000;
    border: none;
    padding: 0;
  }
  .card-body {
    color: #000;
    font-size: var(--text-sm);
    line-height: 1.5;
  }
</style>
