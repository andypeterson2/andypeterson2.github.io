---
interface Props {
  title?: string;
  href?: string;
  class?: string;
}

const { title, href, class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['standard-dialog', 'card', { 'card-link': !!href }, className]} href={href}>
  {title && <h3 class="card-title">{title}</h3>}
  <div class="card-body">
    <slot />
  </div>
</Tag>

<style>
  /* system.css .standard-dialog gives us: border: 2px solid, box-shadow: 2px 2px, padding: 10px, white bg */
  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .card-link {
    text-decoration: none;
    color: #000;
    cursor: pointer;
  }
  .card-link:hover {
    background: #000;
    color: #fff;
  }
  .card-link:hover .card-title,
  .card-link:hover .card-body { color: #fff; }
  .card-title {
    font-family: var(--font-sans);
    font-size: 1.1em;
    font-weight: 700;
  }
  .card-body {
    font-size: 14px;
    line-height: 1.5;
  }
</style>
