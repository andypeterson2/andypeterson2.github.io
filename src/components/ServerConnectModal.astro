---
/**
 * Server-connect modal — adds nav items and connection dialogs for each
 * backend service declared on the page.
 *
 * Meta-tag format:
 *   <meta name="site-backend" content="service-key" data-port="8080" data-label="Label">
 *
 * Each service gets its own navbar item (with status dot), dropdown, and modal.
 */
---

<script is:inline src="/js/server-connect-modal.js"></script>

<style is:global>
  /* ── Server nav item (injected by JS) ── */
  .server-nav-item {
    display: flex;
    align-items: center;
    gap: 0.4em;
    cursor: pointer;
  }

  .sn-dot {
    width: 0.45em;
    height: 0.45em;
    border-radius: 50%;
    background-color: #999 !important;
    opacity: 0.5;
    flex-shrink: 0;
    pointer-events: none;
  }

  .sn-dot.sn-green {
    background-color: #22c55e !important;
    opacity: 1;
    box-shadow: 0 0 5px rgb(34 197 94 / 50%);
  }

  .sn-dot.sn-yellow {
    background-color: #eab308 !important;
    opacity: 1;
    box-shadow: 0 0 5px rgb(234 179 8 / 50%);
  }

  .sn-dot.sn-red {
    background-color: #ef4444 !important;
    opacity: 1;
    box-shadow: 0 0 5px rgb(239 68 68 / 50%);
  }

  /* ── Connect modal (injected by JS) ── */
  .sn-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgb(0 0 0 / 40%);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    animation: sn-fade-in 0.15s ease;
  }

  @keyframes sn-fade-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  .sn-modal {
    background: #fff;
    border: 3px solid #000;
    padding: 20px 24px;
    min-width: 320px;
    max-width: 90vw;
    font-family: var(--font-ui);
    animation: sn-slide-in 0.2s ease;
  }

  @keyframes sn-slide-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .sn-modal-header {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #333;
    border-bottom: 1px solid #ccc;
    padding-bottom: 12px;
    margin-bottom: 16px;
  }

  .sn-modal-footer {
    border-top: 1px solid #ccc;
    padding-top: 12px;
    margin-top: 16px;
    display: flex;
    gap: 8px;
    justify-content: flex-end;
  }

  .sn-connect-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sn-form-row {
    display: grid;
    grid-template-columns: 52px 1fr;
    align-items: center;
    border-bottom: 1px solid #eee;
    padding: 8px 0;
  }

  .sn-form-row:last-child {
    border-bottom: none;
  }

  .sn-form-row label {
    font-size: 11px;
    font-weight: 500;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .sn-form-row input {
    width: 100%;
    background: #f5f5f5;
    border: 1px solid #ccc;
    color: #000;
    font-size: 13px;
    padding: 6px 9px;
    outline: none;
    font-family: monospace;
    box-sizing: border-box;
  }

  .sn-form-row input:focus {
    border-color: #06c;
  }

  .sn-form-row input::-webkit-inner-spin-button,
  .sn-form-row input::-webkit-outer-spin-button {
    appearance: none;
    margin: 0;
  }

  .sn-form-row input[type='number'] {
    appearance: textfield;
  }

  .sn-btn {
    height: 28px;
    padding: 0 16px;
    font-size: 12px;
    border: 2px solid #000;
    cursor: pointer;
    background: #fff;
    color: #000;
    font-family: var(--font-ui);
  }

  .sn-btn:hover {
    background: #000;
    color: #fff;
  }

  .sn-btn-primary {
    background: #000;
    color: #fff;
  }

  .sn-btn-primary:hover {
    background: #333;
  }
</style>
