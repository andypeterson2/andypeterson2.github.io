<!-- Draw card (image input) -->
<section class="card" id="canvas-col" class:list={['hidden']}>
  <h2 class="card-title">Draw</h2>
  <canvas id="draw-canvas" width="280" height="280"></canvas>
  <div class="row">
    <button id="clear-btn" type="button" class="btn">Clear</button>
    <button id="predict-btn" type="button" class="btn btn-primary">Predict</button>
  </div>
</section>

<!-- Tabular input card -->
<section class="card" id="tabular-col" class:list={['hidden']}>
  <h2 class="card-title">Predict</h2>
  <div class="feature-inputs"></div>
  <button id="predict-btn-tab" type="button" class="btn btn-primary btn-block">Predict</button>
</section>

<!-- Predictions -->
<section class="card">
  <h2 class="card-title">Predictions</h2>
  <table class="app-table">
    <thead><tr><th>Model</th><th>Prediction</th><th>Confidence</th></tr></thead>
    <tbody id="pred-body">
      <tr class="empty-row"><td colspan="3">No prediction yet</td></tr>
    </tbody>
  </table>
</section>

<!-- Chart area -->
<div id="chart-area" class="card hidden">
  <canvas id="train-chart" width="600" height="250"></canvas>
</div>

<!-- Evaluation -->
<section class="card">
  <h2 class="card-title">Evaluation</h2>
  <div id="evaluate-progress" class="hidden">
    <div class="progress-bar" role="progressbar">
      <div id="eval-bar" class="progress-bar-fill"></div>
    </div>
    <span id="eval-status"></span>
  </div>
  <div class="metrics-wrap">
    <table class="app-table metrics-table">
      <thead id="metrics-head"></thead>
      <tbody id="metrics-body">
        <tr class="empty-row"><td>No models trained yet</td></tr>
      </tbody>
    </table>
  </div>
</section>

<style>
  /* ── Tables ── */
  .app-table {
    width: 100%;
    border-collapse: collapse;
    font-size: clamp(9px, 1.1vw, 13px);
  }

  .app-table th,
  .app-table td {
    padding: 3px 6px;
    border-bottom: 1px solid #ddd;
    text-align: left;
  }

  .app-table th {
    font-weight: 700;
    background: #f5f5f5;
  }

  .metrics-wrap {
    overflow: auto;
    max-height: 300px;
  }

  :global(.corner-cell) {
    min-width: 80px;
    position: sticky;
    left: 0;
    z-index: 3;
    background: #f5f5f5;
  }

  :global(.model-col-head) {
    min-width: 80px;
  }

  :global(.col-model-name) {
    font-weight: 600;
  }

  :global(.metrics-section-row > td) {
    background: #eee;
    color: #666;
    font-size: clamp(8px, 1vw, 11px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 6px;
    border-top: 1px solid #ccc;
  }

  :global(.metric-label) {
    background: #f5f5f5;
    font-size: clamp(8px, 1vw, 12px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    padding: 3px 6px;
    text-align: left;
    position: sticky;
    left: 0;
    z-index: 2;
    border-right: 1px solid #ddd;
  }

  :global(.cfg-cell) {
    color: #666;
  }

  /* ── Colour helpers ── */
  :global(.pred-label) {
    font-weight: 700;
  }

  :global(.pred-model-name) {
    color: #666;
  }

  :global(.conf-high) {
    color: var(--color-success);
  }

  :global(.conf-low) {
    color: #999;
  }

  :global(.acc-high) {
    color: var(--color-success);
  }

  :global(.acc-med) {
    color: var(--color-warning);
  }

  :global(.acc-low) {
    color: var(--color-danger);
  }

  /* ── Canvas ── */
  #draw-canvas {
    width: 100%;
    max-width: 280px;
    aspect-ratio: 1;
    border: 2px solid #000;
    cursor: crosshair;
    image-rendering: pixelated;
  }

  /* ── Chart ── */
  #chart-area canvas {
    width: 100%;
    display: block;
  }

  /* ── Progress bar ── */
  .progress-bar {
    height: 14px;
    background: #eee;
    border: 1.5px solid #000;
    margin-bottom: 4px;
  }

  .progress-bar-fill {
    height: 100%;
    background: #000;
    width: 0%;
    transition: width 0.2s;
  }
</style>
