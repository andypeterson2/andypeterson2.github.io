---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props;
const Tag = href ? 'a' : 'button';
const classes = ['btn', `btn-${variant}`, `btn-${size}`, className].filter(Boolean).join(' ');
---

<Tag class={classes} href={href} {...rest}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: var(--text-sm);
    cursor: pointer;
    border: 1px solid var(--color-text);
    border-radius: 2px;
    transition:
      background var(--duration-fast),
      border-color var(--duration-fast),
      color var(--duration-fast);
    text-decoration: none;
    white-space: nowrap;
  }
  .btn:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .btn-primary {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }
  .btn-primary:hover { background: var(--color-text-secondary); border-color: var(--color-text-secondary); }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .btn-secondary:hover { background: var(--color-surface-2); border-color: var(--color-text-muted); }

  .btn-ghost {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .btn-ghost:hover { background: var(--color-surface-2); border-color: var(--color-text-muted); }

  .btn-sm { padding: var(--space-2) var(--space-4); min-height: 48px; }
  .btn-md { padding: var(--space-3) var(--space-6); min-height: 48px; }
  .btn-lg { font-size: var(--text-base); padding: var(--space-3) var(--space-6); min-height: 48px; }
</style>
