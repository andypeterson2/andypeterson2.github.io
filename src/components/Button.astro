---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const { variant = 'primary', size = 'md', href, class: className, ...rest } = Astro.props;
const Tag = href ? 'a' : 'button';
const classes = ['btn', `btn-${variant}`, `btn-${size}`, className].filter(Boolean).join(' ');
---

<Tag class={classes} href={href} {...rest}>
  <slot />
</Tag>

<style>
  /* Extend system.css .btn — do not fight its border-image bevels */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }
  .btn:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .btn-primary {
    background: #000;
    color: #fff;
  }
  .btn-primary:active { background: #fff; color: #000; }

  .btn-secondary {
    background: #fff;
    color: #000;
  }
  .btn-secondary:active { background: #000; color: #fff; }

  .btn-ghost {
    background: #fff;
    color: #000;
  }
  .btn-ghost:active { background: #000; color: #fff; }

  .btn-sm { font-size: 14px; padding: 0 12px; }
  .btn-md { font-size: 18px; padding: 0 20px; }
  .btn-lg { font-size: 22px; padding: 2px 28px; }
</style>
