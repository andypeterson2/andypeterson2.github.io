---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="Resume" description={`Resume of ${siteConfig.displayName}`}>
  <Breadcrumbs crumbs={[{ label: 'Resume' }]} />
  <section class="page-header">
    <h1>Resume</h1>
    <p class="page-subtitle">Experience, education, and publications.</p>
  </section>

  <section class="content-section">
    <SectionLabel label="Download" />
    <div class="download-links">
      <Button href="/resume.pdf">Download PDF</Button>
      <Button href="/cover-letter" variant="secondary">Cover Letter</Button>
    </div>
    <p class="last-updated">Last updated: 2026</p>
  </section>

  <section class="content-section">
    <SectionLabel label="Quick View" />
    <div class="window resume-window">
      <div class="title-bar">
        <button class="close" aria-hidden="true"><span>Close</span></button>
        <h1 class="title">{siteConfig.displayName} — Resume</h1>
        <button class="resize" aria-hidden="true"><span>Resize</span></button>
      </div>
      <div class="details-bar">
        <span>{siteConfig.description}</span>
        <span>{siteConfig.email || ''}</span>
      </div>
      <div class="window-pane resume-content">
        <p>Quantum computing researcher focused on QKD, optimization algorithms, and quantum-classical hybrid computing.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Experience" />
    <div class="standard-dialog experience-item">
      <div class="details-bar">
        <span><strong>Quantum Computing Researcher</strong></span>
        <span>Present</span>
      </div>
      <div class="experience-body">
        <p class="experience-org">Qualcomm Institute</p>
        <p>Research in quantum key distribution, quantum optimization algorithms, and quantum-classical hybrid computing.</p>
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Education" />
    <div class="standard-dialog experience-item">
      <div class="details-bar">
        <span><strong>Computer Science</strong></span>
      </div>
      <div class="experience-body">
        <p>Focus on quantum computing, machine learning, and systems programming.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .content-section { padding: var(--space-6) 0; }
  .download-links {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #666;
  }
  .resume-window {
    max-width: var(--content-width);
    min-width: 0;
  }
  .resume-content {
    max-height: 200px;
    font-size: 16px;
  }
  .experience-item { padding: 0; }
  .experience-body {
    padding: var(--space-4);
  }
  .experience-org {
    font-family: var(--font-mono);
    font-size: 12px;
    margin-bottom: var(--space-2);
  }
</style>
