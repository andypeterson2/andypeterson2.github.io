---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

// Icon map — SVG icons for each project
const iconMap: Record<string, string> = {
  'quantum-video-chat': '/icons/video_dark.svg',
  'quantum-nonogram-solver': '/icons/random.svg',
  'quantum-protein-kernel': '/icons/microscope.svg',
  'tech-tree': '/icons/code.svg',
  'task-randomizer': '/icons/grid_light.svg',
  'dashboard': '/icons/gear_light.svg',
};

// Last update date from build time
const lastUpdate = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Projects">
  <!-- Details bar — outside scrollable area -->
  <div class="details-bar finder-bar" slot="details-bar">
    <span>{projects.length} items</span>
    <span>Built with Astro</span>
    <span>Updated {lastUpdate}</span>
  </div>

  <!-- Finder icon grid -->
  <div class="icon-grid">
    {projects.map((project) => (
      <a href={`/projects/${project.slug}`} class="finder-icon">
        <div class="icon-box">
          <img src={iconMap[project.slug]} alt="" class="icon-glyph" />
        </div>
        <span class="icon-label">{project.title}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .finder-bar {
    padding: 6px 12px;
    font-family: var(--font-sans);
    font-size: 24px;
    font-weight: 700;
    border-bottom: 2px solid var(--color-text);
  }
  .finder-bar span {
    flex: 1;
  }
  .finder-bar span:nth-child(2) {
    text-align: center;
  }
  .finder-bar span:last-child {
    text-align: right;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-6);
    padding: var(--space-3) 0;
    justify-items: center;
  }

  .finder-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-decoration: none;
    color: var(--color-text);
    padding: var(--space-2);
    cursor: pointer;
    max-width: 200px;
    background: transparent;
  }
  .finder-icon:hover {
    background: transparent;
    color: var(--color-text);
  }

  .icon-box {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-glyph {
    width: 96px;
    height: 96px;
  }
  .finder-icon:hover .icon-glyph {
    filter: none;
  }

  .icon-label {
    font-family: var(--font-sans);
    font-size: 24px;
    text-align: center;
    word-break: break-word;
    line-height: 1.3;
    padding: 2px 6px;
  }
  .finder-icon:hover .icon-label {
    background: var(--color-text);
    color: var(--color-bg);
  }

  @media (max-width: 480px) {
    .icon-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-4);
    }
  }
</style>
