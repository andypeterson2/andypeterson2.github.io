---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const iconMap: Record<string, string> = {
  'quantum-video-chat': '/icons/video_dark.svg',
  'quantum-nonogram-solver': '/icons/random.svg',
  'quantum-protein-kernel': '/icons/microscope.svg',
  'tech-tree': '/icons/code.svg',
  'task-randomizer': '/icons/grid_dark.svg',
};

const lastUpdate = new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Projects">
  <div class="finder-bar">
    <span>{projects.length} items</span>
    <span>Built with Astro</span>
    <span>Updated {lastUpdate}</span>
  </div>

  <div class="icon-grid">
    {projects.map((project) => {
      const href = project.appUrl || `/projects/${project.slug}/`;
      return (
        <a href={href} class="finder-icon">
          <div class="icon-box">
            <img src={iconMap[project.slug] || '/icons/folder_open.svg'} alt="" class="icon-glyph" />
          </div>
          <span class="icon-label">{project.title}</span>
        </a>
      );
    })}
  </div>
</BaseLayout>

<style>
  .finder-bar {
    display: flex;
    padding: 6px 12px;
    font-family: 'Chicago', 'ChicagoFLF', system-ui, sans-serif;
    font-size: clamp(11px, 1.4vw, 18px);
    border-bottom: 2px solid #000;
    margin: 0 -4vw;
    padding: 6px 4vw;
  }
  .finder-bar span {
    flex: 1;
  }
  .finder-bar span:nth-child(2) {
    text-align: center;
  }
  .finder-bar span:last-child {
    text-align: right;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 2vw;
    padding: 3vw 0;
    justify-items: center;
  }

  .finder-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-decoration: none;
    color: #000;
    padding: 8px;
    cursor: pointer;
    max-width: 160px;
  }

  .icon-box {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-glyph {
    width: 64px;
    height: 64px;
  }

  .icon-label {
    font-family: 'Geneva', 'Geneva_9', system-ui, sans-serif;
    font-size: clamp(11px, 1.4vw, 16px);
    text-align: center;
    word-break: break-word;
    line-height: 1.3;
    padding: 2px 4px;
    margin-top: 4px;
  }
  .finder-icon:hover .icon-label {
    background: #000;
    color: #fff;
  }

  @media (max-width: 480px) {
    .icon-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 4vw;
    }
  }
</style>
