---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Home" hideChrome={true}>
  <!-- Desktop menubar (>768px) -->
  <nav class="home-menubar" slot="topbar" aria-label="Main navigation">
    <ul role="menu-bar">
      <li role="menu-item" class="heart-item">
        <a href="/"><img src="/icons/heart.svg" alt="Home" class="heart-icon" width="36" height="36" /></a>
      </li>
      <li role="menu-item" aria-haspopup="true" tabindex="0">Projects
        <ul role="menu">
          {projects.map((project) => {
            const href = project.appUrl || `/projects/${project.slug}/`;
            return (
              <li role="menu-item">
                <a href={href}>{project.title}</a>
              </li>
            );
          })}
        </ul>
      </li>
      <li role="menu-item"><a href="/about">About</a></li>
      <li role="menu-item"><a href="/contact">Contact</a></li>
    </ul>
  </nav>

  <!-- Mobile header (≤768px) -->
  <div class="mobile-header" slot="topbar" aria-label="Mobile navigation">
    <a href="/" class="mobile-heart">
      <img src="/icons/heart.svg" alt="Home" width="40" height="40" class="mobile-heart-icon" />
    </a>
    <select class="mobile-nav-select" aria-label="Navigate to">
      <option value="">Navigate...</option>
      <option value="/projects/">Projects</option>
      <option value="/about/">About</option>
      <option value="/contact/">Contact</option>
    </select>
  </div>
  <div class="home-canvas">
    <div class="window home-window">
      <div class="title-bar">
        <h1 class="title">Dialog Title</h1>
      </div>
      <div class="details-bar">
        <span>~</span>
        <span class="crumb-sep">/</span>
        <span>home</span>
      </div>
      <div class="separator"></div>
      <div class="window-pane home-pane">
        <!-- content will go here -->
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const sel = document.querySelector('.mobile-nav-select') as HTMLSelectElement | null;
  if (sel) {
    sel.addEventListener('change', () => {
      if (sel.value) window.location.href = sel.value;
    });
  }
</script>

<style>
  /* ── Desktop nav (>768px) ── */
  .home-menubar {
    width: 100%;
    padding: 0.5vh 1.25vw;
    font-size: 1.96vw;
    border-bottom: 3px solid #000;
    background: #fff;
    box-sizing: border-box;
    position: sticky;
    top: 0;
    z-index: 100;
    border-radius: 0.75vw 0.75vw 0 0;
  }

  .home-menubar > ul {
    display: flex;
    gap: 1.875vw;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .home-menubar a {
    text-decoration: none;
    color: inherit;
  }

  .heart-icon {
    width: 1em;
    height: 1em;
    display: block;
  }

  .heart-item:hover .heart-icon {
    filter: invert(1);
  }

  .home-window .details-bar {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 0.75vw;
    padding: 0.3vh 2vw 0;
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
  }

  .home-window .details-bar .crumb-sep {
    font-weight: 700;
  }

  .home-window .title-bar .title {
    font-size: clamp(18px, 2.67vw, 42px);
  }

  .home-window .details-bar {
    font-size: clamp(12px, 1.78vw, 24px);
  }

  /* ── Canvas area behind the window ── */
  .home-canvas {
    flex: 1;
    display: flex;
    padding: 2vw;
    box-sizing: border-box;
  }

  /* ── Inner window with margin from outer border ── */
  .home-window {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-width: 2px;
    border-right-width: 4px;
    border-bottom-width: 4px;
  }

  .home-window .separator {
    height: 1px;
    background: #000;
    flex-shrink: 0;
    margin-top: 0.25vh;
  }

  .home-pane {
    flex: 1;
    overflow-y: auto;
    padding: 4vw;
  }

  /* ── Mobile header: hidden on desktop ── */
  .mobile-header {
    display: none;
  }

  /* ── Switch at 768px ── */
  @media (max-width: 768px) {
    .home-menubar {
      display: none;
    }

    .mobile-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 2vw 4vw;
      box-sizing: border-box;
      background: #fff;
      border-bottom: 2px solid #000;
    }

    .mobile-heart-icon {
      width: 10vw;
      height: 10vw;
      display: block;
    }

    .mobile-nav-select {
      font-size: 4vw;
      height: 10vw;
    }

  }
</style>
