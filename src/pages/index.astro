---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const featured = projects.filter((p) => p.featured);
---

<BaseLayout title="Home">
  <div class="home-grid">
    <!-- Left column: intro + actions -->
    <div class="home-intro">
      <h2 class="greeting">Welcome to Andy's desk.</h2>
      <p class="bio">
        I build software that works under pressure — real-time systems, research prototypes, and the
        infrastructure that holds them together.
      </p>
      <p class="bio">
        I'm a recent <strong>UC San Diego</strong> graduate with two years of quantum computing research
        at <strong>Qualcomm Institute</strong>, co-founder of <strong>San Diego CTF</strong> and the
        <strong>Quantum Computing Student Association</strong> at UC San Diego.
      </p>
      <div class="home-actions">
        <a href="/resume.pdf" class="btn resume-btn">
          <i class="bi bi-file-earmark-text"></i> Resume
        </a>
        <a href="/about/" class="learn-more">Learn More &rarr;</a>
      </div>
    </div>

    <!-- Right column: projects window -->
    <div class="projects-col">
      <div class="window projects-window">
        <div class="title-bar">
          <a href="/projects/" class="projects-title-link">
            <span class="title">View All Projects &rarr;</span>
          </a>
        </div>
        <div class="window-pane projects-pane">
          <div class="icon-grid">
            {
              featured.map((project) => (
                <a href={`/projects/${project.slug}/`} class="finder-icon">
                  <div class="icon-box">
                    <img src={`/icons/${project.icon}`} alt="" class="icon-glyph" />
                  </div>
                  <span class="icon-label">{project.title}</span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(16px, 3vw, 48px);
    align-items: start;
    padding: clamp(12px, 2vw, 32px) 0;
  }

  /* ── Left column ── */
  .greeting {
    font-family: var(--font-ui);
    font-size: clamp(16px, 2.4vw, 36px);
    margin: 0 0 clamp(8px, 1.2vw, 18px);
  }

  .bio {
    font-size: clamp(12px, 1.6vw, 22px);
    line-height: 1.6;
    max-width: 42ch;
    margin: 0 0 clamp(6px, 1vw, 14px);
  }

  .bio strong {
    font-weight: 700;
  }

  .home-actions {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1.5vw, 24px);
    margin-top: clamp(10px, 1.5vw, 20px);
  }

  .resume-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    text-decoration: none;
    font-size: clamp(12px, 1.6vw, 22px);
  }

  .learn-more {
    font-family: var(--font-ui);
    font-size: clamp(12px, 1.6vw, 22px);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
  }

  .learn-more:hover {
    background: var(--color-text);
    color: var(--color-text-inverse);
  }

  /* ── Right column: projects window ── */
  .projects-col {
    display: flex;
    justify-content: center;
  }

  .projects-window {
    width: 100%;
  }

  /* Hide close/resize buttons from system.css title-bar */
  .projects-window .title-bar button {
    display: none;
  }

  .projects-title-link {
    display: contents;
    text-decoration: none;
    color: inherit;
  }

  .projects-title-link:hover .title {
    text-decoration: underline;
  }

  .projects-pane {
    padding: clamp(10px, 1.5vw, 24px);
    overflow: hidden;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(12px, 2vw, 32px);
    justify-items: center;
  }

  .finder-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(4px, 0.5vw, 8px);
    text-decoration: none;
    color: var(--color-text);
    padding: clamp(6px, 0.8vw, 12px);
  }

  .finder-icon:hover {
    background: var(--color-text);
    color: var(--color-text-inverse);
  }

  .finder-icon:hover .icon-glyph {
    filter: invert(1);
  }

  .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-glyph {
    width: clamp(36px, 4.5vw, 64px);
    height: clamp(36px, 4.5vw, 64px);
    display: block;
    image-rendering: pixelated;
  }

  .icon-label {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1.2vw, 16px);
    text-align: center;
    line-height: 1.3;
  }

  /* ── Mobile: stack columns ── */
  @media (width <= 768px) {
    .home-grid {
      grid-template-columns: 1fr;
    }

    .bio {
      max-width: none;
    }
  }
</style>
