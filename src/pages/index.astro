---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { projects } from '../data/projects';

// Icon map — simple text icons for each project (Finder-style)
const iconMap: Record<string, string> = {
  'quantum-video-chat': '🔐',
  'quantum-nonogram-solver': '▦',
  'quantum-protein-kernel': '🧬',
  'tech-tree': '🌳',
  'task-randomizer': '🎲',
  'dashboard': '📊',
};
---

<BaseLayout>
  <!-- Details bar — like "5 items  232K in disk  167K available" -->
  <div class="details-bar finder-bar">
    <span>{projects.length} items</span>
    <span>Built with Astro</span>
    <span>2026</span>
  </div>

  <!-- Finder icon grid -->
  <div class="icon-grid">
    {projects.map((project) => (
      <a href={`/projects/${project.slug}`} class="finder-icon">
        <div class="icon-box">
          <span class="icon-glyph">{iconMap[project.slug] || '📁'}</span>
        </div>
        <span class="icon-label">{project.title}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .finder-bar {
    margin: 0 calc(-1 * var(--space-6));
    padding: 4px 12px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    margin-bottom: var(--space-6);
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: var(--space-8);
    padding: var(--space-6) 0;
    justify-items: center;
  }

  .finder-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    color: #000;
    padding: var(--space-3);
    cursor: pointer;
    max-width: 120px;
  }
  .finder-icon:hover {
    background: #000;
    color: #fff;
  }
  .finder-icon:hover .icon-box {
    border-color: #fff;
  }

  .icon-box {
    width: 80px;
    height: 80px;
    border: 2px solid #000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
  }
  .finder-icon:hover .icon-box {
    background: #000;
  }

  .icon-glyph {
    font-size: 36px;
    line-height: 1;
  }

  .icon-label {
    font-family: var(--font-sans);
    font-size: 13px;
    text-align: center;
    word-break: break-word;
    line-height: 1.3;
  }

  @media (max-width: 480px) {
    .icon-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
  }
</style>
