---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import Tag from '../components/Tag.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout>
  <section class="hero">
    <p class="hero-greeting">Hello, I'm</p>
    <h1>{siteConfig.displayName}</h1>
    <p class="hero-tagline">{siteConfig.description}</p>

    <div class="standard-dialog hero-status">
      <span class="status-dot"></span>
      Currently working on quantum-secured video chat
    </div>

    <div class="hero-actions">
      <Button href="/projects">View Projects</Button>
      <Button variant="secondary" href="/contact">Get in Touch</Button>
    </div>
  </section>

  <div class="separator"></div>

  <section>
    <SectionLabel label="Projects" />
    <div class="project-grid">
      <Card title="Quantum Video Chat" href="/projects/quantum-video-chat">
        <p>QKD-secured real-time video chat using WebRTC and BB84 protocol simulation.</p>
        <div class="card-tags">
          <Tag variant="accent">Quantum</Tag>
          <Tag>WebRTC</Tag>
          <Tag>Python</Tag>
        </div>
      </Card>
      <Card title="Quantum Nonogram Solver" href="/projects/quantum-nonogram-solver">
        <p>Quantum computing approach to solving nonogram puzzles with visual solver UI.</p>
        <div class="card-tags">
          <Tag variant="accent">Quantum</Tag>
          <Tag>Qiskit</Tag>
          <Tag>Python</Tag>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-8);
    max-width: var(--content-width);
  }
  .hero-greeting {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 14px;
    margin-bottom: var(--space-2);
  }
  .hero h1 { margin-bottom: var(--space-4); }
  .hero-tagline {
    font-size: 16px;
    margin-bottom: var(--space-6);
    max-width: 36rem;
  }
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: Monaco, ui-monospace, monospace;
    font-size: 12px;
    margin-bottom: var(--space-6);
  }
  .status-dot {
    width: 8px;
    height: 8px;
    background: #000;
    border: 1px solid #000;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  .card-tags {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }
</style>
