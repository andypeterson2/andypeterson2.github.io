---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { projects } from '../data/projects';

const featured = projects.filter(p => p.featured);
---

<BaseLayout title="Home">
  <div class="home-intro">
    <p class="greeting">Welcome to {siteConfig.firstName || 'my'}'s desk.</p>
    <p class="tagline">Software engineer working at the intersection of quantum computing, machine learning, and cybersecurity.</p>
  </div>

  <div class="home-section">
    <div class="section-rule"><span>Featured Projects</span></div>
    <div class="icon-grid">
      {featured.map((project) => (
        <a href={`/projects/${project.slug}/`} class="finder-icon">
          <div class="icon-box">
            <img src={`/icons/${project.icon}`} alt="" class="icon-glyph" />
          </div>
          <span class="icon-label">{project.title}</span>
        </a>
      ))}
    </div>
    <a href="/projects/" class="view-all">View All Projects →</a>
  </div>

  <div class="home-section">
    <div class="section-rule"><span>Quick Links</span></div>
    <div class="link-row">
      {siteConfig.github && <a href={siteConfig.github} class="quick-link" target="_blank" rel="noopener noreferrer">GitHub</a>}
      {siteConfig.linkedin && <a href={siteConfig.linkedin} class="quick-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>}
      <a href="/contact/" class="quick-link">Contact</a>
    </div>
  </div>
</BaseLayout>

<style>
  .home-intro {
    padding: clamp(16px, 3vw, 40px) 0 clamp(8px, 1.5vw, 20px);
  }
  .greeting {
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(16px, 2.67vw, 42px);
    margin-bottom: clamp(4px, 0.5vw, 10px);
  }
  .tagline {
    font-size: clamp(12px, 1.78vw, 24px);
    max-width: 60ch;
    line-height: 1.5;
  }

  .home-section {
    padding: clamp(12px, 2vw, 28px) 0;
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: clamp(6px, 1vw, 14px);
    margin-bottom: clamp(10px, 1.5vw, 24px);
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(10px, 1.4vw, 18px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .section-rule::before,
  .section-rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #000;
  }

  .icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(clamp(100px, 12vw, 180px), 1fr));
    gap: clamp(16px, 3vw, 40px);
    padding: clamp(8px, 1vw, 16px) 0;
    justify-items: center;
  }

  .finder-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(4px, 0.5vw, 8px);
    text-decoration: none;
    color: #000;
    padding: clamp(4px, 0.5vw, 8px);
    cursor: pointer;
  }
  .finder-icon:hover .icon-glyph {
    filter: invert(1);
  }
  .finder-icon:hover .icon-label {
    background: #000;
    color: #fff;
  }

  .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .icon-glyph {
    width: clamp(48px, 5.25vw, 72px);
    height: clamp(48px, 5.25vw, 72px);
    display: block;
  }
  .icon-label {
    font-family: var(--font-sans);
    font-size: clamp(12px, 1.78vw, 24px);
    text-align: center;
    word-break: break-word;
    line-height: 1.3;
    padding: clamp(2px, 0.3vw, 6px) clamp(4px, 0.6vw, 10px);
    background: #fff;
  }

  .view-all {
    display: inline-block;
    margin-top: clamp(6px, 1vw, 14px);
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(12px, 1.78vw, 24px);
    color: #000;
    text-decoration: none;
  }
  .view-all:hover {
    background: #000;
    color: #fff;
  }

  .link-row {
    display: flex;
    gap: clamp(12px, 2vw, 28px);
    flex-wrap: wrap;
  }
  .quick-link {
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(12px, 1.78vw, 24px);
    color: #000;
    text-decoration: none;
    padding: clamp(2px, 0.3vw, 6px) clamp(6px, 0.8vw, 14px);
    border: 2px solid #000;
  }
  .quick-link:hover {
    background: #000;
    color: #fff;
  }

  @media (max-width: 480px) {
    .icon-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
