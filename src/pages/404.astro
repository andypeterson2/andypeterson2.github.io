---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="404 — Not Found">
  <div class="not-found">
    <div class="window error-window">
      <div class="title-bar">
        <button class="close" aria-hidden="true"><span>Close</span></button>
        <h1 class="title">Error</h1>
        <button class="resize" aria-hidden="true"><span>Resize</span></button>
      </div>
      <div class="window-pane error-content">
        <p class="error-code" aria-hidden="true">404</p>
        <h2>Lost in the superposition</h2>
        <p class="error-message">
          This page collapsed to |0⟩ — it doesn't exist in this basis.
        </p>
        <p class="error-suggestion">
          Maybe try observing one of these states instead:
        </p>
        <div class="error-actions">
          <Button href="/">Home</Button>
          <Button variant="secondary" href="/projects">Projects</Button>
          <Button variant="secondary" href="/blog">Blog</Button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    justify-content: center;
    padding: var(--space-16) 0;
  }
  .error-window {
    max-width: 500px;
    min-width: 300px;
    text-align: center;
  }
  .error-content {
    overflow: visible;
    max-height: none;
  }
  .error-code {
    font-family: var(--font-sans);
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }
  .error-message {
    font-family: var(--font-mono);
    font-size: 16px;
    margin-bottom: var(--space-4);
  }
  .error-suggestion {
    font-size: 13px;
    color: #666;
    margin-bottom: var(--space-6);
  }
  .error-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
