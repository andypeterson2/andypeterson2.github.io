---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Tech Tree" breadcrumbs={[{ label: 'projects', href: '/projects/' }, { label: 'tech tree', href: '/projects/tech-tree/' }, { label: 'app' }]}>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />

  <div id="tech-tree-app">
    <div id="sidebar" class="ui-scrollbar-thin">

      <div class="sidebar-header">
        <h1>Tech Tree</h1>
        <button id="theme-toggle" class="btn btn-icon">LIGHT</button>
      </div>

      <div class="sidebar-section">
        <div class="stat"><span id="stat-learned">0</span> / <span id="stat-total">0</span> learned</div>
        <div class="progress-bar-wrap"><div id="progress-fill" class="progress-bar"></div></div>
        <div class="stat"><span id="stat-unlocked">0</span> unlocked &nbsp;&middot;&nbsp; depth <span id="stat-depth">0</span></div>
      </div>

      <div class="sidebar-section">
        <h3>Target Concept</h3>
        <div id="target-search-wrap">
          <input type="text" id="target-search" placeholder="Search all vault notes..." autocomplete="off">
          <div id="target-suggestions" class="hidden"></div>
        </div>
        <div id="target-display" class="hidden">
          <div id="target-name"></div>
          <div id="target-gap-display"></div>
          <div class="progress-bar-wrap"><div id="target-progress-fill" class="progress-bar"></div></div>
          <div class="target-actions">
            <button id="btn-clear-target" class="btn btn-icon">&times; CLEAR</button>
            <button id="btn-target-guide" class="btn btn-icon">STUDY GUIDE</button>
          </div>
        </div>
      </div>

      <div class="sidebar-section" id="controls">
        <h3>Filters</h3>
        <label><input type="checkbox" id="filter-has-prereqs"> Only nodes with prereqs</label>
        <label><input type="checkbox" id="filter-unlocked"> Only unlocked/learned</label>
        <label><input type="checkbox" id="filter-path"> Only target path</label>
        <input type="text" id="search" placeholder="Search concepts...">
      </div>

      <div id="study-guide" class="hidden sidebar-section">
        <h3>Study Guide: <span id="guide-target"></span></h3>
        <div id="guide-steps"></div>
        <div class="guide-actions">
          <button id="guide-close" class="btn btn-icon">CLOSE</button>
          <button id="guide-export" class="btn btn-icon">EXPORT .MD</button>
        </div>
      </div>

      <div id="node-detail" class="hidden sidebar-section">
        <div id="detail-name"></div>
        <div id="detail-aliases" class="detail-row"></div>
        <div class="detail-row">depth: <span id="detail-depth"></span> &nbsp;&middot;&nbsp; gap: <span id="detail-gap"></span></div>
        <div class="detail-row"><strong>prereqs:</strong></div>
        <ul id="detail-prereqs"></ul>
        <div class="detail-row"><strong>unlocks:</strong></div>
        <ul id="detail-unlocks"></ul>
        <div id="detail-preview"></div>
        <div class="detail-actions">
          <button id="btn-toggle-learned" class="btn btn-secondary">Mark as Learned</button>
          <button id="btn-study-guide" class="btn btn-icon">Study Guide</button>
        </div>
      </div>

    </div>

    <div id="canvas-container">
      <canvas id="tree-canvas"></canvas>
    </div>
  </div>

  <script is:inline src="/tech-tree/js/app.js"></script>
</BaseLayout>

<style>
  /* ── UI-Kit Design Tokens (dark default, light via data-theme) ── */
  :global(:root) {
    --teal:  #6ba3a0;
    --green: #a9b665;
    --red:   #ea6962;
  }
  :global([data-theme="light"]) {
    --teal:  #4a7a78;
    --green: #5a7a30;
    --red:   #c04040;
  }

  /* ── UI-Kit token overrides scoped to tech-tree ── */
  #tech-tree-app {
    --bg:              #2d2b22;
    --surface:         #3a3830;
    --surface2:        #504d40;
    --surface-muted:   #5c5a4d;
    --border:          #504d40;
    --border-focus:    #d8a657;
    --text:            #d4be98;
    --text-secondary:  #b5a993;
    --text-muted:      #ccbba7;
    --text-inverse:    #2d2b22;
    --accent:          #d8a657;
    --accent-hover:    #e8b86a;
    --accent-dark:     #6e5c3e;
    --danger:          #ef8a83;
    --font:            'Atkinson Hyperlegible', system-ui, sans-serif;
  }

  :global([data-theme="light"]) #tech-tree-app {
    --bg:              #E1DDD4;
    --surface:         #D6D2C8;
    --surface2:        #C9C8BD;
    --surface-muted:   #BDB9AE;
    --border:          #9e9a8f;
    --border-focus:    #7a5c1f;
    --text:            #2d2a22;
    --text-secondary:  #4a4639;
    --text-muted:      #6e6a5d;
    --text-inverse:    #E1DDD4;
    --accent:          #8a6b20;
    --accent-hover:    #7a5c1f;
    --accent-dark:     #5c4420;
    --danger:          #b03030;
  }

  /* ── Utility classes ── */
  :global(.hidden) { display: none !important; }

  /* ── Minimal button resets (from ui-kit) ── */
  :global(#tech-tree-app .btn) {
    border: 1px solid var(--border);
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    white-space: nowrap;
    font-family: var(--font);
    border-radius: 0;
    background: transparent;
    color: var(--text);
  }
  :global(#tech-tree-app .btn:active) { opacity: 0.75; }

  :global(#tech-tree-app .btn-secondary) {
    background: var(--surface2);
    color: var(--text);
    border: 1px solid var(--border);
  }
  :global(#tech-tree-app .btn-secondary:hover) { border-color: var(--accent); color: var(--accent); }

  :global(#tech-tree-app .btn-icon) {
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  /* ── Progress bar (from ui-kit) ── */
  :global(#tech-tree-app .progress-bar-wrap) {
    background: var(--surface2);
    height: 5px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  :global(#tech-tree-app .progress-bar) {
    background: var(--accent);
    height: 100%;
    transition: width 0.3s ease;
  }

  /* ── App container: full-bleed inside the site-pane ── */
  #tech-tree-app {
    display: flex;
    height: 70vh;
    min-height: 400px;
    overflow: hidden;
    font-size: 13px;
    line-height: 1.4;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    border: 1px solid var(--border);
  }

  /* ── Sidebar ── */
  :global(#sidebar) {
    width: 300px;
    min-width: 300px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  :global(.sidebar-header) {
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--surface);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  :global(#sidebar h1) {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 3px;
    text-transform: uppercase;
    border: none;
    padding: 0;
    margin: 0;
  }

  :global(.sidebar-section) {
    border-bottom: 1px solid var(--border);
    padding: 8px 10px;
  }

  :global(#sidebar h3) {
    font-size: 9px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    border: none;
    padding: 0;
  }

  /* ── Stats ── */
  :global(.stat) {
    font-size: 11px;
    margin: 2px 0;
    color: var(--text-secondary);
  }
  :global(.stat span) { color: var(--accent); }

  :global(#tech-tree-app .progress-bar-wrap) { height: 3px; margin: 5px 0; border: none; }

  /* ── Target section ── */
  :global(#target-search-wrap) { position: relative; }

  :global(#target-search) {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 5px 8px;
    color: var(--text);
    font-family: var(--font);
    font-size: 11px;
    outline: none;
    border-radius: 0;
  }
  :global(#target-search:focus) { border-color: var(--accent); }
  :global(#target-search::placeholder) { color: var(--text-muted); }

  :global(#target-suggestions) {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-top: none;
    max-height: 180px;
    overflow-y: auto;
    z-index: 100;
  }

  /* Dynamically created suggestion items */
  :global(.suggestion-item) {
    padding: 4px 8px;
    font-size: 11px;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-secondary);
    font-family: var(--font);
  }
  :global(.suggestion-item:last-child) { border-bottom: none; }
  :global(.suggestion-item:hover) { background: var(--surface2); color: var(--accent); }
  :global(.suggestion-depth) { color: var(--text-muted); font-size: 10px; }
  :global(.suggestion-item:hover .suggestion-depth) { color: var(--accent-dark); }

  :global(#target-display) {
    margin-top: 6px;
    padding: 6px;
    background: var(--bg);
    border: 1px solid var(--accent);
  }

  :global(#target-name) {
    font-size: 11px;
    color: var(--accent);
    margin-bottom: 3px;
  }

  :global(#target-gap-display) {
    font-size: 10px;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  :global(#target-display .progress-bar-wrap) { margin: 3px 0 6px; }

  :global(.target-actions) { display: flex; gap: 4px; margin-top: 4px; }

  /* ── Controls ── */
  :global(#controls label) {
    font-size: 11px;
    color: var(--text-secondary);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 2px 0;
    font-family: var(--font);
  }

  :global(#tech-tree-app input[type="checkbox"]) { accent-color: var(--accent); }

  :global(#search) {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 5px 8px;
    color: var(--text);
    font-family: var(--font);
    font-size: 11px;
    outline: none;
    width: 100%;
    margin-top: 5px;
    border-radius: 0;
  }
  :global(#search:focus) { border-color: var(--accent); }
  :global(#search::placeholder) { color: var(--text-muted); }

  /* ── Button overrides ── */
  :global(#sidebar .btn) { font-size: 10px; padding: 5px 10px; }
  :global(#btn-clear-target) { border-color: var(--red); color: var(--red); }
  :global(#btn-target-guide) { flex: 1; }
  :global(#theme-toggle) { font-size: 9px; padding: 3px 7px; letter-spacing: 1px; }

  /* ── Node detail ── */
  :global(#node-detail), :global(#study-guide) {
    padding: 8px 10px;
  }

  :global(#detail-name) {
    font-size: 12px;
    color: var(--text);
    margin-bottom: 5px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 5px;
  }

  :global(#detail-aliases) {
    font-size: 10px;
    color: var(--text-muted);
    font-style: italic;
  }

  :global(.detail-row) {
    font-size: 11px;
    margin: 2px 0;
    color: var(--text-secondary);
  }

  :global(#detail-preview) {
    font-size: 10px;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    padding-top: 5px;
    margin-top: 5px;
    line-height: 1.5;
  }

  :global(#detail-prereqs), :global(#detail-unlocks) {
    list-style: none;
    padding-left: 8px;
  }

  :global(#detail-prereqs li), :global(#detail-unlocks li) {
    font-size: 11px;
    color: var(--teal);
    cursor: pointer;
    padding: 1px 0;
  }
  :global(#detail-prereqs li:hover), :global(#detail-unlocks li:hover) { color: var(--text); }

  :global(.detail-actions) {
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }

  /* ── Study guide ── */
  :global(#study-guide h3) {
    color: var(--text-secondary);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
    word-break: break-word;
    border: none;
    padding: 0;
  }

  :global(#guide-steps) {
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid var(--border);
    margin-bottom: 6px;
  }

  /* Dynamically created guide step elements */
  :global(.guide-step) {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 6px;
    font-size: 11px;
    cursor: pointer;
    border-bottom: 1px solid var(--border);
    font-family: var(--font);
  }
  :global(.guide-step:last-child) { border-bottom: none; }
  :global(.guide-step:hover) { background: var(--surface2); }

  :global(.guide-step .step-num) {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 700;
    flex-shrink: 0;
    border: 1px solid;
  }

  :global(.guide-step.learned .step-num)  { border-color: var(--green); color: var(--green); }
  :global(.guide-step.unlocked .step-num) { border-color: var(--teal);  color: var(--teal);  }
  :global(.guide-step.locked .step-num)   { border-color: var(--text-muted);  color: var(--text-muted);  }

  :global(.guide-step .step-name)  { flex: 1; color: var(--text-secondary); }
  :global(.guide-step .step-depth) { color: var(--text-muted); font-size: 10px; }

  :global(.guide-actions) { display: flex; gap: 4px; }

  /* ── Canvas ── */
  :global(#canvas-container) {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  :global(#tree-canvas) {
    position: absolute;
    top: 0;
    left: 0;
  }

  /* ── Scrollbar styling ── */
  :global(#sidebar::-webkit-scrollbar) { width: 4px; }
  :global(#sidebar::-webkit-scrollbar-track) { background: transparent; }
  :global(#sidebar::-webkit-scrollbar-thumb) { background: var(--surface-muted, #5c5a4d); }

  /* ── Responsive: stack sidebar above canvas on small screens ── */
  @media (max-width: 700px) {
    #tech-tree-app {
      flex-direction: column;
      height: 90vh;
    }
    :global(#sidebar) {
      width: 100%;
      min-width: unset;
      max-height: 200px;
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
  }
</style>
