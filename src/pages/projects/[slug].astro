---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import Tag from '../../components/Tag.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const projectIndex = projects.findIndex(p => p.slug === slug);
const project = projects[projectIndex]!;

const prevProject = projectIndex > 0 ? projects[projectIndex - 1] : null;
const nextProject = projectIndex < projects.length - 1 ? projects[projectIndex + 1] : null;

const relatedProjects = projects
  .filter(p => p.slug !== slug && p.category === project.category)
  .slice(0, 2);
---

<BaseLayout title={project.title} description={project.description}>
  <section class="project-header">
    <div class="details-bar project-meta">
      <span>{project.status}</span>
      <span>{project.category}</span>
    </div>
    <h1>{project.title}</h1>
    <p class="project-description">{project.longDescription || project.description}</p>
    <div class="project-tags">
      {project.tags.map((tag) => (
        <Tag variant={tag.variant}>{tag.label}</Tag>
      ))}
    </div>
    {(project.appUrl || project.repoUrl) && (
      <div class="project-actions">
        {project.appUrl && <Button href={project.appUrl}>Launch App</Button>}
        {project.repoUrl && <Button href={project.repoUrl} variant="secondary">View Source</Button>}
      </div>
    )}
  </section>

  <div class="separator"></div>

  <section class="content-section">
    <SectionLabel label="Architecture" />
    <div class="standard-dialog architecture-placeholder">
      Architecture diagram and technical details for this project.
    </div>
  </section>

  {relatedProjects.length > 0 && (
    <section class="content-section">
      <SectionLabel label="Related Projects" />
      <div class="related-grid">
        {relatedProjects.map((rp) => (
          <Card title={rp.title} href={`/projects/${rp.slug}`}>
            <p>{rp.description}</p>
            <div class="card-tags">
              {rp.tags.map((tag) => (
                <Tag variant={tag.variant}>{tag.label}</Tag>
              ))}
            </div>
          </Card>
        ))}
      </div>
    </section>
  )}

  <div class="separator"></div>

  <nav class="project-nav" aria-label="Project navigation">
    {prevProject ? (
      <a href={`/projects/${prevProject.slug}`} class="standard-dialog project-nav-link">
        <span class="project-nav-dir">&larr; Previous</span>
        <span class="project-nav-title">{prevProject.title}</span>
      </a>
    ) : <span />}
    {nextProject ? (
      <a href={`/projects/${nextProject.slug}`} class="standard-dialog project-nav-link next">
        <span class="project-nav-dir">Next &rarr;</span>
        <span class="project-nav-title">{nextProject.title}</span>
      </a>
    ) : <span />}
  </nav>
</BaseLayout>

<style>
  .project-header {
    padding: var(--space-4) 0 var(--space-8);
    max-width: var(--content-width);
  }
  .project-meta {
    margin-bottom: var(--space-4);
  }
  .project-header h1 { margin-bottom: var(--space-4); }
  .project-description {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }
  .project-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .project-actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }
  .content-section { padding: var(--space-6) 0; }
  .architecture-placeholder {
    font-family: var(--font-mono);
    font-size: 13px;
    text-align: center;
    color: #666;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .card-tags {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }
  .project-nav {
    display: flex;
    justify-content: space-between;
    padding: var(--space-6) 0;
    gap: var(--space-4);
  }
  .project-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-decoration: none;
    color: #000;
    max-width: 45%;
  }
  .project-nav-link:hover { background: #000; color: #fff; }
  .project-nav-link.next { text-align: right; margin-left: auto; }
  .project-nav-dir {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .project-nav-title { font-size: 13px; }
</style>
