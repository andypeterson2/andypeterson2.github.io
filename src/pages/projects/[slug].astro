---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;
const projectIndex = projects.findIndex((p) => p.slug === slug);
const project = projects[projectIndex]!;

const prevProject = projectIndex > 0 ? projects[projectIndex - 1] : null;
const nextProject = projectIndex < projects.length - 1 ? projects[projectIndex + 1] : null;

const relatedProjects = projects
  .filter((p) => p.slug !== slug && p.category === project.category)
  .slice(0, 2);
---

<BaseLayout title={project.title} description={project.description}>
  <div class="project-hero">
    {
      (project.appUrl || project.appLinks || project.repoUrl) && (
        <div class="project-buttons">
          {project.appLinks
            ? project.appLinks.map((link: { label: string; href: string }) => (
                <a href={link.href} class="project-btn">
                  {link.label}
                </a>
              ))
            : project.appUrl && (
                <a href={project.appUrl} class="project-btn">
                  Launch App
                </a>
              )}
          {project.repoUrl && (
            <a href={project.repoUrl} class="project-btn" target="_blank" rel="noopener noreferrer">
              View Source
            </a>
          )}
        </div>
      )
    }
    <div class="hero-screenshot">
      <div class="screenshot-viewer" data-auto="true">
        <div class="screenshot-controls">
          <button type="button" class="arrow-left" aria-label="Previous screenshot"></button>
          <button type="button" class="arrow-right" aria-label="Next screenshot"></button>
        </div>
        <div class="screenshot-stage">
          {
            project.screenshots.length > 0 ? (
              project.screenshots.map((src, i) => (
                <img
                  src={src}
                  alt={`${project.title} screenshot ${i + 1}`}
                  class:list={['screenshot-slide', { active: i === 0 }]}
                  data-index={i}
                />
              ))
            ) : (
              <div class="screenshot-placeholder screenshot-slide active" data-index="0">
                <img src={`/icons/${project.icon}`} alt="" class="screenshot-icon" />
                <span class="screenshot-label">Screenshot</span>
              </div>
            )
          }
        </div>
      </div>
    </div>
    <p class="hero-desc">{project.longDescription || project.description}</p>
  </div>

  {
    relatedProjects.length > 0 && (
      <div class="project-section">
        <div class="section-rule">
          <span>Related Projects</span>
        </div>
        <div class="related-list">
          {relatedProjects.map((rp) => (
            <a href={`/projects/${rp.slug}/`} class="related-item">
              <img src={`/icons/${rp.icon}`} alt={rp.title} class="related-icon" />
              <div class="related-info">
                <span class="related-title">{rp.title}</span>
                <span class="related-desc">{rp.description}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )
  }

  <div class="project-section">
    <div class="section-rule"><span>Browse Projects</span></div>
    <nav class="project-nav" aria-label="Project navigation">
      {
        prevProject ? (
          <a href={`/projects/${prevProject.slug}/`} class="nav-link">
            <span class="nav-dir">&larr; Previous</span>
            <span class="nav-title">{prevProject.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        nextProject ? (
          <a href={`/projects/${nextProject.slug}/`} class="nav-link nav-next">
            <span class="nav-dir">Next &rarr;</span>
            <span class="nav-title">{nextProject.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </div>
</BaseLayout>

<script>
  const viewer = document.querySelector('.screenshot-viewer') as HTMLElement | null;
  if (viewer) {
    const slides = viewer.querySelectorAll('.screenshot-slide');
    const leftBtn = viewer.querySelector('.arrow-left');
    const rightBtn = viewer.querySelector('.arrow-right');
    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;
    const total = slides.length;

    function show(index: number) {
      slides.forEach((s) => s.classList.remove('active'));
      current = ((index % total) + total) % total;
      slides[current].classList.add('active');
    }

    function startAuto() {
      if (total <= 1) return;
      stopAuto();
      autoTimer = setInterval(() => show(current + 1), 4000);
    }

    function stopAuto() {
      if (autoTimer) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    leftBtn?.addEventListener('click', () => {
      stopAuto();
      show(current - 1);
    });
    rightBtn?.addEventListener('click', () => {
      stopAuto();
      show(current + 1);
    });

    viewer.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') {
        stopAuto();
        show(current - 1);
      } else if (e.key === 'ArrowRight') {
        stopAuto();
        show(current + 1);
      }
    });

    startAuto();
  }
</script>

<style>
  /* ── Hero ── */
  .project-hero {
    padding: clamp(16px, 3vw, 40px) 0 clamp(12px, 2vw, 28px);
  }

  .hero-screenshot {
    float: left;
    width: clamp(160px, 22vw, 320px);
    margin: 0 clamp(12px, 2vw, 24px) clamp(8px, 1vw, 12px) 0;
  }

  .screenshot-viewer {
    display: flex;
    flex-direction: column;
  }

  .screenshot-controls {
    position: relative;
    height: clamp(10px, 1.4vw, 18px);
    background: #fff;
    border: 3px solid #000;
    border-bottom: none;
    border-radius: clamp(4px, 0.5vw, 8px) clamp(4px, 0.5vw, 8px) 0 0;
    cursor: pointer;
  }

  .arrow-left,
  .arrow-right {
    position: absolute;
    top: 0;
    padding: 0;
    background: none;
    outline: none;
    width: 0;
    height: 0;
    border-top: calc(clamp(10px, 1.4vw, 18px) / 2) solid transparent;
    border-bottom: calc(clamp(10px, 1.4vw, 18px) / 2) solid transparent;
    cursor: pointer;
  }

  .arrow-left {
    left: 25%;
    border-right: calc(clamp(10px, 1.4vw, 18px) * 0.7) solid #000;
  }

  .arrow-right {
    right: 25%;
    border-left: calc(clamp(10px, 1.4vw, 18px) * 0.7) solid #000;
  }

  .screenshot-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 3px solid #000;
    border-radius: 0 0 clamp(4px, 0.5vw, 8px) clamp(4px, 0.5vw, 8px);
    overflow: hidden;
    background: #eee;
  }

  .screenshot-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .screenshot-slide.active {
    opacity: 1;
  }

  .screenshot-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(6px, 0.8vw, 12px);
  }

  .screenshot-icon {
    width: clamp(32px, 4vw, 56px);
    height: clamp(32px, 4vw, 56px);
    opacity: 0.4;
  }

  .screenshot-label {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1.2vw, 16px);
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-desc {
    font-size: clamp(9px, 1.34vw, 18px);
    line-height: 1.6;
    margin-bottom: clamp(10px, 1.5vw, 20px);
  }

  .project-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(4px, 0.6vw, 8px);
    margin-bottom: clamp(8px, 1.5vw, 20px);
  }

  .project-btn {
    font-family: var(--font-ui);
    font-size: clamp(10px, 1.3vw, 14px);
    padding: clamp(3px, 0.4vw, 6px) clamp(8px, 1vw, 14px);
    border: 2px solid #000;
    background: #fff;
    color: #000;
    text-decoration: none;
    cursor: pointer;
  }

  .project-btn:hover {
    background: #000;
    color: #fff;
  }

  /* ── Sections ── */
  .project-section {
    padding: clamp(12px, 2vw, 28px) 0;
  }

  /* ── Related ── */
  .related-list {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 1vw, 14px);
  }

  .related-item {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1vw, 16px);
    text-decoration: none;
    color: #000;
    padding: clamp(6px, 0.8vw, 12px) clamp(8px, 1vw, 16px);
    border: 2px solid #000;
  }

  .related-item:hover {
    background: #000;
    color: #fff;
  }

  .related-item:hover .related-icon {
    filter: invert(1);
  }

  .related-icon {
    width: clamp(28px, 3vw, 44px);
    height: clamp(28px, 3vw, 44px);
    flex-shrink: 0;
  }

  .related-info {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.3vw, 4px);
  }

  .related-title {
    font-family: var(--font-ui);
    font-size: clamp(12px, 1.78vw, 24px);
  }

  .related-desc {
    font-size: clamp(10px, 1.4vw, 18px);
    opacity: 0.6;
  }

  /* ── Nav ── */
  .project-nav {
    display: flex;
    justify-content: space-between;
    gap: clamp(8px, 1.5vw, 20px);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.3vw, 4px);
    text-decoration: none;
    color: #000;
    padding: clamp(6px, 0.8vw, 12px) clamp(8px, 1vw, 16px);
    border: 2px solid #000;
    max-width: 45%;
  }

  .nav-link:hover {
    background: #000;
    color: #fff;
  }

  .nav-next {
    text-align: right;
    margin-left: auto;
  }

  .nav-dir {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1.2vw, 16px);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .nav-title {
    font-size: clamp(11px, 1.5vw, 20px);
  }

  @media (width <= 600px) {
    .hero-screenshot {
      float: none;
      width: 100%;
      margin-right: 0;
    }
  }
</style>
