---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import Tag from '../../components/Tag.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { siteConfig } from '../../config/site';
import { projects } from '../../data/projects';

const categories = [...new Set(projects.map(p => p.category))];
---

<BaseLayout title="Projects" description={`Projects by ${siteConfig.displayName}`}>
  <Breadcrumbs crumbs={[{ label: 'Projects' }]} />
  <section class="page-header">
    <h1>Projects</h1>
    <p class="page-subtitle">Research projects, tools, and experiments.</p>
  </section>

  <section>
    <div class="project-filters" role="group" aria-label="Filter projects by category">
      <button class="btn filter-btn active" data-filter="all" type="button">All</button>
      {categories.map((cat) => (
        <button class="btn filter-btn" data-filter={cat} type="button">{cat}</button>
      ))}
    </div>

    <div class="project-filters" role="group" aria-label="Filter projects by technology">
      <button class="btn tag-filter-btn active" data-tag="all" type="button">All Tags</button>
      {[...new Set(projects.flatMap(p => p.tags.map(t => t.label)))].map((tag) => (
        <button class="btn tag-filter-btn" data-tag={tag} type="button">{tag}</button>
      ))}
    </div>

    <div class="project-grid">
      {projects.map((project) => (
        <div class="project-card-wrap visible" data-category={project.category} data-tags={project.tags.map(t => t.label).join(',')}>
          <Card title={project.title} href={`/projects/${project.slug}`}>
            <div class="card-meta">
              {project.featured && <span class="featured-badge">Featured</span>}
              <span class="status-indicator">{project.status}</span>
            </div>
            <p>{project.description}</p>
            <div class="card-tags">
              {project.tags.map((tag) => (
                <Tag variant={tag.variant}>{tag.label}</Tag>
              ))}
            </div>
          </Card>
        </div>
      ))}
    </div>
  </section>

  <script>
    let activeCategory = 'all';
    let activeTag = 'all';

    function applyFilters() {
      document.querySelectorAll('.project-card-wrap').forEach(card => {
        const el = card as HTMLElement;
        const cat = el.getAttribute('data-category');
        const tags = el.getAttribute('data-tags') || '';
        const matchesCat = activeCategory === 'all' || cat === activeCategory;
        const matchesTag = activeTag === 'all' || tags.split(',').includes(activeTag);
        el.style.display = matchesCat && matchesTag ? '' : 'none';
      });
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = btn.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });

    document.querySelectorAll('.tag-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tag-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTag = btn.getAttribute('data-tag') || 'all';
        applyFilters();
      });
    });
  </script>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-4);
  }
  .project-card-wrap { }
  .card-tags {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
    flex-wrap: wrap;
  }
  .project-filters {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }
  .filter-btn, .tag-filter-btn {
    font-size: 12px;
    text-transform: capitalize;
    min-width: auto;
    min-height: auto;
    padding: 2px 10px;
  }
  .filter-btn.active, .tag-filter-btn.active {
    background: #000;
    color: #fff;
  }
  .card-meta {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
    align-items: center;
  }
  .featured-badge {
    font-family: var(--font-sans);
    font-size: 10px;
    padding: 1px 4px;
    background: #000;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .status-indicator {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #666;
    text-transform: capitalize;
  }
</style>
