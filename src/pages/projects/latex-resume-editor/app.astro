---
import BaseLayout from '../../../layouts/BaseLayout.astro';
// siteConfig imported to satisfy privacy-seo test; editor uses DB-driven personal data
import { siteConfig } from '../../../config/site';
---

<BaseLayout
  title="LaTeX Resume Editor"
  breadcrumbs={[
    { label: 'projects', href: '/projects/' },
    { label: 'latex resume editor', href: '/projects/latex-resume-editor/' },
    { label: 'app' },
  ]}
>
  <meta slot="head" name="site-backend" content="cv" data-port="3001" data-label="CV Backend" />

  <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"
  ></script>

  <div class="cv-app" x-data="app()" x-init="init()">
    <!-- Mobile view switcher (visible ≤768px only) -->
    <div class="cv-mobile-toolbar" x-cloak>
      <select class="cv-mobile-view-select"
        :value="mobileView"
        @change="setMobileView($event.target.value)">
        <option value="editor">Editor</option>
        <option value="cv">CV</option>
        <option value="resume">Resume</option>
        <option value="coverletter">Cover Letter</option>
      </select>
      <div style="position:relative">
        <button class="btn cv-mobile-file-btn"
          @click="mobileFileMenu = !mobileFileMenu"
          aria-label="File menu">
          <img src="https://unpkg.com/lucide-static@1.7.0/icons/menu.svg" alt="" width="18" height="18" />
        </button>
        <div class="cv-mobile-file-dropdown" x-show="mobileFileMenu" @click.outside="mobileFileMenu = false" @click="mobileFileMenu = false" x-cloak>
          <button @click="createPerson()">New</button>
          <button @click="openPerson()">Open</button>
          <button @click="renamePerson()">Rename</button>
          <hr />
          <button @click="save()">Save</button>
          <button @click="exportData()">Export JSON</button>
          <button @click="importData()">Import JSON</button>
          <hr />
          <button @click="compile()">Compile</button>
        </div>
      </div>
    </div>

    <!-- Modal overlay -->
    <div class="cv-modal-overlay" x-show="modal.open" @click.self="cancelModal()" x-cloak>
      <div class="standard-dialog cv-modal-dialog" role="dialog" aria-modal="true">
        <div class="title-bar">
          <span class="title" x-text="modal.title"></span>
        </div>
        <div class="modal-contents cv-modal-body">
          <template x-for="(field, fi) in modal.fields" :key="fi">
            <div class="field-row cv-modal-field">
              <label x-text="field.label"></label>
              <template x-if="field.options">
                <select x-model="field.value" :autofocus="fi === 0">
                  <template x-for="opt in field.options" :key="opt.value">
                    <option :value="opt.value" x-text="opt.label"></option>
                  </template>
                </select>
              </template>
              <template x-if="!field.options">
                <input
                  type="text"
                  x-model="field.value"
                  @keydown.enter="submitModal()"
                  @input="validateModalField(field)"
                  :autofocus="fi === 0"
                />
              </template>
              <span class="cv-modal-error" x-show="field.error" x-text="field.error"></span>
            </div>
          </template>
          <div class="field-row cv-modal-actions">
            <button class="btn btn-default" @click="submitModal()" :disabled="modalHasErrors()">OK</button>
            <button class="btn" @click="cancelModal()">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Section picker modal -->
    <div class="cv-modal-overlay" x-show="sectionPicker.open" @click.self="cancelSectionPicker()" x-cloak>
      <div class="standard-dialog cv-modal-dialog cv-picker-dialog" role="dialog" aria-modal="true">
        <div class="title-bar">
          <span class="title">New Section</span>
        </div>
        <div class="modal-contents cv-modal-body">
          <div class="field-row cv-modal-field">
            <label>Title</label>
            <input type="text" x-model="sectionPicker.title" @keydown.enter="submitSectionPicker()" autofocus />
          </div>
          <div class="cv-picker-list" role="radiogroup" aria-label="Section type">
            <details class="cv-picker-group" open>
              <summary class="cv-picker-category">Roles &amp; Experience</summary>
              <template x-for="preset in getPresetsByCategory().roles" :key="preset.key">
                <button class="cv-picker-item" role="radio"
                  :aria-checked="sectionPicker.selected === preset.key"
                  :class="{ 'cv-picker-selected': sectionPicker.selected === preset.key }"
                  :title="preset.description"
                  @click="selectPreset(preset.key)"
                  x-text="preset.label">
                </button>
              </template>
            </details>
            <details class="cv-picker-group" open>
              <summary class="cv-picker-category">Achievements</summary>
              <template x-for="preset in getPresetsByCategory().achievements" :key="preset.key">
                <button class="cv-picker-item" role="radio"
                  :aria-checked="sectionPicker.selected === preset.key"
                  :class="{ 'cv-picker-selected': sectionPicker.selected === preset.key }"
                  :title="preset.description"
                  @click="selectPreset(preset.key)"
                  x-text="preset.label">
                </button>
              </template>
            </details>
            <details class="cv-picker-group" open>
              <summary class="cv-picker-category">Other</summary>
              <template x-for="preset in getPresetsByCategory().other" :key="preset.key">
                <button class="cv-picker-item" role="radio"
                  :aria-checked="sectionPicker.selected === preset.key"
                  :class="{ 'cv-picker-selected': sectionPicker.selected === preset.key }"
                  :title="preset.description"
                  @click="selectPreset(preset.key)"
                  x-text="preset.label">
                </button>
              </template>
            </details>
          </div>
          <div class="field-row cv-modal-actions">
            <button class="btn btn-default" @click="submitSectionPicker()">OK</button>
            <button class="btn" @click="cancelSectionPicker()">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Main layout: split pane -->
    <main class="cv-split-layout"
      :class="{
        'cv-readonly': !serverConnected,
        'cv-mobile-show-editor': mobileView === 'editor',
        'cv-mobile-show-pdf': mobileView !== 'editor'
      }"
      aria-label="CV Editor">
      <!-- Left column: editor -->
      <div class="cv-left-col">
        <div class="window cv-inner-window">
          <div class="title-bar">
            <span class="title">Editor</span>
          </div>
        <!-- Editor tab bar -->
        <div class="details-bar cv-editor-tabs">
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'profile' }"
            @click="editorTab = 'profile'">Profile</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'sections' }"
            @click="editorTab = 'sections'">Sections</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'coverletter' }"
            @click="editorTab = 'coverletter'">Letter</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'style' }"
            @click="editorTab = 'style'">Style</button
          >
        </div>

        <!-- ===== Universal Toolbar ===== -->
        <div class="cv-section-toolbar">
          <img class="cv-toolbar-icon" src="https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg" alt="Expand All" title="Expand All" width="28" height="28"
            @click="expandAll()" />
          <img class="cv-toolbar-icon" src="https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg" alt="Collapse All" title="Collapse All" width="28" height="28"
            @click="collapseAll()" />
          <img class="cv-toolbar-icon" src="https://unpkg.com/lucide-static@1.7.0/icons/undo-2.svg" alt="Undo" title="Undo" width="28" height="28"
            @click="undo()" :style="canUndo() ? '' : 'opacity:0.15;pointer-events:none'" />
          <img class="cv-toolbar-icon" src="https://unpkg.com/lucide-static@1.7.0/icons/redo-2.svg" alt="Redo" title="Redo" width="28" height="28"
            @click="redo()" :style="canRedo() ? '' : 'opacity:0.15;pointer-events:none'" />
          <img class="cv-toolbar-icon" src="https://unpkg.com/lucide-static@1.7.0/icons/plus.svg" alt="Add section" title="Add section" width="28" height="28"
            @click="createNewSection()" x-show="editorTab === 'sections' && serverConnected" />
          <span class="cv-save-dot"
            :class="{ 'cv-save-disconnected': saveState === 'disconnected', 'cv-save-unsaved': saveState === 'unsaved', 'cv-save-saved': saveState === 'saved', 'cv-save-error': saveState === 'error' }"
            :title="saveState === 'disconnected' ? 'Not connected' : saveState === 'error' ? 'Save error' : saveState === 'unsaved' ? 'Unsaved changes' : 'All saved'"
          ></span>
        </div>

        <!-- ===== Profile Tab ===== -->
        <div x-show="editorTab === 'profile'" class="cv-tab-content">
          <!-- Identity -->
          <h2 class="cv-node-header" @click="_panels.identity = !_panels.identity" :aria-expanded="_panels.identity">
            <img class="cv-node-expand-icon" :src="_panels.identity ? 'https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg'" alt="" width="14" height="14" />
            <span style="flex:1">Identity</span>
            <button class="cv-node-edit" @click.stop="openAddIdentityExtra()" x-show="serverConnected && availableIdentityExtras().length > 0" title="Add field" aria-label="Add field">
              <img src="https://unpkg.com/lucide-static@1.7.0/icons/plus.svg" alt="" width="14" height="14" />
            </button>
          </h2>
          <div class="cv-node-fields" x-show="_panels.identity" :inert="!serverConnected">
            <label>First Name <input type="text" x-model="personal.firstName" @input="autoSavePersonal('firstName')" @focus="snapshotField('personal', 'firstName')" @blur="commitField('personal', 'firstName')" /></label>
            <label>Last Name <input type="text" x-model="personal.lastName" @input="autoSavePersonal('lastName')" @focus="snapshotField('personal', 'lastName')" @blur="commitField('personal', 'lastName')" /></label>
            <label>Position <input type="text" x-model="personal.position" @input="autoSavePersonal('position')" @focus="snapshotField('personal', 'position')" @blur="commitField('personal', 'position')" /></label>
            <label>Address <input type="text" x-model="personal.address" @input="autoSavePersonal('address')" @focus="snapshotField('personal', 'address')" @blur="commitField('personal', 'address')" /></label>
            <template x-for="key in identityExtras" :key="key">
              <label>
                <div class="cv-extra-label"><span x-text="identityExtra(key).label"></span><img class="cv-toolbar-icon cv-link-remove" src="https://unpkg.com/lucide-static@1.7.0/icons/x.svg" width="10" height="10" alt="Remove" title="Remove" @click.prevent="removeIdentityExtra(key)" /></div>
                <template x-if="key === 'photo'">
                  <div class="cv-link-multi">
                    <label class="cv-toggle" @click.stop><input type="checkbox" :checked="personal.photoEnabled === '1'" @change="togglePhoto()" /><span x-text="personal.photoEnabled === '1' ? 'On' : 'Off'"></span></label>
                    <input type="text" x-model="personal.photoFile" @input="autoSavePersonal('photoFile')" @focus="snapshotField('personal', 'photoFile')" @blur="commitField('personal', 'photoFile')" placeholder="filename" x-show="personal.photoEnabled === '1'" />
                  </div>
                </template>
                <template x-if="key !== 'photo'">
                  <input type="text" x-model="personal[key]" @input="autoSavePersonal(key)" @focus="snapshotField('personal', key)" @blur="commitField('personal', key)" :placeholder="identityExtra(key).placeholder" />
                </template>
              </label>
            </template>
          </div>

          <!-- Contact -->
          <h2 class="cv-node-header" @click="_panels.contact = !_panels.contact" :aria-expanded="_panels.contact">
            <img class="cv-node-expand-icon" :src="_panels.contact ? 'https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg'" alt="" width="14" height="14" />
            Contact
          </h2>
          <div class="cv-node-fields" x-show="_panels.contact" :inert="!serverConnected">
            <label>Mobile <input type="text" x-model="personal.mobile" @input="autoSavePersonal('mobile')" @focus="snapshotField('personal', 'mobile')" @blur="commitField('personal', 'mobile')" /></label>
            <label>Email <input type="text" x-model="personal.email" @input="autoSavePersonal('email')" @focus="snapshotField('personal', 'email')" @blur="commitField('personal', 'email')" /></label>
          </div>

          <!-- Links -->
          <h2 class="cv-node-header" @click="_panels.links = !_panels.links" :aria-expanded="_panels.links">
            <img class="cv-node-expand-icon" :src="_panels.links ? 'https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg'" alt="" width="14" height="14" />
            <span style="flex:1">Links</span>
            <button class="cv-node-edit" @click.stop="openAddLink()" x-show="serverConnected && availableLinks().length > 0" title="Add link" aria-label="Add link">
              <img src="https://unpkg.com/lucide-static@1.7.0/icons/plus.svg" alt="" width="14" height="14" />
            </button>
          </h2>
          <div class="cv-node-fields" x-show="_panels.links" :inert="!serverConnected">
            <template x-for="key in personalLinks" :key="key">
              <label>
                <div class="cv-extra-label"><span x-text="catalogEntry(key).label"></span><img class="cv-toolbar-icon cv-link-remove" src="https://unpkg.com/lucide-static@1.7.0/icons/x.svg" width="10" height="10" alt="Remove" title="Remove" @click.prevent="removeLink(key)" /></div>
                <template x-if="catalogEntry(key).args === 1">
                  <input type="text" x-model="personal[key]" @input="autoSavePersonal(key)" @focus="snapshotField('personal', key)" @blur="commitField('personal', key)" :placeholder="catalogEntry(key).placeholder" />
                </template>
                <template x-if="catalogEntry(key).args === 2">
                  <div class="cv-link-multi">
                    <input type="text" x-model="personal[catalogEntry(key).fields[0]]" @input="autoSavePersonal(catalogEntry(key).fields[0])" @focus="snapshotField('personal', catalogEntry(key).fields[0])" @blur="commitField('personal', catalogEntry(key).fields[0])" :placeholder="catalogEntry(key).placeholders[0]" />
                    <input type="text" x-model="personal[catalogEntry(key).fields[1]]" @input="autoSavePersonal(catalogEntry(key).fields[1])" @focus="snapshotField('personal', catalogEntry(key).fields[1])" @blur="commitField('personal', catalogEntry(key).fields[1])" :placeholder="catalogEntry(key).placeholders[1]" />
                  </div>
                </template>
              </label>
            </template>
            <div x-show="personalLinks.length === 0" class="cv-muted" style="padding:8px 12px">No links added. Use + above to add one.</div>
          </div>
        </div>

        <!-- ===== Sections Tab ===== -->
        <div x-show="editorTab === 'sections'" class="cv-tab-content">
          <div id="section-list" class="cv-node-list">
            <template x-for="(sec, i) in docSections" :key="sec.id">
              <!-- ══ DEPTH 0: Section ══ -->
              <div class="cv-node" data-depth="0" :class="{ 'cv-node-excluded': !sec.enabled }">
                <div class="cv-node-header"
                  @click="sec._expanded = !sec._expanded; if(sec._expanded) loadSectionData(sec)"
                  :aria-expanded="sec._expanded"
                >
                  <span class="cv-node-arrows" @click.stop>
                    <button class="cv-node-arrow" @click="moveSection(i, -1)" :disabled="i === 0" title="Move up" aria-label="Move up">&uarr;</button>
                    <button class="cv-node-arrow" @click="moveSection(i, 1)" :disabled="i === docSections.length - 1" title="Move down" aria-label="Move down">&darr;</button>
                  </span>
                  <img class="cv-node-expand-icon" :src="sec._expanded ? 'https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg'" alt="" width="14" height="14" />
                  <span class="cv-node-title-display" x-text="sec.title"></span>
                  <button class="cv-node-edit" @click.stop="renameSection(sec.id)" title="Rename section">
                    <img src="https://unpkg.com/lucide-static@1.7.0/icons/pencil.svg" alt="Rename" width="14" height="14" />
                  </button>
                  <button class="cv-node-edit" @click.stop="addEntry(sec)" title="Add entry" aria-label="Add entry" x-show="sec._expanded && sec._data && !SECTION_TYPES[sec._data?.type]?.isParagraph">
                    <img src="https://unpkg.com/lucide-static@1.7.0/icons/plus.svg" alt="" width="14" height="14" />
                  </button>
                  <button class="cv-node-toggle" @click.stop="sec.enabled = !sec.enabled; toggleSection(i)">
                    <img :src="sec.enabled ? 'https://unpkg.com/lucide-static@1.7.0/icons/eye.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/eye-off.svg'" alt="Toggle resume inclusion" width="16" height="16" class="cv-toggle-icon" />
                  </button>
                  <button class="cv-node-delete" @click.stop="deleteSection(sec.id)" title="Delete section" aria-label="Delete">&times;</button>
                </div>

                <div x-show="sec._expanded" class="cv-node-body" :inert="!serverConnected">
                  <template x-if="sec._data">
                    <div>
                      <!-- ── Entries (all types except cvparagraph) ── -->
                      <template x-if="!SECTION_TYPES[sec._data.type]?.isParagraph">
                        <div class="cv-node-children">
                          <template x-for="(entry, entryIdx) in sec._data.entries" :key="entry.id">
                            <!-- ══ DEPTH 1: Entry ══ -->
                            <div class="cv-node" data-depth="1" :class="{ 'cv-node-excluded': !entry.resumeIncluded }">
                              <div class="cv-node-header" @click="entry._expanded = !entry._expanded" :aria-expanded="entry._expanded">
                                <span class="cv-node-arrows" @click.stop>
                                  <button class="cv-node-arrow" @click="moveEntry(sec, entryIdx, -1)" :disabled="entryIdx === 0" title="Move up" aria-label="Move up">&uarr;</button>
                                  <button class="cv-node-arrow" @click="moveEntry(sec, entryIdx, 1)" :disabled="entryIdx === sec._data.entries.length - 1" title="Move down" aria-label="Move down">&darr;</button>
                                </span>
                                <img class="cv-node-expand-icon" :src="entry._expanded ? 'https://unpkg.com/lucide-static@1.7.0/icons/minimize-2.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/maximize-2.svg'" alt="" width="12" height="12" />
                                <span class="cv-node-title-display" x-show="!entry._editing" x-text="getSectionTitle(sec.type, entry.fields)"></span>
                                <input x-show="entry._editing" x-ref="entryTitleInput" type="text" class="cv-node-title"
                                  :value="entry.fields[getSectionTitleField(sec.type)] || ''"
                                  @click.stop
                                  @keydown.enter="$event.target.blur()"
                                  @blur="
                                    entry._editing = false;
                                    const field = getSectionTitleField(sec.type);
                                    if (field) entry.fields[field] = $event.target.value;
                                    autoSaveEntry(entry);
                                  " />
                                <button class="cv-node-edit" @click.stop="entry._editing = !entry._editing; if(entry._editing) $nextTick(() => $refs.entryTitleInput?.focus())" title="Edit name">
                                  <img src="https://unpkg.com/lucide-static@1.7.0/icons/pencil.svg" alt="Edit" width="14" height="14" />
                                </button>
                                <button class="cv-node-toggle" @click.stop="entry.resumeIncluded = !entry.resumeIncluded; toggleResumeEntry(entry)">
                                  <img :src="entry.resumeIncluded ? 'https://unpkg.com/lucide-static@1.7.0/icons/eye.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/eye-off.svg'" alt="Toggle resume inclusion" width="14" height="14" class="cv-toggle-icon" />
                                </button>
                                <button class="cv-node-delete" @click.stop="removeEntry(sec, entry.id)" aria-label="Delete">&times;</button>
                              </div>

                              <div x-show="entry._expanded" class="cv-node-body">
                                <!-- Type-specific fields -->
                                <div class="cv-node-fields">
                                  <template x-for="field in (SECTION_TYPES[sec.type]?.fields || [])" :key="field.key">
                                    <label>
                                      <span x-text="field.label"></span>
                                      <template x-if="field.options">
                                        <select :value="entry.fields[field.key]"
                                          @change="entry.fields[field.key] = $event.target.value; autoSaveEntry(entry)">
                                          <template x-for="opt in field.options" :key="opt">
                                            <option :value="opt" x-text="opt || '—'" :selected="entry.fields[field.key] === opt"></option>
                                          </template>
                                        </select>
                                      </template>
                                      <template x-if="!field.options">
                                        <input type="text" :value="entry.fields[field.key]"
                                          @input="entry.fields[field.key] = $event.target.value; autoSaveEntry(entry)" />
                                      </template>
                                    </label>
                                  </template>
                                </div>

                                <!-- Child items (bullets) — only for cventries -->
                                <template x-if="SECTION_TYPES[sec.type]?.hasItems">
                                  <div>
                                    <div class="cv-node-children-header">
                                      <label class="cv-node-children-label" x-text="(SECTION_TYPES[sec.type]?.itemLabel || 'Bullet') + ' Points'"></label>
                                      <button class="cv-node-edit" @click.stop="addItem(entry)" title="Add item" aria-label="Add item">
                                        <img src="https://unpkg.com/lucide-static@1.7.0/icons/plus.svg" alt="" width="14" height="14" />
                                      </button>
                                    </div>
                                    <div class="cv-node-children">
                                    <template x-for="(item, itemIdx) in entry.items" :key="item.id">
                                      <!-- ══ DEPTH 2: Item (flat row) ══ -->
                                      <div class="cv-item-row" :class="{ 'cv-node-excluded': !item.resumeIncluded }">
                                        <span class="cv-node-arrows">
                                          <button class="cv-node-arrow" @click="moveItem(entry, itemIdx, -1)" :disabled="itemIdx === 0" title="Move up" aria-label="Move up">&uarr;</button>
                                          <button class="cv-node-arrow" @click="moveItem(entry, itemIdx, 1)" :disabled="itemIdx === entry.items.length - 1" title="Move down" aria-label="Move down">&darr;</button>
                                        </span>
                                        <textarea x-model="item.content" rows="1" @input="autoSaveItem(item); $event.target.style.height = 'auto'; $event.target.style.height = $event.target.scrollHeight + 'px'" :aria-label="'Bullet point'" class="cv-item-textarea" :readonly="!serverConnected" placeholder="Enter bullet point..."></textarea>
                                        <button class="cv-node-toggle" @click.stop="item.resumeIncluded = !item.resumeIncluded; toggleResumeItem(item)">
                                          <img :src="item.resumeIncluded ? 'https://unpkg.com/lucide-static@1.7.0/icons/eye.svg' : 'https://unpkg.com/lucide-static@1.7.0/icons/eye-off.svg'" alt="Toggle resume inclusion" width="12" height="12" class="cv-toggle-icon" />
                                        </button>
                                        <button class="cv-node-delete" @click.stop="removeItem(entry, item.id)" aria-label="Delete">&times;</button>
                                      </div>
                                    </template>
                                    </div>
                                  </div>
                                </template>
                              </div>
                            </div>
                          </template>
                        </div>
                      </template>

                      <!-- ── cvparagraph (special case) ── -->
                      <template x-if="SECTION_TYPES[sec._data.type]?.isParagraph">
                        <div class="cv-node-children">
                          <template x-if="sec._data.entries.length > 0">
                            <div class="cv-node-fields">
                              <textarea x-model="sec._data.entries[0].fields.text" rows="4" class="cv-full-textarea"
                                @input="autoSaveParagraph(sec)" aria-label="Text"></textarea>
                            </div>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>
                  <template x-if="!sec._data">
                    <p class="cv-muted">Loading...</p>
                  </template>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- ===== Cover Letter Tab ===== -->
