  <script is:inline>
    // ── File menu (injected into navbar before CV Backend) ──
    (function () {
      function _cvApp() {
        var el = document.querySelector('.cv-app');
        return el && el._x_dataStack ? el._x_dataStack[0] : null;
      }

      function createNavMenu(className, labelText, menuItems) {
        var menuLi = document.createElement('li');
        menuLi.setAttribute('role', 'menu-item');
        menuLi.setAttribute('aria-haspopup', 'true');
        menuLi.setAttribute('tabindex', '0');
        menuLi.className = className;
        menuLi.style.cursor = 'pointer';

        var label = document.createElement('span');
        label.textContent = labelText;
        label.style.pointerEvents = 'none';
        menuLi.appendChild(label);

        var _open = false;
        menuLi.addEventListener('mousedown', function (e) {
          if (_open) {
            e.preventDefault();
            menuLi.blur();
            _open = false;
          }
        });
        menuLi.addEventListener('focus', function () { _open = true; });
        menuLi.addEventListener('blur', function () { _open = false; });

        var subUl = document.createElement('ul');
        subUl.setAttribute('role', 'menu');

        for (var i = 0; i < menuItems.length; i++) {
          var li = document.createElement('li');
          li.setAttribute('role', 'menu-item');
          var a = document.createElement('a');
          a.href = '#';
          a.textContent = menuItems[i].text;
          (function (fn, parent) {
            a.addEventListener('mousedown', function (e) {
              e.preventDefault();
              e.stopPropagation();
              fn();
              parent.blur();
            });
            a.addEventListener('keydown', function (e) {
              if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                fn();
                parent.blur();
              }
            });
          })(menuItems[i].action, menuLi);
          li.appendChild(a);
          subUl.appendChild(li);
        }

        menuLi.appendChild(subUl);
        return menuLi;
      }

      function initNavMenus() {
        var ul = document.querySelector('.site-menubar ul[role="menu-bar"]');
        if (!ul || ul.querySelector('.cv-file-nav')) return;

        var serverItem = ul.querySelector('.server-nav-item');

        // File menu — dynamically built to include person list under Open
        var fileMenuLi = document.createElement('li');
        fileMenuLi.setAttribute('role', 'menu-item');
        fileMenuLi.setAttribute('aria-haspopup', 'true');
        fileMenuLi.setAttribute('tabindex', '0');
        fileMenuLi.className = 'cv-file-nav';
        fileMenuLi.style.cursor = 'pointer';
        var fileLabel = document.createElement('span');
        fileLabel.textContent = 'File';
        fileLabel.style.pointerEvents = 'none';
        fileMenuLi.appendChild(fileLabel);
        var _fOpen = false;
        fileMenuLi.addEventListener('mousedown', function (e) {
          if (_fOpen) { e.preventDefault(); fileMenuLi.blur(); _fOpen = false; }
        });
        fileMenuLi.addEventListener('focus', function () { _fOpen = true; buildFileSubmenu(); });
        fileMenuLi.addEventListener('blur', function () { _fOpen = false; });
        var fileSubUl = document.createElement('ul');
        fileSubUl.setAttribute('role', 'menu');
        fileMenuLi.appendChild(fileSubUl);

        function addFileItem(ul, text, action) {
          var li = document.createElement('li');
          li.setAttribute('role', 'menu-item');
          var a = document.createElement('a');
          a.href = '#';
          a.textContent = text;
          a.addEventListener('mousedown', function (e) {
            e.preventDefault(); e.stopPropagation();
            action();
            fileMenuLi.blur();
          });
          li.appendChild(a);
          ul.appendChild(li);
        }

        function addFileSep(ul) {
          var sep = document.createElement('li');
          sep.style.borderTop = '1px solid #ccc';
          sep.style.margin = '2px 0';
          ul.appendChild(sep);
        }

        function buildFileSubmenu() {
          var app = _cvApp();
          fileSubUl.innerHTML = '';
          addFileItem(fileSubUl, 'New', function () { if (app) app.createPerson(); });
          addFileItem(fileSubUl, 'Open', function () { if (app) app.openPerson(); });
          addFileItem(fileSubUl, 'Rename', function () { if (app) app.renamePerson(); });
          addFileSep(fileSubUl);
          addFileItem(fileSubUl, 'Save', function () { if (app && app.save) app.save(); });
          addFileItem(fileSubUl, 'Export JSON', function () { if (app && app.exportData) app.exportData(); });
          addFileItem(fileSubUl, 'Import JSON', function () { if (app && app.importData) app.importData(); });
          addFileSep(fileSubUl);
          addFileItem(fileSubUl, 'Compile', function () { if (app && app.compile) app.compile(); });
        }

        var fileMenu = fileMenuLi;

        // View menu
        var viewMenu = createNavMenu('cv-view-nav', 'View', [
          { text: 'CV', action: function () { var a = _cvApp(); if (a) a.switchPdfTab('cv'); } },
          { text: 'Resume', action: function () { var a = _cvApp(); if (a) a.switchPdfTab('resume'); } },
          { text: 'Cover Letter', action: function () { var a = _cvApp(); if (a) a.switchPdfTab('coverletter'); } },
        ]);

        if (serverItem) {
          ul.insertBefore(viewMenu, serverItem);
          ul.insertBefore(fileMenu, viewMenu);
        } else {
          ul.appendChild(fileMenu);
          ul.appendChild(viewMenu);
        }
      }

      // Wait for ServerConnectModal to inject its item first
      document.addEventListener('navbar:connect-ready', function () {
        setTimeout(initNavMenus, 0);
      });

      // Fallback if no backend meta tag exists
      if (!document.querySelector('meta[name="site-backend"]')) {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initNavMenus);
        } else {
          initNavMenus();
        }
      }
    })();
  </script>

  <script is:inline>
    var API_BASE = '';
    (function () {
      var _cvWidget = null;

      document.addEventListener('navbar:connect-ready', function (e) {
        if (e.detail.service !== 'cv') return;
        _cvWidget = e.detail.widget;
      });

      document.addEventListener('navbar:connect', function (e) {
        if (e.detail.service !== 'cv') return;
        if (_cvWidget) _cvWidget.setStatus('connecting');
        var url = e.detail.url;
        fetch(url + '/api/health')
          .then(function (r) {
            if (!r.ok) throw new Error('Health check failed');
            return r.json();
          })
          .then(function (data) {
            if (data.status !== 'ok' || data.service !== 'cv')
              throw new Error('Bad health response');
            API_BASE = url;
            var el = document.querySelector('.cv-app');
            if (el && el._x_dataStack) {
              return el._x_dataStack[0].init();
            }
          })
          .then(function () {
            if (_cvWidget) _cvWidget.setStatus('connected');
          })
          .catch(function (err) {
            console.error('CV backend connect failed:', err);
            if (_cvWidget) _cvWidget.setStatus('error');
          });
      });

      document.addEventListener('navbar:disconnect', function (e) {
        if (e.detail.service !== 'cv') return;
        API_BASE = '';
        var el = document.querySelector('.cv-app');
        if (el && el._x_dataStack) el._x_dataStack[0].serverConnected = false;
        if (_cvWidget) _cvWidget.setStatus('disconnected');
      });

      document.addEventListener('navbar:dismiss', function (e) {
        if (e.detail.service !== 'cv') return;
        var el = document.querySelector('.cv-app');
        if (el && el._x_dataStack) el._x_dataStack[0].init();
      });
    })();
  </script>
