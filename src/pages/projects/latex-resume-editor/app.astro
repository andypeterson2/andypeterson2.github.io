---
import BaseLayout from '../../../layouts/BaseLayout.astro';
// siteConfig imported to satisfy privacy-seo test; editor uses DB-driven personal data
import { siteConfig } from '../../../config/site';
---

<BaseLayout
  title="LaTeX Resume Editor"
  breadcrumbs={[
    { label: 'projects', href: '/projects/' },
    { label: 'latex resume editor', href: '/projects/latex-resume-editor/' },
    { label: 'app' },
  ]}
>
  <meta slot="head" name="site-backend" content="cv" data-port="3001" data-label="CV Backend" />

  <script is:inline src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"
  ></script>

  <div class="cv-app" x-data="app()" x-init="init()">
    <!-- Modal overlay -->
    <div class="cv-modal-overlay" x-show="modal.open" @click.self="cancelModal()" x-cloak>
      <div class="standard-dialog cv-modal-dialog" role="dialog" aria-modal="true">
        <div class="title-bar">
          <span class="title" x-text="modal.title"></span>
        </div>
        <div class="modal-contents cv-modal-body">
          <template x-for="(field, fi) in modal.fields" :key="fi">
            <div class="field-row cv-modal-field">
              <label x-text="field.label"></label>
              <input
                type="text"
                x-model="field.value"
                @keydown.enter="submitModal()"
                :autofocus="fi === 0"
              />
            </div>
          </template>
          <div class="field-row cv-modal-actions">
            <button class="btn btn-default" @click="submitModal()">OK</button>
            <button class="btn" @click="cancelModal()">Cancel</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Details bar -->
    <div class="details-bar cv-details-bar">
      <!-- Person selector -->
      <div class="field-row cv-toolbar-group">
        <select @change="handlePersonSelect($event.target.value)" aria-label="Active person">
          <template x-for="p in (persons || [])" :key="p.id">
            <option :value="p.id" x-text="p.name" :selected="p.id === activePersonId"></option>
          </template>
          <option value="__new__">[New]</option>
        </select>
      </div>
      <!-- Save -->
      <button class="btn" @click="save && save()" :disabled="!dirty" title="Save changes">
        Save<span x-show="dirty">*</span>
      </button>
      <!-- Import / Export -->
      <button class="btn" @click="exportData && exportData()" title="Export JSON"
        >&#8593; Export</button
      >
      <button class="btn" @click="importData && importData()" title="Import JSON"
        >&#8595; Import</button
      >
      <!-- Compile -->
      <button
        class="btn btn-default"
        @click="compile()"
        :disabled="compiling"
        aria-label="Compile document to PDF"
      >
        <span x-show="!compiling">&#9654; Compile</span>
        <span x-show="compiling">Compiling&hellip;</span>
      </button>
      <!-- Spacer -->
      <div class="cv-toolbar-spacer"></div>
      <!-- PDF variant radios -->
      <div class="field-row cv-toolbar-group">
        <input
          type="radio"
          id="pdf-cv"
          name="pdfTab"
          value="cv"
          :checked="pdfTab === 'cv'"
          @change="switchPdfTab('cv')"
        />
        <label for="pdf-cv">CV</label>
      </div>
      <div class="field-row cv-toolbar-group">
        <input
          type="radio"
          id="pdf-resume"
          name="pdfTab"
          value="resume"
          :checked="pdfTab === 'resume'"
          @change="switchPdfTab('resume')"
        />
        <label for="pdf-resume">Resume</label>
      </div>
      <div class="field-row cv-toolbar-group">
        <input
          type="radio"
          id="pdf-coverletter"
          name="pdfTab"
          value="coverletter"
          :checked="pdfTab === 'coverletter'"
          @change="switchPdfTab('coverletter')"
        />
        <label for="pdf-coverletter">Cover Letter</label>
      </div>
    </div>

    <!-- Main layout: split pane -->
    <main class="cv-split-layout" aria-label="CV Editor">
      <!-- Left column: editor -->
      <div class="cv-left-col">
        <!-- Editor tab bar -->
        <div class="details-bar cv-editor-tabs">
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'profile' }"
            @click="editorTab = 'profile'">Profile</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'sections' }"
            @click="editorTab = 'sections'">Sections</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'coverletter' }"
            @click="editorTab = 'coverletter'">Cover Ltr</button
          >
          <button
            class="btn cv-editor-tab"
            :class="{ 'btn-default': editorTab === 'style' }"
            @click="editorTab = 'style'">Style</button
          >
        </div>

        <div
          class="cv-alert"
          x-show="statusMsg"
          x-text="statusMsg"
          :class="statusType"
          role="status"
        >
        </div>

        <!-- ===== Profile Tab ===== -->
        <div x-show="editorTab === 'profile'" class="cv-tab-content">
          <!-- Identity -->
          <h2 class="cv-profile-heading">Identity</h2>
          <div class="cv-profile-grid">
            <label class="field-row cv-field"
              >First Name <input
                type="text"
                x-model="personal.firstName"
                @input="autoSavePersonal('firstName')"
              /></label
            >
            <label class="field-row cv-field"
              >Last Name <input
                type="text"
                x-model="personal.lastName"
                @input="autoSavePersonal('lastName')"
              /></label
            >
            <label class="field-row cv-field"
              >Position <input
                type="text"
                x-model="personal.position"
                @input="autoSavePersonal('position')"
              /></label
            >
            <label class="field-row cv-field"
              >Address <input
                type="text"
                x-model="personal.address"
                @input="autoSavePersonal('address')"
              /></label
            >
            <label class="field-row cv-field"
              >Date of Birth <input
                type="text"
                x-model="personal.dateofbirth"
                @input="autoSavePersonal('dateofbirth')"
                placeholder="e.g. January 1, 1990"
              /></label
            >
            <div class="cv-toggle-row">
              <span>Photo</span>
              <label class="cv-toggle">
                <input
                  type="checkbox"
                  :checked="personal.photoEnabled === '1'"
                  @change="togglePhoto()"
                />
                <span x-text="personal.photoEnabled === '1' ? 'On' : 'Off'"></span>
              </label>
            </div>
            <template x-if="personal.photoEnabled === '1'">
              <label class="field-row cv-field"
                >Photo File <span class="cv-hint">(filename)</span>
                <input
                  type="text"
                  x-model="personal.photoFile"
                  @input="autoSavePersonal('photoFile')"
                  placeholder="e.g. profile"
                />
              </label>
            </template>
            <label class="cv-form-field cv-profile-full"
              >Quote <span class="cv-hint">(optional, shown in header)</span>
              <input
                type="text"
                x-model="personal.quote"
                @input="autoSavePersonal('quote')"
                placeholder="Leave blank to hide"
              />
            </label>
            <label class="cv-form-field cv-profile-full"
              >Extra Info <span class="cv-hint">(custom text shown in header)</span>
              <input
                type="text"
                x-model="personal.extrainfo"
                @input="autoSavePersonal('extrainfo')"
                placeholder="Leave blank to hide"
              />
            </label>
          </div>

          <!-- Contact -->
          <h2 class="cv-profile-heading">Contact</h2>
          <div class="cv-profile-grid">
            <label class="field-row cv-field"
              >Mobile <input
                type="text"
                x-model="personal.mobile"
                @input="autoSavePersonal('mobile')"
              /></label
            >
            <label class="field-row cv-field"
              >Email <input
                type="text"
                x-model="personal.email"
                @input="autoSavePersonal('email')"
              /></label
            >
            <label class="field-row cv-field"
              >WhatsApp <input
                type="text"
                x-model="personal.whatsapp"
                @input="autoSavePersonal('whatsapp')"
                placeholder="Phone number"
              /></label
            >
            <label class="field-row cv-field"
              >Skype <input
                type="text"
                x-model="personal.skype"
                @input="autoSavePersonal('skype')"
                placeholder="Username"
              /></label
            >
            <label class="field-row cv-field"
              >Telegram <input
                type="text"
                x-model="personal.telegram"
                @input="autoSavePersonal('telegram')"
                placeholder="Username"
              /></label
            >
          </div>

          <!-- Web & Code -->
          <h2 class="cv-profile-heading">Web &amp; Code</h2>
          <div class="cv-profile-grid">
            <label class="field-row cv-field"
              >Homepage <input
                type="text"
                x-model="personal.homepage"
                @input="autoSavePersonal('homepage')"
                placeholder="yoursite.com"
              /></label
            >
            <label class="field-row cv-field"
              >GitHub <input
                type="text"
                x-model="personal.github"
                @input="autoSavePersonal('github')"
              /></label
            >
            <label class="field-row cv-field"
              >LinkedIn <input
                type="text"
                x-model="personal.linkedin"
                @input="autoSavePersonal('linkedin')"
              /></label
            >
            <label class="field-row cv-field"
              >GitLab <input
                type="text"
                x-model="personal.gitlab"
                @input="autoSavePersonal('gitlab')"
              /></label
            >
            <label class="field-row cv-field"
              >Bitbucket <input
                type="text"
                x-model="personal.bitbucket"
                @input="autoSavePersonal('bitbucket')"
              /></label
            >
          </div>

          <!-- Social -->
          <h2 class="cv-profile-heading">Social</h2>
          <div class="cv-profile-grid">
            <label class="field-row cv-field"
              >Twitter <input
                type="text"
                x-model="personal.twitter"
                @input="autoSavePersonal('twitter')"
                placeholder="Handle"
              /></label
            >
            <label class="field-row cv-field"
              >X <span class="cv-hint">(if different from Twitter)</span>
              <input
                type="text"
                x-model="personal.x"
                @input="autoSavePersonal('x')"
                placeholder="Handle"
              /></label
            >
            <label class="field-row cv-field"
              >Reddit <input
                type="text"
                x-model="personal.reddit"
                @input="autoSavePersonal('reddit')"
                placeholder="Username"
              /></label
            >
            <label class="field-row cv-field"
              >Medium <input
                type="text"
                x-model="personal.medium"
                @input="autoSavePersonal('medium')"
                placeholder="Username"
              /></label
            >
            <label class="field-row cv-field"
              >Xing <input
                type="text"
                x-model="personal.xing"
                @input="autoSavePersonal('xing')"
                placeholder="Username"
              /></label
            >
            <label class="field-row cv-field"
              >Mastodon Instance <input
                type="text"
                x-model="personal.mastodonInstance"
                @input="autoSavePersonal('mastodonInstance')"
                placeholder="e.g. mastodon.social"
              /></label
            >
            <label class="field-row cv-field"
              >Mastodon Username <input
                type="text"
                x-model="personal.mastodonName"
                @input="autoSavePersonal('mastodonName')"
                placeholder="Username"
              /></label
            >
          </div>

          <!-- Academic -->
          <h2 class="cv-profile-heading">Academic</h2>
          <div class="cv-profile-grid">
            <label class="field-row cv-field"
              >ORCID <input
                type="text"
                x-model="personal.orcid"
                @input="autoSavePersonal('orcid')"
                placeholder="0000-0000-0000-0000"
              /></label
            >
            <label class="field-row cv-field"
              >ResearchGate <input
                type="text"
                x-model="personal.researchgate"
                @input="autoSavePersonal('researchgate')"
                placeholder="Account"
              /></label
            >
            <label class="field-row cv-field"
              >Google Scholar ID <input
                type="text"
                x-model="personal.googlescholarId"
                @input="autoSavePersonal('googlescholarId')"
                placeholder="User ID"
              /></label
            >
            <label class="field-row cv-field"
              >Google Scholar Name <input
                type="text"
                x-model="personal.googlescholarName"
                @input="autoSavePersonal('googlescholarName')"
                placeholder="Display name"
              /></label
            >
            <label class="field-row cv-field"
              >Stack Overflow ID <input
                type="text"
                x-model="personal.stackoverflowId"
                @input="autoSavePersonal('stackoverflowId')"
                placeholder="User ID"
              /></label
            >
            <label class="field-row cv-field"
              >Stack Overflow Name <input
                type="text"
                x-model="personal.stackoverflowName"
                @input="autoSavePersonal('stackoverflowName')"
                placeholder="Display name"
              /></label
            >
            <label class="field-row cv-field"
              >Kaggle <input
                type="text"
                x-model="personal.kaggle"
                @input="autoSavePersonal('kaggle')"
                placeholder="Username"
              /></label
            >
            <label class="field-row cv-field"
              >HackerRank <input
                type="text"
                x-model="personal.hackerrank"
                @input="autoSavePersonal('hackerrank')"
                placeholder="Username"
              /></label
            >
          </div>
        </div>

        <!-- ===== Sections Tab ===== -->
        <div x-show="editorTab === 'sections'" class="cv-tab-content">
          <div class="cv-section-toolbar">
            <button class="btn cv-btn-sm" @click="createNewSection()">+ Add Section</button>
          </div>
          <div id="section-list" class="cv-section-list">
            <template x-for="(sec, i) in docSections" :key="sec.id">
              <div
                class="cv-section"
                :class="{ 'cv-disabled': !sec.enabled }"
                :data-sec-id="sec.id"
              >
                <div class="cv-section-header">
                  <span class="ui-drag-handle" aria-hidden="true"></span>
                  <strong x-text="sec.title"></strong>
                  <label class="cv-section-toggle" title="Include in document">
                    <input
                      type="checkbox"
                      :checked="sec.enabled"
                      @change="toggleSection(i)"
                      :aria-label="'Enable ' + sec.title"
                    />
                  </label>
                  <button
                    class="btn cv-btn-sm"
                    @click="sec._expanded = !sec._expanded; if(sec._expanded) loadSectionData(sec)"
                    x-text="sec._expanded ? 'Collapse' : 'Expand'"></button>
                  <button
                    class="btn cv-btn-xs"
                    @click="renameSection(sec.id)"
                    title="Rename section">Rename</button
                  >
                  <button
                    class="btn cv-btn-xs cv-btn-danger"
                    @click="deleteSection(sec.id)"
                    title="Delete section">&times;</button
                  >
                </div>

                <!-- Expanded editor -->
                <div x-show="sec._expanded && sec.enabled" class="cv-section-body">
                  <template x-if="sec._data">
                    <div>
                      <!-- Inline metrics for this section -->
                      <div class="cv-inline-metrics">
                        <div class="cv-inline-metrics-header">
                          <h2 class="cv-inline-metrics-heading">Variables</h2>
                          <button class="btn cv-btn-xs" @click="addMetricGroup(sec.id)"
                            >+ Group</button
                          >
                        </div>
                        <template
                          x-for="[group, mets] in metricGroupsForSection(sec.id)"
                          :key="group"
                        >
                          <div class="cv-metric-group">
                            <div class="cv-metric-group-header">
                              <span
                                class="cv-metric-group-name"
                                x-text="group"
                                @dblclick="renameMetricGroup(sec.id, group)"
                                title="Double-click to rename"></span>
                              <div class="cv-metric-group-actions">
                                <button class="btn cv-btn-xs" @click="addMetric(sec.id, group)"
                                  >+ Var</button
                                >
                                <button
                                  class="btn cv-btn-xs cv-btn-danger"
                                  @click="removeMetricGroup(sec.id, group)"
                                  title="Remove entire group">x</button
                                >
                              </div>
                            </div>
                            <div class="cv-metrics-list">
                              <template x-for="metric in mets" :key="metric.id">
                                <div class="cv-metric-row">
                                  <div class="cv-metric-row-header">
                                    <span class="cv-metric-cmd" x-text="metric.command"></span>
                                    <button
                                      class="btn cv-btn-xs cv-btn-danger"
                                      @click="removeMetric(metric.id)"
                                      title="Remove variable">&times;</button
                                    >
                                  </div>
                                  <textarea
                                    x-model="metric.value"
                                    :placeholder="metric.label"
                                    @input="autoSaveMetric(metric)"
                                    rows="1"
                                    class="cv-metric-textarea"></textarea>
                                </div>
                              </template>
                            </div>
                          </div>
                        </template>
                        <template x-if="metricsForSection(sec.id).length === 0">
                          <p class="cv-muted">
                            No variables. Click "+ Group" to add a variable group.
                          </p>
                        </template>
                      </div>

                      <!-- cventries editor -->
                      <template x-if="sec._data.type === 'cventries'">
                        <div>
                          <template x-for="entry in sec._data.entries" :key="entry.id">
                            <div class="cv-entry" :class="{ 'cv-dim': !entry.resumeIncluded }">
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.organization || entry.fields.position"
                                ></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input
                                      type="checkbox"
                                      :checked="entry.resumeIncluded"
                                      @change="toggleResumeEntry(entry)"
                                      aria-label="Include entry in resume"
                                    />
                                  </label>
                                  <button
                                    class="btn cv-btn-xs cv-btn-danger"
                                    @click="removeEntry(sec, entry.id)">Remove</button
                                  >
                                </div>
                              </div>
                              <label
                                >Position <input
                                  type="text"
                                  x-model="entry.fields.position"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Organization <input
                                  type="text"
                                  x-model="entry.fields.organization"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Location <input
                                  type="text"
                                  x-model="entry.fields.location"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Date <input
                                  type="text"
                                  x-model="entry.fields.date"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <div
                                class="items-list"
                                :data-entry-id="entry.id"
                                :data-sec-id="sec.id"
                              >
                                <strong>Bullet Points</strong>
                                <template x-for="item in entry.items" :key="item.id">
                                  <div
                                    class="cv-item-row"
                                    :class="{ 'cv-dim': !item.resumeIncluded }"
                                  >
                                    <span class="ui-drag-handle cv-drag-sm" aria-hidden="true"
                                    ></span>
                                    <textarea
                                      x-model="item.content"
                                      rows="2"
                                      @input="autoSaveItem(item)"
                                      :aria-label="'Bullet point'"></textarea>
                                    <label class="cv-item-resume" title="Include in Resume">
                                      <span class="cv-badge-sm">R</span>
                                      <input
                                        type="checkbox"
                                        :checked="item.resumeIncluded"
                                        @change="toggleResumeItem(item)"
                                      />
                                    </label>
                                    <button
                                      class="btn cv-btn-xs cv-btn-danger"
                                      @click="removeItem(entry, item.id)"
                                      aria-label="Remove bullet point">x</button
                                    >
                                  </div>
                                </template>
                                <button class="btn cv-btn-sm" @click="addItem(entry)"
                                  >+ Add Bullet</button
                                >
                              </div>
                            </div>
                          </template>
                          <div class="cv-add-row">
                            <button class="btn" @click="addEntry(sec)">+ Add Entry</button>
                          </div>
                        </div>
                      </template>

                      <!-- cvskills editor -->
                      <template x-if="sec._data.type === 'cvskills'">
                        <div>
                          <template x-for="entry in sec._data.entries" :key="entry.id">
                            <div
                              class="cv-entry cv-entry-compact"
                              :class="{ 'cv-dim': !entry.resumeIncluded }"
                            >
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.category"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input
                                      type="checkbox"
                                      :checked="entry.resumeIncluded"
                                      @change="toggleResumeEntry(entry)"
                                    />
                                  </label>
                                  <button
                                    class="btn cv-btn-xs cv-btn-danger"
                                    @click="removeEntry(sec, entry.id)">Remove</button
                                  >
                                </div>
                              </div>
                              <label
                                >Category <input
                                  type="text"
                                  x-model="entry.fields.category"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Skills <input
                                  type="text"
                                  x-model="entry.fields.skills"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                            </div>
                          </template>
                          <div class="cv-add-row">
                            <button class="btn cv-btn-sm" @click="addEntry(sec)">+ Add Skill</button
                            >
                          </div>
                        </div>
                      </template>

                      <!-- cvhonors editor -->
                      <template x-if="sec._data.type === 'cvhonors'">
                        <div>
                          <template x-for="entry in sec._data.entries" :key="entry.id">
                            <div
                              class="cv-entry cv-entry-compact"
                              :class="{ 'cv-dim': !entry.resumeIncluded }"
                            >
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.award"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input
                                      type="checkbox"
                                      :checked="entry.resumeIncluded"
                                      @change="toggleResumeEntry(entry)"
                                    />
                                  </label>
                                  <button
                                    class="btn cv-btn-xs cv-btn-danger"
                                    @click="removeEntry(sec, entry.id)">Remove</button
                                  >
                                </div>
                              </div>
                              <label
                                >Award <input
                                  type="text"
                                  x-model="entry.fields.award"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Issuer <input
                                  type="text"
                                  x-model="entry.fields.issuer"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Location <input
                                  type="text"
                                  x-model="entry.fields.location"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                              <label
                                >Date <input
                                  type="text"
                                  x-model="entry.fields.date"
                                  @input="autoSaveEntry(entry)"
                                /></label
                              >
                            </div>
                          </template>
                          <div class="cv-add-row">
                            <button class="btn cv-btn-sm" @click="addEntry(sec)">+ Add Honor</button
                            >
                          </div>
                        </div>
                      </template>

                      <!-- cvreferences editor -->
                      <template x-if="sec._data.type === 'cvreferences'">
                        <div>
                          <template x-for="entry in sec._data.entries" :key="entry.id">
                            <div
                              class="cv-entry cv-entry-compact"
                              :class="{ 'cv-dim': !entry.resumeIncluded }"
                            >
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.name"></strong>
                                <div class="cv-entry-actions">
