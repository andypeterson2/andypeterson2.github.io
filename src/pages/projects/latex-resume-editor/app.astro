  <script is:inline>
    // Auto-resize textareas to fit content
    function autoResize(el) {
      el.style.height = 'auto';
      el.style.height = el.scrollHeight + 'px';
    }
    document.addEventListener('input', function (e) {
      if (e.target && e.target.tagName === 'TEXTAREA') {
        autoResize(e.target);
      }
    });
    // Initial resize for all textareas after Alpine renders
    document.addEventListener('alpine:initialized', function () {
      setTimeout(function () {
        document.querySelectorAll('.cv-app textarea').forEach(autoResize);
      }, 200);
    });
    // Also resize on tab switch (content becomes visible)
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.type === 'attributes' && m.attributeName === 'style') {
          var el = m.target;
          if (el.querySelectorAll) {
            el.querySelectorAll('textarea').forEach(autoResize);
          }
        }
      });
    }).observe(document.querySelector('.cv-app') || document.body, {
      attributes: true,
      subtree: true,
      attributeFilter: ['style'],
    });
  </script>
