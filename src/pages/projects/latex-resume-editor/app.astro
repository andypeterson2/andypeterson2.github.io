  <script is:inline>
    var API_BASE = 'http://localhost:3001';
    (function () {
      var _cvWidget = null;

      document.addEventListener('navbar:connect-ready', function (e) {
        if (e.detail.service !== 'cv') return;
        _cvWidget = e.detail.widget;
      });

      document.addEventListener('navbar:connect', function (e) {
        if (e.detail.service !== 'cv') return;
        if (_cvWidget) _cvWidget.setStatus('connecting');
        var url = e.detail.url;
        fetch(url + '/api/health')
          .then(function (r) {
            if (!r.ok) throw new Error('Health check failed');
            return r.json();
          })
          .then(function (data) {
            if (data.status !== 'ok' || data.service !== 'cv')
              throw new Error('Bad health response');
            API_BASE = url;
            var el = document.querySelector('.cv-app');
            if (el && el._x_dataStack) {
              return el._x_dataStack[0].init();
            }
          })
          .then(function () {
            if (_cvWidget) _cvWidget.setStatus('connected');
          })
          .catch(function (err) {
            console.error('CV backend connect failed:', err);
            if (_cvWidget) _cvWidget.setStatus('error');
          });
      });

      document.addEventListener('navbar:disconnect', function (e) {
        if (e.detail.service !== 'cv') return;
        API_BASE = 'http://localhost:3001';
        if (_cvWidget) _cvWidget.setStatus('disconnected');
      });
    })();
  </script>
  <script is:inline src="/cv/app.js"></script>
  <script is:inline>
    // Auto-resize textareas to fit content
    function autoResize(el) {
      el.style.height = 'auto';
      el.style.height = el.scrollHeight + 'px';
    }
    document.addEventListener('input', function (e) {
      if (e.target && e.target.tagName === 'TEXTAREA') {
        autoResize(e.target);
      }
    });
    // Initial resize for all textareas after Alpine renders
    document.addEventListener('alpine:initialized', function () {
      setTimeout(function () {
        document.querySelectorAll('.cv-app textarea').forEach(autoResize);
      }, 200);
    });
    // Also resize on tab switch (content becomes visible)
    new MutationObserver(function (mutations) {
      mutations.forEach(function (m) {
        if (m.type === 'attributes' && m.attributeName === 'style') {
          var el = m.target;
          if (el.querySelectorAll) {
            el.querySelectorAll('textarea').forEach(autoResize);
          }
        }
      });
    }).observe(document.querySelector('.cv-app') || document.body, {
      attributes: true,
      subtree: true,
      attributeFilter: ['style'],
    });
  </script>
</BaseLayout>

