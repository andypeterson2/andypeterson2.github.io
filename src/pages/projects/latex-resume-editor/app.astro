---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="LaTeX Resume Editor"
  breadcrumbs={[
    { label: 'projects', href: '/projects/' },
    { label: 'latex resume editor', href: '/projects/latex-resume-editor/' },
    { label: 'app' },
  ]}
>
  <meta slot="head" name="site-backend" content="cv" data-port="3001" data-label="CV Backend" />

  <script is:inline src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>

  <div class="cv-app" x-data="app()">

    <!-- Modal overlay -->
    <div class="cv-modal-overlay" x-show="modal.open" @click.self="cancelModal()" x-cloak>
      <div class="cv-modal-dialog" role="dialog" aria-modal="true">
        <h3 x-text="modal.title" class="cv-modal-title"></h3>
        <template x-for="(field, fi) in modal.fields" :key="fi">
          <label class="cv-modal-field">
            <span x-text="field.label"></span>
            <input type="text" x-model="field.value" @keydown.enter="submitModal()" :autofocus="fi === 0">
          </label>
        </template>
        <div class="cv-modal-actions">
          <button class="cv-btn" @click="submitModal()">OK</button>
          <button class="cv-btn" @click="cancelModal()">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="cv-toolbar">
      <!-- Left group: person selector -->
      <template x-if="serverConnected">
        <div class="cv-toolbar-group">
          <select class="cv-select" @change="switchPerson(parseInt($event.target.value))" aria-label="Active person">
            <template x-for="p in persons" :key="p.id">
              <option :value="p.id" x-text="p.name" :selected="p.id === activePersonId"></option>
            </template>
          </select>
          <button class="cv-btn cv-btn-sm" @click="createPerson()" title="New person">+</button>
        </div>
      </template>
      <template x-if="!serverConnected">
        <span class="cv-toolbar-label">Jane Doe <span class="cv-hint">(offline)</span></span>
      </template>
      <template x-if="serverConnected && !isJaneDoe">
        <button class="cv-btn cv-btn-primary" @click="save()" :disabled="!dirty">
          Save<span x-show="dirty">*</span>
        </button>
      </template>

      <!-- Center group: doc type selector -->
      <div class="cv-toolbar-group">
        <select class="cv-select" x-model="activeDoc" @change="switchDoc(activeDoc)" aria-label="Document type">
          <option value="cv">CV</option>
          <option value="resume">Resume</option>
          <option value="coverletter">Cover Letter</option>
        </select>
      </div>

      <!-- Right group: import/export + compile -->
      <div class="cv-toolbar-group">
        <button class="cv-btn cv-btn-sm" @click="exportData()" title="Export JSON">&#8593; Export</button>
        <button class="cv-btn cv-btn-sm" @click="importData()" title="Import JSON">&#8595; Import</button>
        <template x-if="serverConnected">
          <button class="cv-btn cv-btn-primary" @click="compile()" :disabled="compiling">
            <span x-show="!compiling">&#9654; Compile</span>
            <span x-show="compiling">Compiling&hellip;</span>
          </button>
        </template>
      </div>
    </div>

    <!-- Status bar -->
    <div class="cv-alert" x-show="statusMsg" x-text="statusMsg" :class="statusType === 'ui-alert-danger' ? 'cv-alert-err' : ''" role="status"></div>

    <!-- Tab bar -->
    <nav class="cv-tabs" role="tablist">
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'profile' }" @click="activeTab = 'profile'" role="tab">Profile</button>
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'sections' }" @click="activeTab = 'sections'" role="tab">Sections</button>
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'coverletter' }" @click="activeTab = 'coverletter'" role="tab">Cover Letter</button>
    </nav>

    <!-- Tab content -->
    <div class="cv-tab-content">

      <!-- PROFILE TAB -->
      <div x-show="activeTab === 'profile'" class="cv-tab-pane">
        <!-- Identity -->
        <h3 class="cv-profile-heading">Identity</h3>
        <div class="cv-profile-grid">
          <label>First Name <input type="text" x-model="personal.firstName" @input="dirty = true"></label>
          <label>Last Name <input type="text" x-model="personal.lastName" @input="dirty = true"></label>
          <label>Position <input type="text" x-model="personal.position" @input="dirty = true"></label>
          <label>Address <input type="text" x-model="personal.address" @input="dirty = true"></label>
          <label>Date of Birth <input type="text" x-model="personal.dateofbirth" @input="dirty = true" placeholder="e.g. January 1, 1990"></label>
          <div class="cv-toggle-row">
            <span>Photo</span>
            <label class="cv-toggle">
              <input type="checkbox" :checked="personal.photoEnabled === '1'" @change="togglePhoto()">
              <span x-text="personal.photoEnabled === '1' ? 'On' : 'Off'"></span>
            </label>
          </div>
          <template x-if="personal.photoEnabled === '1'">
            <label>Photo File <span class="cv-hint">(filename)</span>
              <input type="text" x-model="personal.photoFile" @input="dirty = true" placeholder="e.g. profile">
            </label>
          </template>
          <label class="cv-profile-full">Quote <span class="cv-hint">(optional)</span>
            <input type="text" x-model="personal.quote" @input="dirty = true" placeholder="Leave blank to hide">
          </label>
          <label class="cv-profile-full">Extra Info <span class="cv-hint">(custom text shown in header)</span>
            <input type="text" x-model="personal.extrainfo" @input="dirty = true" placeholder="Leave blank to hide">
          </label>
        </div>

        <!-- Contact -->
        <h3 class="cv-profile-heading">Contact</h3>
        <div class="cv-profile-grid">
          <label>Mobile <input type="text" x-model="personal.mobile" @input="dirty = true"></label>
          <label>Email <input type="text" x-model="personal.email" @input="dirty = true"></label>
          <label>WhatsApp <input type="text" x-model="personal.whatsapp" @input="dirty = true" placeholder="Phone number"></label>
          <label>Skype <input type="text" x-model="personal.skype" @input="dirty = true" placeholder="Username"></label>
          <label>Telegram <input type="text" x-model="personal.telegram" @input="dirty = true" placeholder="Username"></label>
        </div>

        <!-- Web & Code -->
        <h3 class="cv-profile-heading">Web &amp; Code</h3>
        <div class="cv-profile-grid">
          <label>Homepage <input type="text" x-model="personal.homepage" @input="dirty = true" placeholder="yoursite.com"></label>
          <label>GitHub <input type="text" x-model="personal.github" @input="dirty = true"></label>
          <label>LinkedIn <input type="text" x-model="personal.linkedin" @input="dirty = true"></label>
          <label>GitLab <input type="text" x-model="personal.gitlab" @input="dirty = true"></label>
          <label>Bitbucket <input type="text" x-model="personal.bitbucket" @input="dirty = true"></label>
        </div>

        <!-- Social -->
        <h3 class="cv-profile-heading">Social</h3>
        <div class="cv-profile-grid">
          <label>Twitter <input type="text" x-model="personal.twitter" @input="dirty = true" placeholder="Handle"></label>
          <label>X <span class="cv-hint">(if different from Twitter)</span> <input type="text" x-model="personal.x" @input="dirty = true" placeholder="Handle"></label>
          <label>Reddit <input type="text" x-model="personal.reddit" @input="dirty = true" placeholder="Username"></label>
          <label>Medium <input type="text" x-model="personal.medium" @input="dirty = true" placeholder="Username"></label>
          <label>Xing <input type="text" x-model="personal.xing" @input="dirty = true" placeholder="Username"></label>
          <label>Mastodon Instance <input type="text" x-model="personal.mastodonInstance" @input="dirty = true" placeholder="e.g. mastodon.social"></label>
          <label>Mastodon Username <input type="text" x-model="personal.mastodonName" @input="dirty = true" placeholder="Username"></label>
        </div>

        <!-- Academic -->
        <h3 class="cv-profile-heading">Academic</h3>
        <div class="cv-profile-grid">
          <label>ORCID <input type="text" x-model="personal.orcid" @input="dirty = true" placeholder="0000-0000-0000-0000"></label>
          <label>ResearchGate <input type="text" x-model="personal.researchgate" @input="dirty = true" placeholder="Account"></label>
          <label>Google Scholar ID <input type="text" x-model="personal.googlescholarId" @input="dirty = true" placeholder="User ID"></label>
          <label>Google Scholar Name <input type="text" x-model="personal.googlescholarName" @input="dirty = true" placeholder="Display name"></label>
          <label>Stack Overflow ID <input type="text" x-model="personal.stackoverflowId" @input="dirty = true" placeholder="User ID"></label>
          <label>Stack Overflow Name <input type="text" x-model="personal.stackoverflowName" @input="dirty = true" placeholder="Display name"></label>
          <label>Kaggle <input type="text" x-model="personal.kaggle" @input="dirty = true" placeholder="Username"></label>
          <label>HackerRank <input type="text" x-model="personal.hackerrank" @input="dirty = true" placeholder="Username"></label>
        </div>
        <!-- Person management is handled via the toolbar dropdown -->
      </div>

      <!-- SECTIONS TAB -->
      <div x-show="activeTab === 'sections'" class="cv-tab-pane cv-split">
        <!-- Left: Section list -->
        <div class="cv-split-main">
          <!-- Add Section button bar -->
          <div class="cv-section-toolbar" x-show="serverConnected">
            <button class="cv-btn cv-btn-sm" @click="createNewSection()">+ Add Section</button>
          </div>

          <div id="section-list" class="cv-section-list">
            <template x-for="(sec, i) in docSections" :key="sec.id">
              <div class="cv-section" :class="{ 'cv-disabled': !sec.enabled }" :data-sec-id="sec.id">
                <div class="cv-section-header">
                  <span class="ui-drag-handle" aria-hidden="true">&#x2630;</span>
                  <strong x-text="sec.title" @dblclick="renameSection(sec.id)" title="Double-click to rename" style="cursor:pointer"></strong>
                  <label class="cv-section-toggle" title="Include in document">
                    <input type="checkbox" :checked="sec.enabled" @change="toggleSection(i)" :aria-label="'Enable ' + sec.title">
                  </label>
                  <button class="cv-btn cv-btn-sm" @click="toggleSectionExpand(sec)"
                    x-text="sec._expanded ? 'Collapse' : 'Expand'"></button>
                  <template x-if="serverConnected">
                    <button class="cv-btn cv-btn-xs cv-btn-danger" @click="deleteSection(sec.id)" title="Delete section">&#x2715;</button>
                  </template>
                </div>

                <!-- Expanded section content -->
                <div x-show="sec._expanded && sec.enabled" class="cv-section-body">
                      <!-- cventries -->
                      <template x-if="sec.type === 'cventries'">
                        <div>
                          <template x-for="entry in sec.entries" :key="entry.id">
                            <div class="cv-entry" :class="{ 'cv-dim': !entry.resumeIncluded }">
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.organization || entry.fields.position"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                  </label>
                                  <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                                </div>
                              </div>
                              <label>Position <input type="text" x-model="entry.fields.position" @input="dirty = true"></label>
                              <label>Organization <input type="text" x-model="entry.fields.organization" @input="dirty = true"></label>
                              <label>Location <input type="text" x-model="entry.fields.location" @input="dirty = true"></label>
                              <label>Date <input type="text" x-model="entry.fields.date" @input="dirty = true"></label>
                              <div class="items-list" :data-entry-id="entry.id" :data-sec-id="sec.id">
                                <strong>Bullet Points</strong>
                                <template x-for="item in entry.items" :key="item.id">
                                  <div class="cv-item-row" :class="{ 'cv-dim': !item.resumeIncluded }">
                                    <span class="ui-drag-handle cv-drag-sm" aria-hidden="true">&#x2630;</span>
                                    <textarea x-model="item.content" rows="2" @input="dirty = true" aria-label="Bullet point"></textarea>
                                    <label class="cv-item-resume" title="Include in Resume">
                                      <span class="cv-badge-sm">R</span>
                                      <input type="checkbox" :checked="item.resumeIncluded" @change="toggleResumeItem(item)">
                                    </label>
                                    <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeItem(entry, item.id)">x</button>
                                  </div>
                                </template>
                                <button class="cv-btn cv-btn-sm" @click="addItem(entry)">+ Add Bullet</button>
                              </div>
                            </div>
                          </template>
                          <div class="cv-add-row"><button class="cv-btn" @click="addEntry(sec)">+ Add Entry</button></div>
                        </div>
                      </template>

                      <!-- cvskills -->
                      <template x-if="sec.type === 'cvskills'">
                        <div>
                          <template x-for="entry in sec.entries" :key="entry.id">
                            <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.category"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                  </label>
                                  <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                                </div>
                              </div>
                              <label>Category <input type="text" x-model="entry.fields.category" @input="dirty = true"></label>
                              <label>Skills <input type="text" x-model="entry.fields.skills" @input="dirty = true"></label>
                            </div>
                          </template>
                          <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Skill</button></div>
                        </div>
                      </template>

                      <!-- cvhonors -->
                      <template x-if="sec.type === 'cvhonors'">
                        <div>
                          <template x-for="entry in sec.entries" :key="entry.id">
                            <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.award"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                  </label>
                                  <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                                </div>
                              </div>
                              <label>Award <input type="text" x-model="entry.fields.award" @input="dirty = true"></label>
                              <label>Issuer <input type="text" x-model="entry.fields.issuer" @input="dirty = true"></label>
                              <label>Location <input type="text" x-model="entry.fields.location" @input="dirty = true"></label>
                              <label>Date <input type="text" x-model="entry.fields.date" @input="dirty = true"></label>
                            </div>
                          </template>
                          <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Honor</button></div>
                        </div>
                      </template>

                      <!-- cvreferences -->
                      <template x-if="sec.type === 'cvreferences'">
                        <div>
                          <template x-for="entry in sec.entries" :key="entry.id">
                            <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                              <div class="cv-entry-header">
                                <strong x-text="entry.fields.name"></strong>
                                <div class="cv-entry-actions">
                                  <label class="cv-resume-badge" title="Include in Resume">
                                    <span class="cv-badge">R</span>
                                    <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                  </label>
                                  <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                                </div>
                              </div>
                              <label>Name <input type="text" x-model="entry.fields.name" @input="dirty = true"></label>
                              <label>Relation <input type="text" x-model="entry.fields.relation" @input="dirty = true"></label>
                              <label>Phone <input type="text" x-model="entry.fields.phone" @input="dirty = true"></label>
                              <label>Email <input type="text" x-model="entry.fields.email" @input="dirty = true"></label>
                            </div>
                          </template>
                          <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Reference</button></div>
                        </div>
                      </template>

                      <!-- cvparagraph -->
                      <template x-if="sec.type === 'cvparagraph'">
                        <div>
                          <template x-if="sec.entries.length > 0">
                            <div>
                              <div class="cv-para-label">CV Text</div>
                              <textarea x-model="sec.entries[0].fields.text" rows="4" class="cv-full-textarea" @input="dirty = true" aria-label="CV summary text"></textarea>
                              <div class="cv-para-label">Resume Text <span class="cv-muted">(shorter version)</span></div>
                              <textarea x-model="sec.resumeParagraphText" @input="dirty = true" rows="3" class="cv-full-textarea" aria-label="Resume summary text"></textarea>
                            </div>
                          </template>
                        </div>
                      </template>
                </div>
              </div>
            </template>
          </div>
        </div>

        <!-- Right: Sidebar with PDF/Variables toggle -->
        <aside class="cv-split-sidebar">
          <div class="cv-sidebar-tabs">
            <button class="cv-sidebar-tab" :class="{ 'cv-sidebar-tab-active': sidebarMode === 'pdf' }" @click="sidebarMode = 'pdf'">Preview</button>
            <button class="cv-sidebar-tab" :class="{ 'cv-sidebar-tab-active': sidebarMode === 'variables' }" @click="sidebarMode = 'variables'">Variables</button>
          </div>

          <!-- PDF Preview -->
          <div x-show="sidebarMode === 'pdf'" class="cv-sidebar-pdf">
            <div class="cv-pdf-controls">
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = Math.max(50, pdfZoom - 25)" title="Zoom out">&minus;</button>
              <span class="cv-pdf-zoom-label" x-text="pdfZoom + '%'"></span>
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = Math.min(300, pdfZoom + 25)" title="Zoom in">+</button>
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = 100" title="Reset zoom">Fit</button>
              <template x-if="pdfUrl">
                <a :href="pdfUrl" target="_blank" class="cv-btn cv-btn-xs" title="Open in new tab">&#8599; Pop Out</a>
              </template>
            </div>
            <div class="cv-pdf-scroll">
              <template x-if="pdfUrl">
                <iframe :src="pdfUrl" class="cv-pdf-iframe" :style="'width:' + pdfZoom + '%; height:' + pdfZoom + '%'" title="PDF preview"></iframe>
              </template>
              <template x-if="!pdfUrl">
                <p class="cv-muted" style="padding:12px">Compile to see a preview.</p>
              </template>
            </div>
          </div>

          <!-- Variables -->
          <div x-show="sidebarMode === 'variables'" class="cv-sidebar-content">
            <template x-if="expandedSectionId">
              <div>
                <div class="cv-metrics-header">
                  <button class="cv-btn cv-btn-xs" @click="addMetricGroup(expandedSectionId)">+ Group</button>
                </div>
                <template x-for="[group, mets] in metricGroupsForSection(expandedSectionId)" :key="group">
                  <div class="cv-metric-group">
                    <div class="cv-metric-group-header">
                      <span class="cv-metric-group-name" x-text="group" @dblclick="renameMetricGroup(expandedSectionId, group)" title="Double-click to rename"></span>
                      <div class="cv-metric-group-actions">
                        <button class="cv-btn cv-btn-xs" @click="addMetric(expandedSectionId, group)">+ Var</button>
                        <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeMetricGroup(expandedSectionId, group)" title="Remove group">x</button>
                      </div>
                    </div>
                    <div class="cv-metrics-grid">
                      <template x-for="metric in mets" :key="metric.id">
                        <div class="cv-metric-cell">
                          <div class="cv-metric-cell-header">
                            <span class="cv-metric-cmd" x-text="metric.command"></span>
                            <button class="cv-btn-remove" @click="removeMetric(metric.id)" title="Remove">&times;</button>
                          </div>
                          <input type="text" x-model="metric.value" :placeholder="metric.label" @input="dirty = true">
                        </div>
                      </template>
                    </div>
                  </div>
                </template>
                <template x-if="metricsForSection(expandedSectionId).length === 0">
                  <p class="cv-muted" style="padding:8px 12px">No variables. Click "+ Group" to add.</p>
                </template>
              </div>
            </template>
            <template x-if="!expandedSectionId">
              <p class="cv-muted" style="padding:12px">Expand a section to see its variables.</p>
            </template>
          </div>
        </aside>
      </div>

      <!-- COVER LETTER TAB -->
      <div x-show="activeTab === 'coverletter'" class="cv-tab-pane cv-split">
        <!-- Left: Cover letter content -->
        <div class="cv-split-main">
          <div class="cv-coverletter">
            <div class="cv-cl-heading">Recipient</div>
            <label>Name <input type="text" x-model="coverletter.settings.recipientName" @input="dirty = true"></label>
            <label>Address <textarea x-model="coverletter.settings.recipientAddress" @input="dirty = true" rows="3"></textarea></label>

            <div class="cv-cl-heading">Letter Details</div>
            <label>Title <input type="text" x-model="coverletter.settings.title" @input="dirty = true"></label>
            <label>Opening <input type="text" x-model="coverletter.settings.opening" @input="dirty = true"></label>
            <label>Closing <input type="text" x-model="coverletter.settings.closing" @input="dirty = true"></label>
            <label>Enclosure Label <input type="text" x-model="coverletter.settings.enclosureLabel" @input="dirty = true"></label>
            <label>Enclosure Content <input type="text" x-model="coverletter.settings.enclosureContent" @input="dirty = true"></label>

            <div class="cv-cl-heading">Sections</div>
            <template x-for="sec in coverletter.sections" :key="sec.id">
              <div class="cv-entry">
                <label>Title <input type="text" x-model="sec.title" @input="dirty = true"></label>
                <label>Body <textarea x-model="sec.body" @input="dirty = true" rows="6" class="cv-full-textarea"></textarea></label>
                <div class="cv-add-row"><button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeCoverletterSection(sec.id)">Remove Section</button></div>
              </div>
            </template>
            <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addCoverletterSection()">+ Add Section</button></div>
          </div>
        </div>

        <!-- Right: Sidebar with PDF/Variables toggle -->
        <aside class="cv-split-sidebar">
          <div class="cv-sidebar-tabs">
            <button class="cv-sidebar-tab" :class="{ 'cv-sidebar-tab-active': sidebarMode === 'pdf' }" @click="sidebarMode = 'pdf'">Preview</button>
            <button class="cv-sidebar-tab" :class="{ 'cv-sidebar-tab-active': sidebarMode === 'variables' }" @click="sidebarMode = 'variables'">Variables</button>
          </div>

          <!-- PDF Preview -->
          <div x-show="sidebarMode === 'pdf'" class="cv-sidebar-pdf">
            <div class="cv-pdf-controls">
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = Math.max(50, pdfZoom - 25)" title="Zoom out">&minus;</button>
              <span class="cv-pdf-zoom-label" x-text="pdfZoom + '%'"></span>
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = Math.min(300, pdfZoom + 25)" title="Zoom in">+</button>
              <button class="cv-btn cv-btn-xs" @click="pdfZoom = 100" title="Reset zoom">Fit</button>
              <template x-if="pdfUrl">
                <a :href="pdfUrl" target="_blank" class="cv-btn cv-btn-xs" title="Open in new tab">&#8599; Pop Out</a>
              </template>
            </div>
            <div class="cv-pdf-scroll">
              <template x-if="pdfUrl">
