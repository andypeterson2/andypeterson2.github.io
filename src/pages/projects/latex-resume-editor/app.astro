---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="LaTeX Resume Editor"
  breadcrumbs={[
    { label: 'projects', href: '/projects/' },
    { label: 'latex resume editor', href: '/projects/latex-resume-editor/' },
    { label: 'app' },
  ]}
>
  <meta slot="head" name="site-backend" content="cv" data-port="3001" data-label="CV Backend" />

  <script is:inline src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
  <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>

  <div class="cv-app" x-data="app()">

    <!-- Modal overlay -->
    <div class="cv-modal-overlay" x-show="modal.open" @click.self="cancelModal()" x-cloak>
      <div class="cv-modal-dialog" role="dialog" aria-modal="true">
        <h3 x-text="modal.title" class="cv-modal-title"></h3>
        <template x-for="(field, fi) in modal.fields" :key="fi">
          <label class="cv-modal-field">
            <span x-text="field.label"></span>
            <input type="text" x-model="field.value" @keydown.enter="submitModal()" :autofocus="fi === 0">
          </label>
        </template>
        <div class="cv-modal-actions">
          <button class="cv-btn" @click="submitModal()">OK</button>
          <button class="cv-btn" @click="cancelModal()">Cancel</button>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="cv-toolbar">
      <!-- Left group: person selector -->
      <template x-if="serverConnected">
        <div class="cv-toolbar-group">
          <select class="cv-select" x-model="activePersonId" @change="switchPerson(parseInt($event.target.value))" aria-label="Active person">
            <template x-for="p in persons" :key="p.id">
              <option :value="p.id" x-text="p.name" :selected="p.id === activePersonId"></option>
            </template>
          </select>
          <button class="cv-btn cv-btn-sm" @click="createPerson()" title="New person">+</button>
        </div>
      </template>
      <template x-if="!serverConnected">
        <span class="cv-toolbar-label">Jane Doe <span class="cv-hint">(offline)</span></span>
      </template>

      <!-- Center group: doc type selector + compile -->
      <div class="cv-toolbar-group">
        <select class="cv-select" x-model="activeDoc" @change="switchDoc(activeDoc)" aria-label="Document type">
          <option value="cv">CV</option>
          <option value="resume">Resume</option>
          <option value="coverletter">Cover Letter</option>
        </select>
        <template x-if="serverConnected">
          <button class="cv-btn cv-btn-primary" @click="compile()" :disabled="compiling">
            <span x-show="!compiling">&#9654; Compile</span>
            <span x-show="compiling">Compiling&hellip;</span>
          </button>
        </template>
      </div>

      <!-- Right group: import/export -->
      <div class="cv-toolbar-group">
        <button class="cv-btn cv-btn-sm" @click="exportData()" title="Export JSON">&#8595; Export</button>
        <button class="cv-btn cv-btn-sm" @click="importData()" title="Import JSON">&#8593; Import</button>
      </div>
    </div>

    <!-- Status bar -->
    <div class="cv-alert" x-show="statusMsg" x-text="statusMsg" :class="statusType === 'ui-alert-danger' ? 'cv-alert-err' : ''" role="status"></div>

    <!-- Tab bar -->
    <nav class="cv-tabs" role="tablist">
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'profile' }" @click="activeTab = 'profile'" role="tab">Profile</button>
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'sections' }" @click="activeTab = 'sections'" role="tab">Sections</button>
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'coverletter' }" @click="activeTab = 'coverletter'" role="tab">Cover Letter</button>
      <button class="cv-tab" :class="{ 'cv-tab-active': activeTab === 'variables' }" @click="activeTab = 'variables'" role="tab">Variables</button>
    </nav>

    <!-- Tab content -->
    <div class="cv-tab-content">

      <!-- PROFILE TAB -->
      <div x-show="activeTab === 'profile'" class="cv-tab-pane">
        <div class="cv-profile-grid">
          <label>First Name <input type="text" x-model="personal.firstName" @input="autoSavePersonal('firstName')"></label>
          <label>Last Name <input type="text" x-model="personal.lastName" @input="autoSavePersonal('lastName')"></label>
          <label>Position <input type="text" x-model="personal.position" @input="autoSavePersonal('position')"></label>
          <label>Address <input type="text" x-model="personal.address" @input="autoSavePersonal('address')"></label>
          <label>Mobile <input type="text" x-model="personal.mobile" @input="autoSavePersonal('mobile')"></label>
          <label>Email <input type="text" x-model="personal.email" @input="autoSavePersonal('email')"></label>
          <label>GitHub <input type="text" x-model="personal.github" @input="autoSavePersonal('github')"></label>
          <label>LinkedIn <input type="text" x-model="personal.linkedin" @input="autoSavePersonal('linkedin')"></label>
          <label class="cv-profile-full">Quote <span class="cv-hint">(optional)</span>
            <input type="text" x-model="personal.quote" @input="autoSavePersonal('quote')" placeholder="Leave blank to hide">
          </label>
          <div class="cv-toggle-row">
            <span>Photo</span>
            <label class="cv-toggle">
              <input type="checkbox" :checked="personal.photoEnabled === '1'" @change="togglePhoto()">
              <span x-text="personal.photoEnabled === '1' ? 'On' : 'Off'"></span>
            </label>
          </div>
          <template x-if="personal.photoEnabled === '1'">
            <label>Photo File <span class="cv-hint">(filename)</span>
              <input type="text" x-model="personal.photoFile" @input="autoSavePersonal('photoFile')" placeholder="e.g. profile">
            </label>
          </template>
        </div>
        <!-- Person management when connected -->
        <template x-if="serverConnected && persons.length > 0">
          <div class="cv-person-manage">
            <h3>People</h3>
            <template x-for="p in persons" :key="p.id">
              <div class="cv-person-row">
                <span x-text="p.name" :class="{ 'cv-bold': p.id === activePersonId }"></span>
                <div class="cv-person-actions">
                  <button class="cv-btn cv-btn-xs" @click="renamePerson(p.id)">Rename</button>
                  <template x-if="p.id !== activePersonId">
                    <button class="cv-btn cv-btn-xs cv-btn-danger" @click="deletePerson(p.id)">Delete</button>
                  </template>
                </div>
              </div>
            </template>
          </div>
        </template>
      </div>

      <!-- SECTIONS TAB -->
      <div x-show="activeTab === 'sections'" class="cv-tab-pane">
        <div id="section-list" class="cv-section-list">
          <template x-for="(sec, i) in docSections" :key="sec.id">
            <div class="cv-section" :class="{ 'cv-disabled': !sec.enabled }" :data-sec-id="sec.id">
              <div class="cv-section-header">
                <span class="ui-drag-handle" aria-hidden="true">&#x2630;</span>
                <strong x-text="sec.title"></strong>
                <label class="cv-section-toggle" title="Include in document">
                  <input type="checkbox" :checked="sec.enabled" @change="toggleSection(i)" :aria-label="'Enable ' + sec.title">
                </label>
                <button class="cv-btn cv-btn-sm" @click="sec._expanded = !sec._expanded; if(sec._expanded) loadSectionData(sec)"
                  x-text="sec._expanded ? 'Collapse' : 'Expand'"></button>
              </div>

              <!-- Expanded editor -->
              <div x-show="sec._expanded && sec.enabled" class="cv-section-body">
                <template x-if="sec._data">
                  <div>
                    <!-- cventries -->
                    <template x-if="sec._data.type === 'cventries'">
                      <div>
                        <template x-for="entry in sec._data.entries" :key="entry.id">
                          <div class="cv-entry" :class="{ 'cv-dim': !entry.resumeIncluded }">
                            <div class="cv-entry-header">
                              <strong x-text="entry.fields.organization || entry.fields.position"></strong>
                              <div class="cv-entry-actions">
                                <label class="cv-resume-badge" title="Include in Resume">
                                  <span class="cv-badge">R</span>
                                  <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                </label>
                                <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                              </div>
                            </div>
                            <label>Position <input type="text" x-model="entry.fields.position" @input="autoSaveEntry(entry)"></label>
                            <label>Organization <input type="text" x-model="entry.fields.organization" @input="autoSaveEntry(entry)"></label>
                            <label>Location <input type="text" x-model="entry.fields.location" @input="autoSaveEntry(entry)"></label>
                            <label>Date <input type="text" x-model="entry.fields.date" @input="autoSaveEntry(entry)"></label>
                            <div class="items-list" :data-entry-id="entry.id" :data-sec-id="sec.id">
                              <strong>Bullet Points</strong>
                              <template x-for="item in entry.items" :key="item.id">
                                <div class="cv-item-row" :class="{ 'cv-dim': !item.resumeIncluded }">
                                  <span class="ui-drag-handle cv-drag-sm" aria-hidden="true">&#x2630;</span>
                                  <textarea x-model="item.content" rows="2" @input="autoSaveItem(item)" aria-label="Bullet point"></textarea>
                                  <label class="cv-item-resume" title="Include in Resume">
                                    <span class="cv-badge-sm">R</span>
                                    <input type="checkbox" :checked="item.resumeIncluded" @change="toggleResumeItem(item)">
                                  </label>
                                  <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeItem(entry, item.id)">x</button>
                                </div>
                              </template>
                              <button class="cv-btn cv-btn-sm" @click="addItem(entry)">+ Add Bullet</button>
                            </div>
                          </div>
                        </template>
                        <div class="cv-add-row"><button class="cv-btn" @click="addEntry(sec)">+ Add Entry</button></div>
                      </div>
                    </template>

                    <!-- cvskills -->
                    <template x-if="sec._data.type === 'cvskills'">
                      <div>
                        <template x-for="entry in sec._data.entries" :key="entry.id">
                          <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                            <div class="cv-entry-header">
                              <strong x-text="entry.fields.category"></strong>
                              <div class="cv-entry-actions">
                                <label class="cv-resume-badge" title="Include in Resume">
                                  <span class="cv-badge">R</span>
                                  <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                </label>
                                <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                              </div>
                            </div>
                            <label>Category <input type="text" x-model="entry.fields.category" @input="autoSaveEntry(entry)"></label>
                            <label>Skills <input type="text" x-model="entry.fields.skills" @input="autoSaveEntry(entry)"></label>
                          </div>
                        </template>
                        <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Skill</button></div>
                      </div>
                    </template>

                    <!-- cvhonors -->
                    <template x-if="sec._data.type === 'cvhonors'">
                      <div>
                        <template x-for="entry in sec._data.entries" :key="entry.id">
                          <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                            <div class="cv-entry-header">
                              <strong x-text="entry.fields.award"></strong>
                              <div class="cv-entry-actions">
                                <label class="cv-resume-badge" title="Include in Resume">
                                  <span class="cv-badge">R</span>
                                  <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                </label>
                                <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                              </div>
                            </div>
                            <label>Award <input type="text" x-model="entry.fields.award" @input="autoSaveEntry(entry)"></label>
                            <label>Issuer <input type="text" x-model="entry.fields.issuer" @input="autoSaveEntry(entry)"></label>
                            <label>Location <input type="text" x-model="entry.fields.location" @input="autoSaveEntry(entry)"></label>
                            <label>Date <input type="text" x-model="entry.fields.date" @input="autoSaveEntry(entry)"></label>
                          </div>
                        </template>
                        <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Honor</button></div>
                      </div>
                    </template>

                    <!-- cvreferences -->
                    <template x-if="sec._data.type === 'cvreferences'">
                      <div>
                        <template x-for="entry in sec._data.entries" :key="entry.id">
                          <div class="cv-entry cv-entry-compact" :class="{ 'cv-dim': !entry.resumeIncluded }">
                            <div class="cv-entry-header">
                              <strong x-text="entry.fields.name"></strong>
                              <div class="cv-entry-actions">
                                <label class="cv-resume-badge" title="Include in Resume">
                                  <span class="cv-badge">R</span>
                                  <input type="checkbox" :checked="entry.resumeIncluded" @change="toggleResumeEntry(entry)">
                                </label>
                                <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeEntry(sec, entry.id)">Remove</button>
                              </div>
                            </div>
                            <label>Name <input type="text" x-model="entry.fields.name" @input="autoSaveEntry(entry)"></label>
                            <label>Relation <input type="text" x-model="entry.fields.relation" @input="autoSaveEntry(entry)"></label>
                            <label>Phone <input type="text" x-model="entry.fields.phone" @input="autoSaveEntry(entry)"></label>
                            <label>Email <input type="text" x-model="entry.fields.email" @input="autoSaveEntry(entry)"></label>
                          </div>
                        </template>
                        <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addEntry(sec)">+ Add Reference</button></div>
                      </div>
                    </template>

                    <!-- cvparagraph -->
                    <template x-if="sec._data.type === 'cvparagraph'">
                      <div>
                        <template x-if="sec._data.entries.length > 0">
                          <div>
                            <div class="cv-para-label">CV Text</div>
                            <textarea x-model="sec._data.entries[0].fields.text" rows="4" class="cv-full-textarea" @input="autoSaveParagraph(sec)" aria-label="CV summary text"></textarea>
                            <div class="cv-para-label">Resume Text <span class="cv-muted">(shorter version)</span></div>
                            <textarea x-model="sec.resumeParagraphText" @input="autoSaveResumeParagraphText(sec)" rows="3" class="cv-full-textarea" aria-label="Resume summary text"></textarea>
                          </div>
                        </template>
                      </div>
                    </template>
                  </div>
                </template>
                <template x-if="!sec._data">
                  <p class="cv-muted">Loading&hellip;</p>
                </template>
              </div>
            </div>
          </template>
        </div>
      </div>

      <!-- COVER LETTER TAB -->
      <div x-show="activeTab === 'coverletter'" class="cv-tab-pane">
        <div class="cv-coverletter">
          <div class="cv-cl-heading">Recipient</div>
          <label>Name <input type="text" x-model="coverletter.settings.recipientName" @input="autoSaveCoverletterSetting('recipientName')"></label>
          <label>Address <textarea x-model="coverletter.settings.recipientAddress" @input="autoSaveCoverletterSetting('recipientAddress')" rows="3"></textarea></label>

          <div class="cv-cl-heading">Letter Details</div>
          <label>Title <input type="text" x-model="coverletter.settings.title" @input="autoSaveCoverletterSetting('title')"></label>
          <label>Opening <input type="text" x-model="coverletter.settings.opening" @input="autoSaveCoverletterSetting('opening')"></label>
          <label>Closing <input type="text" x-model="coverletter.settings.closing" @input="autoSaveCoverletterSetting('closing')"></label>
          <label>Enclosure Label <input type="text" x-model="coverletter.settings.enclosureLabel" @input="autoSaveCoverletterSetting('enclosureLabel')"></label>
          <label>Enclosure Content <input type="text" x-model="coverletter.settings.enclosureContent" @input="autoSaveCoverletterSetting('enclosureContent')"></label>

          <div class="cv-cl-heading">Sections</div>
          <template x-for="sec in coverletter.sections" :key="sec.id">
            <div class="cv-entry">
              <label>Title <input type="text" x-model="sec.title" @input="autoSaveCoverletterSection(sec)"></label>
              <label>Body <textarea x-model="sec.body" @input="autoSaveCoverletterSection(sec)" rows="6" class="cv-full-textarea"></textarea></label>
              <div class="cv-add-row"><button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeCoverletterSection(sec.id)">Remove Section</button></div>
            </div>
          </template>
          <div class="cv-add-row"><button class="cv-btn cv-btn-sm" @click="addCoverletterSection()">+ Add Section</button></div>
        </div>
      </div>

      <!-- VARIABLES TAB -->
      <div x-show="activeTab === 'variables'" class="cv-tab-pane">
        <template x-for="sec in sections" :key="sec.id">
          <div class="cv-metrics-section">
            <h3 x-text="sec.title" class="cv-metrics-section-title"></h3>
            <div class="cv-metrics-header">
              <button class="cv-btn cv-btn-xs" @click="addMetricGroup(sec.id)">+ Group</button>
            </div>
            <template x-for="[group, mets] in metricGroupsForSection(sec.id)" :key="group">
              <div class="cv-metric-group">
                <div class="cv-metric-group-header">
                  <span class="cv-metric-group-name" x-text="group" @dblclick="renameMetricGroup(sec.id, group)" title="Double-click to rename"></span>
                  <div class="cv-metric-group-actions">
                    <button class="cv-btn cv-btn-xs" @click="addMetric(sec.id, group)">+ Var</button>
                    <button class="cv-btn cv-btn-xs cv-btn-danger" @click="removeMetricGroup(sec.id, group)" title="Remove group">x</button>
                  </div>
                </div>
                <div class="cv-metrics-grid">
                  <template x-for="metric in mets" :key="metric.id">
                    <div class="cv-metric-cell">
                      <div class="cv-metric-cell-header">
                        <span class="cv-metric-cmd" x-text="metric.command"></span>
                        <button class="cv-btn-remove" @click="removeMetric(metric.id)" title="Remove">&times;</button>
                      </div>
                      <input type="text" x-model="metric.value" :placeholder="metric.label" @input="autoSaveMetric(metric)">
                    </div>
                  </template>
                </div>
              </div>
            </template>
            <template x-if="metricsForSection(sec.id).length === 0">
              <p class="cv-muted">No variables for this section.</p>
            </template>
          </div>
        </template>
        <template x-if="sections.length === 0">
          <p class="cv-muted">No sections yet.</p>
        </template>
      </div>

    </div>
  </div>

  <script is:inline>
    var API_BASE = "http://localhost:3001";
    (function () {
      var _cvWidget = null;

      function connectToBackend(url) {
        if (_cvWidget) _cvWidget.setStatus("connecting");
        return fetch(url + "/api/health")
          .then(function (r) {
            if (!r.ok) throw new Error("Health check returned " + r.status);
            return r.json();
          })
          .then(function (data) {
            if (data.status !== "ok" || data.service !== "cv") {
              throw new Error("Unexpected health response");
            }
            API_BASE = url;
            var el = document.querySelector(".cv-app");
            if (el && el._x_dataStack) {
              return el._x_dataStack[0].init();
            }
          })
          .then(function () {
            if (_cvWidget) _cvWidget.setStatus("connected");
          });
      }

      document.addEventListener("navbar:connect-ready", function (e) {
        if (e.detail.service !== "cv") return;
        _cvWidget = e.detail.widget;
        connectToBackend(API_BASE).catch(function () {
          if (_cvWidget) _cvWidget.setStatus("disconnected");
          // Still init in offline mode
          var el = document.querySelector(".cv-app");
          if (el && el._x_dataStack) {
            el._x_dataStack[0].init();
          }
        });
      });

      document.addEventListener("navbar:connect", function (e) {
        if (e.detail.service !== "cv") return;
        connectToBackend(e.detail.url).catch(function (err) {
          console.error("CV backend connect failed:", err);
          if (_cvWidget) _cvWidget.setStatus("error");
        });
      });

      document.addEventListener("navbar:disconnect", function (e) {
        if (e.detail.service !== "cv") return;
        API_BASE = "http://localhost:3001";
        if (_cvWidget) _cvWidget.setStatus("disconnected");
      });
    })();
  </script>
  <script is:inline src="/cv/app.js"></script>
</BaseLayout>

<style>
  /* ── Override site-pane for full-height app layout ── */
  :global(.site-pane:has(.cv-app)) {
    padding: 0 !important;
    overflow: hidden !important;
  }

  [x-cloak] { display: none !important; }

  /* ── App container ── */
  :global(.cv-app) {
    display: flex;
    flex-direction: column;
    height: 100%;
    font-family: var(--font-ui);
    font-size: 13px;
  }

  /* ── Toolbar ── */
  :global(.cv-toolbar) {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 6px 12px;
    border-bottom: 2px solid #000;
    background: #eee;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  :global(.cv-toolbar-group) {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  :global(.cv-toolbar-label) {
    font-size: 13px;
    font-weight: 700;
  }

  /* ── Selects ── */
  :global(.cv-select) {
    padding: 4px 8px;
    border: 2px solid #000;
    background: #fff;
    font-family: var(--font-ui);
    font-size: 13px;
    cursor: pointer;
  }

  :global(.cv-select:focus) {
    outline: 2px solid #06c;
    outline-offset: -2px;
  }

  /* ── Buttons ── */
  :global(.cv-btn) {
    background: #fff;
    border: none;
    border-right: 2px solid #000;
    font-family: var(--font-ui);
    font-size: 13px;
    padding: 6px 14px;
    cursor: pointer;
    user-select: none;
  }

  :global(.cv-btn:hover) {
    background: #000;
    color: #fff;
  }

  :global(.cv-btn:disabled) {
    opacity: 0.4;
    cursor: default;
  }

  :global(.cv-btn:disabled:hover) {
    background: #fff;
    color: #000;
  }

  :global(.cv-btn-primary) {
    background: #000;
    color: #fff;
    font-weight: 700;
  }

  :global(.cv-btn-primary:hover) {
    background: #333;
  }

  :global(.cv-btn-sm) {
    font-size: 12px;
    padding: 4px 10px;
    border: 2px solid #000;
    border-right-width: 2px;
    background: #fff;
    color: #000;
    font-family: var(--font-ui);
    cursor: pointer;
  }

  :global(.cv-btn-sm:hover) {
    background: #000;
    color: #fff;
  }

  :global(.cv-btn-xs) {
    font-size: 11px;
    padding: 2px 8px;
    border: 1px solid #000;
    background: #fff;
    color: #000;
    font-family: var(--font-ui);
    cursor: pointer;
  }

  :global(.cv-btn-xs:hover) {
    background: #000;
    color: #fff;
  }

  :global(.cv-btn-danger) {
    color: #c00 !important;
    border-color: #c00 !important;
  }

  :global(.cv-btn-danger:hover) {
    background: #c00 !important;
    color: #fff !important;
  }

  :global(.cv-btn-remove) {
    background: none;
    border: none;
    color: #999;
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
    padding: 0 2px;
  }

  :global(.cv-btn-remove:hover) {
    color: #c00;
  }

  /* ── Tabs ── */
  :global(.cv-tabs) {
    display: flex;
    border-bottom: 2px solid #000;
