              </template>
              <template x-if="!pdfUrl">
                <p class="cv-muted" style="padding:12px">Compile to see a preview.</p>
              </template>
            </div>
          </div>

          <!-- Variables reference -->
          <div x-show="sidebarMode === 'variables'" class="cv-sidebar-content">
            <template x-for="sec in sections" :key="sec.id">
              <div class="cv-metrics-section-compact">
                <div class="cv-metrics-section-label" x-text="sec.title"></div>
                <template x-for="metric in metricsForSection(sec.id)" :key="metric.id">
                  <div class="cv-metric-ref">
                    <code class="cv-metric-cmd-sm" x-text="'\\' + metric.command"></code>
                    <span class="cv-metric-val-sm" x-text="metric.value || '(empty)'" :class="{ 'cv-dim': !metric.value }"></span>
                  </div>
                </template>
                <template x-if="metricsForSection(sec.id).length === 0">
                  <span class="cv-muted" style="font-size:10px;padding:0 8px">No variables</span>
