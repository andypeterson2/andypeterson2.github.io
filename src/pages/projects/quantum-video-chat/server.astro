---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Video Chat Server"
  breadcrumbs={[
    { label: 'projects', href: '/projects/' },
    { label: 'quantum video chat', href: '/projects/quantum-video-chat/' },
    { label: 'server' },
  ]}
>
  <meta
    slot="head"
    name="site-backend"
    content="qvc-server"
    data-port="5050"
    data-label="Signaling"
  />
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <div id="dashboard">
    <!-- Top bar -->
    <header id="topbar" role="banner">
      <span id="topbar-title">QVC Signaling</span>
      <div class="topbar-divider" aria-hidden="true"></div>
      <div class="stats-row" aria-label="Server status">
        <div class="stat">
          <span class="s-label">Uptime</span><span class="s-value" id="c-uptime" aria-live="polite"
            >&mdash;</span
          >
        </div>
        <span class="stat-sep" aria-hidden="true">&middot;</span>
        <div class="stat">
          <span class="s-label">Status</span><span class="s-value" id="c-state" aria-live="polite"
            >&mdash;</span
          >
        </div>
        <span class="stat-sep" aria-hidden="true">&middot;</span>
        <div class="stat">
          <span class="s-label">Rooms</span><span class="s-value" id="c-rooms" aria-live="polite"
            >&mdash;</span
          >
        </div>
        <span class="stat-sep" aria-hidden="true">&middot;</span>
        <div class="stat">
          <span class="s-label">Peers</span><span class="s-value" id="c-peers" aria-live="polite"
            >&mdash;</span
          >
        </div>
      </div>
      <div class="topbar-spacer"></div>
      <div id="topbar-error" role="alert" aria-live="assertive"></div>
    </header>

    <!-- Middle row: rooms | peers | events -->
    <div id="middle-row">
      <section class="panel" aria-label="Active rooms">
        <p class="panel-title">Rooms</p>
        <div id="rooms-error" role="alert" aria-live="assertive"></div>
        <div class="panel-scroll" id="rooms-container">
          <p class="empty">No active rooms.</p>
        </div>
      </section>
      <section class="panel" aria-label="Connected peers">
        <p class="panel-title">Peers</p>
        <div id="peers-error" role="alert" aria-live="assertive"></div>
        <div class="panel-scroll" id="peers-container">
          <p class="empty">No connected peers.</p>
        </div>
      </section>
    </div>

    <!-- Events -->
    <section id="log-section" aria-label="Recent events">
      <div id="log-header">
        <span id="log-section-title">Events</span>
      </div>
      <div class="panel-scroll" id="events-container"><p class="empty">No events yet.</p></div>
      <div id="events-error" role="alert" aria-live="assertive"></div>
    </section>
  </div>

  <script is:inline src="/video-chat/js/dashboard.js"></script>
</BaseLayout>

<style>
  /* Dashboard layout */
  #dashboard {
    display: grid;
    grid-template-rows: 58px 1fr 32vh;
    min-height: 80vh;
    font-family: 'IBM Plex Mono', monospace;
    -webkit-font-smoothing: none;
    font-smooth: never;
  }

  /* Top bar */
  #topbar {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 0 20px;
    border-bottom: 2px solid #000;
    overflow: hidden;
  }

  #topbar-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .topbar-divider {
    width: 1px;
    height: 22px;
    background: #999;
    flex-shrink: 0;
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.2;
  }

  .stat .s-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #777;
  }

  .stat .s-value {
    font-size: 0.88rem;
    font-weight: 600;
  }

  .stat-sep {
    color: #999;
    font-size: 1.2rem;
  }

  #config-inline {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.75rem;
    color: #777;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #config-inline .cfg-val {
    font-weight: 500;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
  }

  .topbar-spacer {
    flex: 1;
  }

  #topbar-error {
    font-size: 0.78rem;
    color: #c33;
  }

  .topbar-btn {
    padding: 5px 13px;
    border: 2px solid #000;
    background: transparent;
    font-size: 0.78rem;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .topbar-btn:hover {
    background: #000;
    color: #fff;
  }

  .topbar-btn-danger {
    border-color: #c33;
    color: #c33;
  }

  .topbar-btn-danger:hover {
    background: #c33;
    color: #fff;
  }

  /* Middle row */
  #middle-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border-bottom: 2px solid #000;
  }

  .panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 14px 18px;
  }

  .panel + .panel {
    border-left: 2px solid #000;
  }

  .panel-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #777;
    margin-bottom: 10px;
    flex-shrink: 0;
  }

  .panel-scroll {
    flex: 1;
    overflow-y: auto;
  }

  /* Log section */
  #log-section {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 10px 18px 12px;
  }

  #log-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 6px;
    flex-shrink: 0;
  }

  #log-section-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #777;
  }

  #log-file {
    font-size: 0.72rem;
    color: #777;
    font-family: 'IBM Plex Mono', monospace;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #log-viewer {
    flex: 1;
    overflow-y: auto;
    background: #f5f5f5;
    border: 2px solid #000;
    padding: 8px 12px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* Tables */
  #dashboard :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.84rem;
  }

  #dashboard :global(th) {
    text-align: left;
    padding: 5px 10px;
    border-bottom: 2px solid #000;
    color: #777;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    position: sticky;
    top: 0;
    background: #fff;
  }

  #dashboard :global(td) {
    padding: 6px 10px;
    border-bottom: 1px solid #ddd;
    vertical-align: middle;
  }

  #dashboard :global(.mono) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
  }

  .empty {
    color: #777;
    font-size: 0.85rem;
    padding: 6px 0;
  }

  /* Badges */
  #dashboard :global(.badge) {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.74rem;
    font-weight: 600;
    border: 1px solid;
  }

  #dashboard :global(.badge-idle) {
    color: #1a7a42;
    border-color: #1a7a42;
  }

  #dashboard :global(.badge-connected) {
    color: #25c;
    border-color: #25c;
  }

  #dashboard :global(.badge-user_added) {
    color: #1a7a42;
    border-color: #1a7a42;
  }

  #dashboard :global(.badge-user_removed) {
    color: #c80;
    border-color: #c80;
  }

  #dashboard :global(.badge-peer_connected) {
    color: #25c;
    border-color: #25c;
  }

  #dashboard :global(.badge-peer_disconnected) {
    color: #c33;
    border-color: #c33;
  }

  /* Action buttons */
  #dashboard :global(.btn) {
    padding: 2px 9px;
    border: 1px solid;
    background: transparent;
    cursor: pointer;
    font-size: 0.74rem;
    font-weight: 500;
    font-family: inherit;
    margin-right: 3px;
  }

  #dashboard :global(.btn:disabled) {
    opacity: 0.3;
    cursor: not-allowed;
  }

  #dashboard :global(.btn-warn) {
    color: #c80;
    border-color: #c80;
  }

  #dashboard :global(.btn-warn:hover:not(:disabled)) {
    background: rgb(204 136 0 / 12%);
  }

  #dashboard :global(.btn-danger) {
    color: #c33;
    border-color: #c33;
  }

  #dashboard :global(.btn-danger:hover:not(:disabled)) {
    background: rgb(204 51 51 / 12%);
  }

  /* Error banner */
  #dashboard :global(.error-msg) {
    border: 2px solid #c33;
    color: #c33;
    padding: 7px 12px;
    margin-bottom: 10px;
    font-size: 0.82rem;
  }

  /* Log line colors */
  #dashboard :global(.log-info) {
    color: #333;
  }

  #dashboard :global(.log-debug) {
    color: #888;
  }

  #dashboard :global(.log-warning) {
    color: #c80;
  }

  #dashboard :global(.log-error) {
    color: #c33;
  }

  /* Scrollbar */
  #dashboard ::-webkit-scrollbar {
    width: 5px;
  }

  #dashboard ::-webkit-scrollbar-track {
    background: transparent;
  }

  #dashboard ::-webkit-scrollbar-thumb {
    background: #ccc;
  }
</style>
