---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Tag from '../../components/Tag.astro';
import { siteConfig } from '../../config/site';

const postModules = import.meta.glob('../../content/blog/*.mdx', { eager: true });
const tagMap = new Map<string, { title: string; slug: string; date: string }[]>();

for (const [path, mod] of Object.entries(postModules)) {
  const post = mod as any;
  const slug = path.split('/').pop()?.replace('.mdx', '') || '';
  for (const tag of (post.frontmatter.tags || [])) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push({
      title: post.frontmatter.title,
      slug,
      date: post.frontmatter.date,
    });
  }
}

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<BaseLayout title="Tags" description="Browse blog posts by tag">
  <Breadcrumbs crumbs={[
    { label: 'Blog', href: '/blog' },
    { label: 'Tags' },
  ]} />

  <section class="page-header">
    <h1>Tags</h1>
    <p class="page-subtitle">Browse posts by topic.</p>
  </section>

  <div class="tags-grid">
    {sortedTags.map(([tag, tagPosts]) => (
      <div class="standard-dialog tag-group">
        <h2 class="tag-heading">
          <Tag variant="default">{tag}</Tag>
          <span class="tag-count">{tagPosts.length} post{tagPosts.length > 1 ? 's' : ''}</span>
        </h2>
        <ul class="tag-posts">
          {tagPosts
            .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
            .map((p) => (
              <li><a href={`/blog/${p.slug}`}>{p.title}</a></li>
            ))}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
    padding-bottom: var(--space-8);
  }
  .tag-heading {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: 1em;
  }
  .tag-count {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 11px;
    color: #666;
  }
  .tag-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tag-posts li { margin-bottom: var(--space-1); }
  .tag-posts a {
    font-size: 13px;
    color: #000;
  }
  .tag-posts a:hover { background: #000; color: #fff; }
</style>
