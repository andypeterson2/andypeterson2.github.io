---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Tag from '../../components/Tag.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const allPosts = await import.meta.glob('../../content/blog/*.mdx', { eager: true });
  return Object.entries(allPosts).map(([path, post]: [string, any]) => ({
    params: { slug: path.split('/').pop()?.replace('.mdx', '') || '' },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
const { slug } = Astro.params;

const allPostModules = import.meta.glob('../../content/blog/*.mdx', { eager: true });
const allPostEntries = Object.entries(allPostModules).map(([path, mod]: [string, any]) => ({
  ...mod,
  _slug: path.split('/').pop()?.replace('.mdx', '') || '',
}));
const sortedPosts = allPostEntries
  .filter(p => p.frontmatter?.date)
  .sort((a, b) => new Date(a.frontmatter.date).getTime() - new Date(b.frontmatter.date).getTime());
const postIndex = sortedPosts.findIndex(p => p._slug === slug);

const prevPost = postIndex > 0 ? sortedPosts[postIndex - 1] : null;
const nextPost = postIndex < sortedPosts.length - 1 ? sortedPosts[postIndex + 1] : null;

const prevSlug = prevPost?._slug;
const nextSlug = nextPost?._slug;

// Series support
const seriesPosts = frontmatter.series
  ? sortedPosts.filter(p => p.frontmatter.series === frontmatter.series)
  : [];
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Blog', href: '/blog' },
      { label: frontmatter.title },
    ]} />

    <article class="blog-post">
      <header class="post-header">
        <time class="post-date" datetime={frontmatter.date}>
          {new Date(frontmatter.date).toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          })}
        </time>
        <h1>{frontmatter.title}</h1>
        <p class="post-description">{frontmatter.description}</p>
        <div class="post-tags">
          {frontmatter.tags?.map((tag: string) => (
            <Tag variant="default">{tag}</Tag>
          ))}
        </div>
      </header>

      <aside class="toc" aria-label="Table of contents">
        <p class="toc-title">Contents</p>
        <nav id="toc-nav"></nav>
      </aside>

      {seriesPosts.length > 1 && (
        <div class="series-nav">
          <p class="series-label">Part of series: <strong>{frontmatter.series}</strong></p>
          <ol class="series-list">
            {seriesPosts.map((sp) => {
              const spSlug = sp._slug;
              const isCurrent = spSlug === slug;
              return (
                <li class:list={[{ current: isCurrent }]}>
                  {isCurrent ? (
                    <span>{sp.frontmatter.title}</span>
                  ) : (
                    <a href={`/blog/${spSlug}`}>{sp.frontmatter.title}</a>
                  )}
                </li>
              );
            })}
          </ol>
        </div>
      )}

      <div class="post-content prose">
        <Content />
      </div>
    </article>

    <nav class="post-nav" aria-label="Post navigation">
      {prevPost ? (
        <a href={`/blog/${prevSlug}`} class="post-nav-link prev">
          <span class="post-nav-dir">&larr; Previous</span>
          <span class="post-nav-title">{prevPost.frontmatter.title}</span>
        </a>
      ) : <span />}
      {nextPost ? (
        <a href={`/blog/${nextSlug}`} class="post-nav-link next">
          <span class="post-nav-dir">Next &rarr;</span>
          <span class="post-nav-title">{nextPost.frontmatter.title}</span>
        </a>
      ) : <span />}
    </nav>
  </div>
</BaseLayout>

<script>
  // Table of contents generation
  const headings = document.querySelectorAll('.post-content h2, .post-content h3');
  const tocNav = document.getElementById('toc-nav');
  if (tocNav && headings.length > 0) {
    const list = document.createElement('ul');
    headings.forEach((heading, i) => {
      if (!heading.id) heading.id = `heading-${i}`;
      const li = document.createElement('li');
      li.className = heading.tagName === 'H3' ? 'toc-h3' : '';
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent || '';
      li.appendChild(a);
      list.appendChild(li);
    });
    tocNav.appendChild(list);
  }

  // Copy to clipboard on code blocks
  document.querySelectorAll('.post-content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.type = 'button';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent || pre.textContent || '';
      await navigator.clipboard.writeText(code);
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
    (pre as HTMLElement).style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style>
  .post-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .post-header h1 {
    margin: var(--space-2) 0 var(--space-4);
  }
  .post-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }
  .post-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .toc {
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
    max-width: var(--content-width);
  }
  .toc-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-2);
  }
  .toc :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc :global(li) {
    margin-bottom: var(--space-1);
  }
  .toc :global(.toc-h3) {
    padding-left: var(--space-4);
  }
  .toc :global(a) {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .toc :global(a:hover) {
    color: var(--color-accent);
  }

  .series-nav {
    padding: var(--space-4) var(--space-6);
    background: var(--color-surface);
    border-left: 3px solid var(--color-accent);
    margin-bottom: var(--space-8);
    max-width: var(--content-width);
  }
  .series-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }
  .series-list {
    padding-left: var(--space-6);
    margin: 0;
    font-size: var(--text-sm);
  }
  .series-list li {
    margin-bottom: var(--space-1);
    color: var(--color-text-secondary);
  }
  .series-list .current {
    font-weight: 600;
    color: var(--color-accent);
  }

  .post-content {
    max-width: var(--content-width);
    padding-bottom: var(--space-12);
  }
  .post-content :global(h2) {
    margin-top: var(--space-12);
    margin-bottom: var(--space-4);
  }
  .post-content :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }
  .post-content :global(p) {
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
    color: var(--color-text-secondary);
  }
  .post-content :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-relaxed);
  }
  .post-content :global(pre) {
    margin-bottom: var(--space-6);
  }

  :global(.copy-btn) {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: var(--space-1) var(--space-2);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color var(--duration-fast);
  }
  :global(.copy-btn:hover) {
    color: var(--color-accent);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    padding: var(--space-8) 0;
    border-top: 1px solid var(--color-border);
    gap: var(--space-4);
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: border-color var(--duration-fast);
    max-width: 45%;
  }
  .post-nav-link:hover {
    border-color: var(--color-accent);
  }
  .post-nav-link.next {
    text-align: right;
    margin-left: auto;
  }
  .post-nav-dir {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .post-nav-title {
    font-size: var(--text-sm);
    color: var(--color-text);
  }
</style>
