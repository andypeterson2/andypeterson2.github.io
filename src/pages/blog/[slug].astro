---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Tag from '../../components/Tag.astro';
import Button from '../../components/Button.astro';
import { siteConfig } from '../../config/site';

export async function getStaticPaths() {
  const allPosts = await import.meta.glob('../../content/blog/*.mdx', { eager: true });
  return Object.entries(allPosts).map(([path, post]: [string, any]) => ({
    params: { slug: path.split('/').pop()?.replace('.mdx', '') || '' },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, frontmatter } = post;
const { slug } = Astro.params;

const allPostModules = import.meta.glob('../../content/blog/*.mdx', { eager: true });
const allPostEntries = Object.entries(allPostModules).map(([path, mod]: [string, any]) => ({
  ...mod,
  _slug: path.split('/').pop()?.replace('.mdx', '') || '',
}));
const sortedPosts = allPostEntries
  .filter(p => p.frontmatter?.date)
  .sort((a, b) => new Date(a.frontmatter.date).getTime() - new Date(b.frontmatter.date).getTime());
const postIndex = sortedPosts.findIndex(p => p._slug === slug);

const prevPost = postIndex > 0 ? sortedPosts[postIndex - 1] : null;
const nextPost = postIndex < sortedPosts.length - 1 ? sortedPosts[postIndex + 1] : null;
const prevSlug = prevPost?._slug;
const nextSlug = nextPost?._slug;

const seriesPosts = frontmatter.series
  ? sortedPosts.filter(p => p.frontmatter.series === frontmatter.series)
  : [];
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <Breadcrumbs crumbs={[
    { label: 'Blog', href: '/blog' },
    { label: frontmatter.title },
  ]} />

  <article class="blog-post">
    <header class="post-header">
      <time class="post-date" datetime={frontmatter.date}>
        {new Date(frontmatter.date).toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric',
        })}
      </time>
      <h1>{frontmatter.title}</h1>
      <p class="post-description">{frontmatter.description}</p>
      <div class="post-tags">
        {frontmatter.tags?.map((tag: string) => (
          <Tag variant="default">{tag}</Tag>
        ))}
      </div>
    </header>

    <aside class="standard-dialog toc" aria-label="Table of contents">
      <strong>Contents</strong>
      <nav id="toc-nav"></nav>
    </aside>

    {seriesPosts.length > 1 && (
      <div class="standard-dialog series-nav">
        <strong>Series: {frontmatter.series}</strong>
        <ol class="series-list">
          {seriesPosts.map((sp) => {
            const spSlug = sp._slug;
            const isCurrent = spSlug === slug;
            return (
              <li class:list={[{ current: isCurrent }]}>
                {isCurrent ? (
                  <span>{sp.frontmatter.title}</span>
                ) : (
                  <a href={`/blog/${spSlug}`}>{sp.frontmatter.title}</a>
                )}
              </li>
            );
          })}
        </ol>
      </div>
    )}

    <div class="post-content prose">
      <Content />
    </div>
  </article>

  <div class="separator"></div>

  <nav class="post-nav" aria-label="Post navigation">
    {prevPost ? (
      <a href={`/blog/${prevSlug}`} class="standard-dialog post-nav-link">
        <span class="post-nav-dir">&larr; Previous</span>
        <span class="post-nav-title">{prevPost.frontmatter.title}</span>
      </a>
    ) : <span />}
    {nextPost ? (
      <a href={`/blog/${nextSlug}`} class="standard-dialog post-nav-link next">
        <span class="post-nav-dir">Next &rarr;</span>
        <span class="post-nav-title">{nextPost.frontmatter.title}</span>
      </a>
    ) : <span />}
  </nav>
</BaseLayout>

<script>
  // Table of contents generation
  const headings = document.querySelectorAll('.post-content h2, .post-content h3');
  const tocNav = document.getElementById('toc-nav');
  if (tocNav && headings.length > 0) {
    const list = document.createElement('ul');
    list.style.listStyle = 'none';
    list.style.padding = '0';
    list.style.margin = '4px 0 0';
    headings.forEach((heading, i) => {
      if (!heading.id) heading.id = `heading-${i}`;
      const li = document.createElement('li');
      if (heading.tagName === 'H3') li.style.paddingLeft = '16px';
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent || '';
      a.style.fontSize = '13px';
      a.style.fontFamily = 'Monaco, ui-monospace, monospace';
      li.appendChild(a);
      list.appendChild(li);
    });
    tocNav.appendChild(list);
  }

  // Copy to clipboard on code blocks
  document.querySelectorAll('.post-content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'btn copy-btn';
    btn.textContent = 'Copy';
    btn.type = 'button';
    btn.style.cssText = 'position:absolute;top:4px;right:4px;font-size:11px;min-width:auto;min-height:auto;padding:1px 6px;';
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent || pre.textContent || '';
      await navigator.clipboard.writeText(code);
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 2000);
    });
    (pre as HTMLElement).style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style>
  .post-header {
    padding: var(--space-6) 0 var(--space-4);
    max-width: var(--content-width);
  }
  .post-date {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 12px;
    color: #666;
  }
  .post-header h1 { margin: var(--space-2) 0 var(--space-4); }
  .post-description {
    font-size: 16px;
    margin-bottom: var(--space-4);
  }
  .post-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .toc {
    margin-bottom: var(--space-6);
    max-width: var(--content-width);
  }
  .series-nav {
    margin-bottom: var(--space-6);
    max-width: var(--content-width);
    border-left: 4px solid #000;
  }
  .series-list {
    padding-left: var(--space-6);
    margin: var(--space-2) 0 0;
    font-size: 13px;
  }
  .series-list li { margin-bottom: var(--space-1); }
  .series-list .current { font-weight: 700; }

  .post-content {
    max-width: var(--content-width);
    padding-bottom: var(--space-8);
  }
  .post-content :global(h2) { margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .post-content :global(h3) { margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .post-content :global(p) { line-height: 1.65; }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }
  .post-content :global(li) { margin-bottom: var(--space-2); line-height: 1.65; }
  .post-content :global(pre) { margin-bottom: var(--space-4); }

  .post-nav {
    display: flex;
    justify-content: space-between;
    padding: var(--space-6) 0;
    gap: var(--space-4);
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    text-decoration: none;
    color: #000;
    max-width: 45%;
  }
  .post-nav-link:hover { background: #000; color: #fff; }
  .post-nav-link.next { text-align: right; margin-left: auto; }
  .post-nav-dir {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .post-nav-title { font-size: 13px; }
</style>
