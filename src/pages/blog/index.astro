---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Tag from '../../components/Tag.astro';
import { siteConfig } from '../../config/site';

const postModules = import.meta.glob('../../content/blog/*.mdx', { eager: true });
const posts = Object.entries(postModules).map(([path, mod]: [string, any]) => ({
  ...mod,
  slug: path.split('/').pop()?.replace('.mdx', '') || '',
}));
const sortedPosts = posts
  .filter(p => p.frontmatter?.date)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const allTags = [...new Set(sortedPosts.flatMap(p => p.frontmatter.tags || []))];
---

<BaseLayout title="Blog" description={`Blog posts by ${siteConfig.displayName}`}>
  <div class="container">
    <Breadcrumbs crumbs={[{ label: 'Blog' }]} />
    <section class="page-header">
      <h1>Blog</h1>
      <p class="page-subtitle">Thoughts on quantum computing, software, and research.</p>
    </section>

    <div class="blog-tags" role="group" aria-label="Filter by tag">
      <button class="blog-tag-btn active" data-tag="all" type="button">All</button>
      {allTags.map((tag) => (
        <button class="blog-tag-btn" data-tag={tag} type="button">{tag}</button>
      ))}
    </div>

    <div class="blog-feed" role="feed" aria-label="Blog posts">
      {sortedPosts.map((post) => {
        const slug = post.slug;
        return (
          <article class="blog-post-card" data-tags={post.frontmatter.tags?.join(',') || ''}>
            <a href={`/blog/${slug}`} class="post-link">
              <time class="post-date" datetime={post.frontmatter.date}>
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                  year: 'numeric', month: 'short', day: 'numeric',
                })}
              </time>
              <h2 class="post-title">{post.frontmatter.title}</h2>
              <p class="post-excerpt">{post.frontmatter.description}</p>
              <div class="post-tags">
                {post.frontmatter.tags?.map((tag: string) => (
                  <Tag variant="default">{tag}</Tag>
                ))}
              </div>
            </a>
          </article>
        );
      })}
    </div>

    <section class="rss-section">
      <a href="/rss.xml" class="rss-link">
        <span class="rss-icon">RSS</span> Subscribe via RSS
      </a>
    </section>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.blog-tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.blog-tag-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = btn.getAttribute('data-tag');
      document.querySelectorAll('.blog-post-card').forEach(card => {
        const tags = (card as HTMLElement).getAttribute('data-tags') || '';
        (card as HTMLElement).style.display =
          tag === 'all' || tags.split(',').includes(tag!) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .page-header {
    padding: var(--space-16) 0 var(--space-8);
    max-width: var(--content-width);
  }
  .page-header h1 {
    margin-bottom: var(--space-4);
  }
  .page-subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
  }

  .blog-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    flex-wrap: wrap;
  }
  .blog-tag-btn {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--duration-fast);
    min-height: 40px;
  }
  .blog-tag-btn:hover,
  .blog-tag-btn.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .blog-feed {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: var(--content-width);
  }
  .blog-post-card {
    border-bottom: 1px solid var(--color-border);
  }
  .post-link {
    display: block;
    padding: var(--space-6) 0;
    text-decoration: none;
    transition: transform var(--duration-fast);
  }
  .post-link:hover {
    transform: translateX(var(--space-2));
  }
  .post-link:hover .post-title {
    color: var(--color-accent);
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .post-title {
    color: var(--color-text);
    margin: var(--space-2) 0;
    transition: color var(--duration-fast);
  }
  .post-excerpt {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-2);
  }
  .post-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .rss-section {
    padding: var(--space-8) 0;
  }
  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }
  .rss-link:hover {
    color: var(--color-accent);
  }
  .rss-icon {
    padding: var(--space-1) var(--space-2);
    background: var(--color-accent);
    color: var(--color-text-inverse);
    font-size: var(--text-xs);
    font-weight: 600;
  }
</style>
