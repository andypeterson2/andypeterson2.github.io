---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Tag from '../../components/Tag.astro';
import { siteConfig } from '../../config/site';

const postModules = import.meta.glob('../../content/blog/*.mdx', { eager: true });
const posts = Object.entries(postModules).map(([path, mod]: [string, any]) => ({
  ...mod,
  slug: path.split('/').pop()?.replace('.mdx', '') || '',
}));
const sortedPosts = posts
  .filter(p => p.frontmatter?.date)
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());

const allTags = [...new Set(sortedPosts.flatMap(p => p.frontmatter.tags || []))];
---

<BaseLayout title="Blog" description={`Blog posts by ${siteConfig.displayName}`}>
  <Breadcrumbs crumbs={[{ label: 'Blog' }]} />
  <section class="page-header">
    <h1>Blog</h1>
    <p class="page-subtitle">Thoughts on quantum computing, software, and research.</p>
  </section>

  <div class="blog-tags" role="group" aria-label="Filter by tag">
    <button class="btn blog-tag-btn active" data-tag="all" type="button">All</button>
    {allTags.map((tag) => (
      <button class="btn blog-tag-btn" data-tag={tag} type="button">{tag}</button>
    ))}
  </div>

  <div class="blog-feed" role="feed" aria-label="Blog posts">
    {sortedPosts.map((post) => {
      const slug = post.slug;
      return (
        <article class="blog-post-card" data-tags={post.frontmatter.tags?.join(',') || ''}>
          <a href={`/blog/${slug}`} class="post-link">
            <time class="post-date" datetime={post.frontmatter.date}>
              {new Date(post.frontmatter.date).toLocaleDateString('en-US', {
                year: 'numeric', month: 'short', day: 'numeric',
              })}
            </time>
            <h2 class="post-title">{post.frontmatter.title}</h2>
            <p class="post-excerpt">{post.frontmatter.description}</p>
            <div class="post-tags">
              {post.frontmatter.tags?.map((tag: string) => (
                <Tag variant="default">{tag}</Tag>
              ))}
            </div>
          </a>
        </article>
      );
    })}
  </div>

  <section class="rss-section">
    <a href="/rss.xml" class="rss-link">[RSS] Subscribe via RSS</a>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.blog-tag-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.blog-tag-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tag = btn.getAttribute('data-tag');
      document.querySelectorAll('.blog-post-card').forEach(card => {
        const tags = (card as HTMLElement).getAttribute('data-tags') || '';
        (card as HTMLElement).style.display =
          tag === 'all' || tags.split(',').includes(tag!) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .blog-tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }
  .blog-tag-btn {
    font-size: 12px;
    min-width: auto;
    min-height: auto;
    padding: 2px 8px;
  }
  .blog-tag-btn.active {
    background: #000;
    color: #fff;
  }
  .blog-feed {
    max-width: var(--content-width);
  }
  .blog-post-card {
    border-bottom: 2px solid #000;
  }
  .post-link {
    display: block;
    padding: var(--space-4) 0;
    text-decoration: none;
    color: #000;
  }
  .post-link:hover {
    background: #000;
    color: #fff;
    padding-left: var(--space-2);
    padding-right: var(--space-2);
  }
  .post-link:hover .post-title { color: #fff; }
  .post-date {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 12px;
    color: #666;
  }
  .post-link:hover .post-date { color: #ccc; }
  .post-title {
    margin: var(--space-1) 0;
  }
  .post-excerpt {
    font-size: 13px;
    margin-bottom: var(--space-2);
  }
  .post-tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .rss-section { padding: var(--space-6) 0; }
  .rss-link {
    font-family: Monaco, ui-monospace, monospace;
    font-size: 13px;
    color: #000;
  }
  .rss-link:hover { background: #000; color: #fff; }
</style>
