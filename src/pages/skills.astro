---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Tag from '../components/Tag.astro';
import { siteConfig } from '../config/site';

const categories = [
  {
    id: 'quantum',
    label: 'Quantum Computing',
    skills: ['QKD Protocols (BB84)', 'Qiskit', 'Quantum Circuits', 'Quantum Optimization', 'Quantum Error Correction'],
  },
  {
    id: 'languages',
    label: 'Languages',
    skills: ['Python', 'TypeScript', 'JavaScript', 'Rust', 'C++', 'SQL'],
  },
  {
    id: 'frameworks',
    label: 'Frameworks & Tools',
    skills: ['React', 'Astro', 'Node.js', 'Flask', 'Docker', 'WebRTC'],
  },
  {
    id: 'ml',
    label: 'Machine Learning',
    skills: ['PyTorch', 'Scikit-learn', 'Kernel Methods', 'CNNs', 'Data Pipelines'],
  },
];
---

<BaseLayout title="Skills" description={`Skills and expertise of ${siteConfig.displayName}`}>
  <section class="page-header">
    <h1>Skills</h1>
    <p class="page-subtitle">Technical skills and areas of expertise.</p>
  </section>

  <!-- Tab switcher styled like system.css menu-bar -->
  <div role="tablist" class="skills-tabs" aria-label="Skill categories">
    {categories.map((cat, i) => (
      <button
        role="tab"
        type="button"
        class:list={['tab-btn', { active: i === 0 }]}
        data-tab={cat.id}
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`panel-${cat.id}`}
        id={`tab-${cat.id}`}
      >
        {cat.label}
      </button>
    ))}
  </div>

  {categories.map((cat, i) => (
    <div
      class:list={['tab-panel', { active: i === 0 }]}
      data-panel={cat.id}
      id={`panel-${cat.id}`}
      role="tabpanel"
      aria-labelledby={`tab-${cat.id}`}
    >
      <div class="skill-grid">
        {cat.skills.map((skill) => (
          <div class="standard-dialog skill-item">
            {skill}
          </div>
        ))}
      </div>
    </div>
  ))}
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('[role="tab"]');
  const panels = document.querySelectorAll('[role="tabpanel"]');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('active');
    });
  });
</script>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .skills-tabs {
    display: flex;
    margin-bottom: var(--space-6);
    border: 2px solid #000;
    border-bottom: 2px solid #000;
    background: #fff;
  }
  .tab-btn {
    padding: 6px 12px;
    border: none;
    background: #fff;
    color: #000;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 16px;
    cursor: pointer;
  }
  .tab-btn:hover { background: #000; color: #fff; }
  .tab-btn.active {
    background: #000;
    color: #fff;
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: var(--space-3);
  }
  .skill-item {
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .skill-item:hover {
    background: #000;
    color: #fff;
  }
</style>
