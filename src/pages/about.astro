---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="About" description={`About ${siteConfig.displayName}`}>
  <!-- Bio -->
  <div class="window bio-window">
    <div class="title-bar">
      <button class="close" aria-hidden="true" tabindex="-1"><span>Close</span></button>
      <h1 class="title">Intro</h1>
      <button class="resize" aria-hidden="true" tabindex="-1"><span>Resize</span></button>
    </div>
    <div class="details-bar">
      <span>Quantum Researcher · Security Engineer · Software Architect</span>
      <span>Perris, CA</span>
    </div>
    <div class="bio-body">
      <div class="bio-card">
        <img src="/headshot.png" alt="Andrew Peterson" class="bio-headshot" />
        <div class="bio-name">Andrew Peterson</div>
        <div class="bio-contact">
          <a href="mailto:acpeters@ucsd.edu" class="btn">Email</a>
          <a
            href="https://linkedin.com/in/i-am-andy-peterson"
            class="btn"
            target="_blank"
            rel="noopener noreferrer">LinkedIn</a
          >
          <a
            href="https://github.com/andypeterson2"
            class="btn"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </div>
      </div>
      <p>
        Recent <strong>UC San Diego</strong> graduate passionate about making
        <strong>high-level technical ideas</strong> usable and understandable to as many people as possible.
      </p>
      <p>
        I co-founded <strong>San Diego CTF</strong> and the
        <strong>Quantum Computing Student Association at UC San Diego</strong>, led remote learning
        infrastructure during COVID, and handled training and documentation for two student orgs. On
        the research side, I spent two years at the <strong>Qualcomm Institute</strong> on
        <strong>quantum-secured communications</strong>, <strong>quantum algorithms</strong>, and
        <strong>quantum machine learning</strong>.
      </p>
      <p>
        I'm looking for roles where the
        <strong>technical and human sides both matter</strong> — building scalable, secure, and usable
        solutions while communicating ideas clearly.
      </p>
    </div>
  </div>

  <!-- Two-column layout -->
  <div class="about-grid">
    <!-- Left sidebar -->
    <aside class="sidebar">
      <section class="sidebar-section">
        <h2 class="sidebar-heading">Education</h2>
        <div class="sidebar-entry">
          <div class="sidebar-entry-title">B.S. Computer Science</div>
          <div class="sidebar-entry-sub">UC San Diego</div>
          <div class="sidebar-entry-date">2020 – 2024</div>
        </div>
      </section>

      <section class="sidebar-section">
        <h2 class="sidebar-heading">Certifications</h2>
        <div class="sidebar-entry">
          <div class="sidebar-entry-title">Azure Data Fundamentals</div>
          <div class="sidebar-entry-sub">Microsoft · 2025</div>
        </div>
        <div class="sidebar-entry">
          <div class="sidebar-entry-title">IT Fundamentals+</div>
          <div class="sidebar-entry-sub">CompTIA · 2022</div>
        </div>
      </section>

      <section class="sidebar-section">
        <h2 class="sidebar-heading">Skills</h2>
        <div class="skill-group">
          <div class="skill-group-label">Quantum</div>
          <div class="skill-tags">
            <span class="tag">Qiskit</span>
            <span class="tag">PennyLane</span>
            <span class="tag">BB84</span>
            <span class="tag">QAOA</span>
            <span class="tag">Grover</span>
            <span class="tag">QML</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Languages</div>
          <div class="skill-tags">
            <span class="tag">Python</span>
            <span class="tag">TypeScript</span>
            <span class="tag">C/C++</span>
            <span class="tag">Java</span>
            <span class="tag">SQL</span>
            <span class="tag">Rust</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Systems</div>
          <div class="skill-tags">
            <span class="tag">Docker</span>
            <span class="tag">Kubernetes</span>
            <span class="tag">Terraform</span>
            <span class="tag">Linux</span>
            <span class="tag">AWS</span>
            <span class="tag">CI/CD</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">Security</div>
          <div class="skill-tags">
            <span class="tag">Pen Testing</span>
            <span class="tag">Cryptography</span>
            <span class="tag">OSINT</span>
            <span class="tag">Ghidra</span>
            <span class="tag">CTF</span>
          </div>
        </div>
        <div class="skill-group">
          <div class="skill-group-label">AI / Data</div>
          <div class="skill-tags">
            <span class="tag">PyTorch</span>
            <span class="tag">Scikit-Learn</span>
            <span class="tag">Pandas</span>
            <span class="tag">Computer Vision</span>
          </div>
        </div>
      </section>

      <section class="sidebar-section">
        <a href="/resume.pdf" class="resume-btn">Download Resume</a>
      </section>
    </aside>

    <!-- Right: Timeline -->
    <div class="timeline">
      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2022 – 2024</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Quantum Software Engineering Lead</div>
          <div class="timeline-org">Qualcomm Institute · La Jolla, CA</div>
          <ul class="timeline-bullets">
            <li>
              Architected a QKD-secured video chat platform using BB84 protocol over WebRTC
              Insertable Streams.
            </li>
            <li>
              Optimized Grover's algorithm in Qiskit for binary constraint satisfaction problems,
              demonstrating quadratic speedup.
            </li>
            <li>
              Built and evaluated QML classifiers via quantum neural networks and kernel methods.
            </li>
            <li>
              Mentored cross-functional intern team and oversaw setup of a new undergraduate quantum
              computing lab under Dr. Nikola Alic.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2021 – 2024</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Co-Founder & President</div>
          <div class="timeline-org">Quantum Computing Student Association at UC San Diego</div>
          <ul class="timeline-bullets">
            <li>
              Co-founded UCSD's first undergraduate quantum computing organization, growing to 100+
              members.
            </li>
            <li>
              Developed technical curriculum for workshops covering quantum foundations and Qiskit.
            </li>
            <li>
              Standardized workflows and digital infrastructure for sustainable leadership
              transitions.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2023</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">President & Cybersecurity Competitor</div>
          <div class="timeline-org">ACM Cyber @ UCSD</div>
          <ul class="timeline-bullets">
            <li>Trained and led teams for CCDC, CPTC, and Google CTF national competitions.</li>
            <li>
              Authored training modules on penetration testing, network defense, and cryptography.
            </li>
            <li>Ran weekly workshops and Deep Dive sessions on advanced security topics.</li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2022</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Full-Stack DevOps Engineer & Advisor</div>
          <div class="timeline-org">RIT Esports · Remote</div>
          <ul class="timeline-bullets">
            <li>
              Built and deployed scalable web infrastructure using MERN stack and Docker Compose.
            </li>
            <li>
              Managed DigitalOcean cloud infra with Nginx reverse proxies, maintaining 99.9% uptime.
            </li>
            <li>Built CI/CD pipelines and monitoring suites to reduce deployment friction.</li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2022</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Lead Infrastructure Engineer & Challenge Designer</div>
          <div class="timeline-org">San Diego CTF (SDCTF)</div>
          <ul class="timeline-bullets">
            <li>
              Built the backend for SD's largest annual cybersecurity competition, supporting 500+
              global participants in its inaugural year.
            </li>
            <li>
              Provisioned cloud-native infra with Terraform, managing Postgres and containerized
              challenge environments.
            </li>
            <li>
              Designed OSINT challenges and a Discord.JS bot for real-time flag validation and
              leaderboard updates.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2021</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Instructor & IT Systems Specialist</div>
          <div class="timeline-org">Mathnasium · Temecula, CA</div>
          <ul class="timeline-bullets">
            <li>
              Taught Calculus and Computer Science, adapting to diverse student learning levels.
            </li>
            <li>
              Led digital transformation during COVID-19, maintaining IT infrastructure for remote
              learning.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Bio window ── */
  .bio-body {
    font-size: clamp(13px, 1.6vw, 18px);
    line-height: 1.65;
    padding: clamp(8px, 1.2vw, 16px);
  }

  .bio-card {
    float: left;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(6px, 0.8vw, 10px);
    text-align: center;
    margin: 0 clamp(12px, 2vw, 24px) clamp(8px, 1vw, 12px) 0;
    width: clamp(100px, 20%, 150px);
  }

  .bio-headshot {
    width: 100%;
    height: auto;
    border: 2px solid #000;
    display: block;
  }

  .bio-name {
    font-family: var(--font-ui);
    font-size: clamp(11px, 1.3vw, 15px);
    font-weight: 700;
    line-height: 1.3;
  }

  .bio-contact {
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 5px);
    width: 100%;
  }

  /* ── Two-column grid ── */
  .about-grid {
    display: grid;
    grid-template-columns: clamp(180px, 26%, 240px) 1fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: start;
    margin-top: clamp(16px, 2.5vw, 32px);
  }

  /* ── Sidebar ── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2.5vw, 28px);
    position: sticky;
    top: clamp(12px, 2vw, 24px);
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 0.8vw, 10px);
  }

  .sidebar-heading {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1.1vw, 13px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-bottom: 1px solid #000;
    padding-bottom: clamp(3px, 0.4vw, 5px);
    margin: 0;
  }

  .sidebar-entry {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-entry + .sidebar-entry {
    margin-top: clamp(4px, 0.6vw, 8px);
  }

  .sidebar-entry-title {
    font-family: var(--font-ui);
    font-size: clamp(10px, 1.3vw, 14px);
    font-weight: 700;
    line-height: 1.3;
  }

  .sidebar-entry-sub,
  .sidebar-entry-date {
    font-size: clamp(9px, 1.1vw, 12px);
    opacity: 0.6;
    line-height: 1.3;
  }

  /* Skills */
  .skill-group {
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 4px);
    margin-top: clamp(6px, 0.8vw, 10px);
  }

  .skill-group:first-of-type {
    margin-top: 0;
  }

  .skill-group-label {
    font-family: var(--font-mono);
    font-size: clamp(8px, 0.9vw, 10px);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(3px, 0.4vw, 4px);
  }

  .tag {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1vw, 11px);
    border: 1px solid #000;
    padding: 1px clamp(4px, 0.5vw, 6px);
    line-height: 1.6;
  }

  /* Resume button */
  .resume-btn {
    display: block;
    font-family: var(--font-ui);
    font-size: clamp(10px, 1.3vw, 14px);
    border: 2px solid #000;
    padding: clamp(4px, 0.5vw, 7px) clamp(10px, 1.2vw, 16px);
    text-decoration: none;
    color: #000;
    background: #fff;
    text-align: center;
  }

  .resume-btn:hover {
    background: #000;
    color: #fff;
  }

  /* ── Timeline ── */
  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: clamp(36px, 4.5vw, 54px);
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: #000;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: clamp(36px, 4.5vw, 54px) 1fr;
    gap: clamp(12px, 1.8vw, 22px);
    padding-bottom: clamp(20px, 3vw, 36px);
    position: relative;
  }

  .timeline-entry:last-child {
    padding-bottom: 0;
  }

  .timeline-entry::after {
    content: '';
    position: absolute;
    left: clamp(36px, 4.5vw, 54px);
    top: 8px;
    width: 7px;
    height: 7px;
    background: #000;
    transform: translateX(-3px);
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-top: 2px;
  }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: clamp(8px, 0.9vw, 11px);
    opacity: 0.5;
    text-align: right;
    line-height: 1.4;
    white-space: nowrap;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.3vw, 3px);
  }

  .timeline-role {
    font-family: var(--font-ui);
    font-size: clamp(11px, 1.4vw, 16px);
    font-weight: 700;
    line-height: 1.3;
  }

  .timeline-org {
    font-size: clamp(10px, 1.2vw, 13px);
    opacity: 0.55;
    margin-bottom: clamp(4px, 0.6vw, 8px);
  }

  .timeline-bullets {
    margin: 0;
    padding-left: clamp(14px, 1.8vw, 20px);
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 5px);
  }

  .timeline-bullets li {
    font-size: clamp(11px, 1.3vw, 15px);
    line-height: 1.55;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }

    .timeline::before {
      display: none;
    }

    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .timeline-entry::after {
      display: none;
    }

    .timeline-meta {
      align-items: flex-start;
    }

    .timeline-date {
      text-align: left;
    }
  }
</style>
