---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="About" description={`About ${siteConfig.displayName}`}>
  <div class="container">
    <section class="page-header">
      <h1>About</h1>
      <p class="page-subtitle">Background, research, and what drives my work.</p>
    </section>

    <section class="about-bio">
      <SectionLabel label="Bio" />
      <div class="bio-content">
        <p>
          {siteConfig.displayName} — researcher, engineer, and builder of things
          at the intersection of quantum computing and applied software.
        </p>
      </div>
    </section>

    <section class="about-timeline">
      <SectionLabel label="Timeline" />
      <div class="timeline">
        <div class="timeline-item">
          <span class="timeline-date">Present</span>
          <div class="timeline-content">
            <h3>Quantum Computing Research</h3>
            <p>Building quantum-secured communication systems and exploring quantum advantage in optimization problems.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="about-interests">
      <SectionLabel label="Research Interests" />
      <ul class="interest-list">
        <li>Quantum Key Distribution (QKD)</li>
        <li>Quantum Optimization Algorithms</li>
        <li>Applied Cryptography</li>
        <li>Systems Programming</li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-16) 0 var(--space-8);
    max-width: var(--content-width);
  }
  .page-header h1 {
    margin-bottom: var(--space-4);
  }
  .page-subtitle {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
  }

  .about-bio,
  .about-timeline,
  .about-interests {
    padding: var(--space-12) 0;
  }
  .bio-content {
    max-width: var(--content-width);
  }
  .bio-content p {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    padding-left: var(--space-6);
    border-left: 2px solid var(--color-border);
  }
  .timeline-item {
    position: relative;
  }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-6) - 5px);
    top: var(--space-1);
    width: 8px;
    height: 8px;
    background: var(--color-accent);
  }
  .timeline-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
  .timeline-content h3 {
    margin: var(--space-1) 0 var(--space-2);
  }
  .timeline-content p {
    color: var(--color-text-secondary);
  }

  .interest-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-3);
    list-style: none;
    padding: 0;
  }
  .interest-list li {
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
