---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PullQuote from '../components/PullQuote.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="About" description={`About ${siteConfig.displayName}`}>
  <Breadcrumbs crumbs={[{ label: 'About' }]} />
  <section class="page-header">
    <h1>About</h1>
    <p class="page-subtitle">Background, research, and what drives my work.</p>
  </section>

  <section class="content-section">
    <SectionLabel label="Bio" />
    <p class="bio">
      {siteConfig.displayName} — researcher, engineer, and builder of things
      at the intersection of quantum computing and applied software.
    </p>
  </section>

  <PullQuote>
    Building bridges between quantum theory and practical software — one qubit at a time.
  </PullQuote>

  <section class="content-section">
    <SectionLabel label="Timeline" />
    <div class="standard-dialog timeline-item">
      <div class="details-bar">
        <span>Quantum Computing Research</span>
        <span>Present</span>
      </div>
      <div class="timeline-body">
        Building quantum-secured communication systems and exploring quantum advantage in optimization problems.
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Research Interests" />
    <div class="interest-grid">
      <div class="standard-dialog interest-item">Quantum Key Distribution (QKD)</div>
      <div class="standard-dialog interest-item">Quantum Optimization Algorithms</div>
      <div class="standard-dialog interest-item">Applied Cryptography</div>
      <div class="standard-dialog interest-item">Systems Programming</div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .content-section { padding: var(--space-6) 0; }
  .bio {
    max-width: var(--content-width);
    font-size: 16px;
    line-height: 1.8;
  }
  .timeline-body {
    padding: var(--space-4);
    font-size: 16px;
  }
  .interest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-3);
  }
  .interest-item {
    font-family: var(--font-mono);
    font-size: 13px;
  }
</style>
