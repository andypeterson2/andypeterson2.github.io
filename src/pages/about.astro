---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="About" description={`About ${siteConfig.displayName}`}>
  <!-- Bio -->
  <div class="window bio-window">
    <div class="title-bar">

      <h1 class="title">Intro</h1>

    </div>
    <div class="details-bar">
      <span>Software Developer</span>
      <span>Perris, CA</span>
    </div>
    <div class="bio-body">
      <div class="bio-card window">
        <div class="title-bar">
    
          <span class="title">Me</span>
    
        </div>
        <img src="/headshot.png" alt="Andrew Peterson" class="bio-headshot" />
        <div class="details-bar bio-details-bar">
          <span>Andrew Peterson</span>
        </div>
      </div>
      <p>
        Recent <strong>UC San Diego</strong> Computer Science graduate. I spent two and a half years as a
        <strong>Research Intern at the Qualcomm Institute (CALIT2)</strong>, building
        quantum-secured video communications, quantum search algorithms, and machine learning
        classification pipelines.
      </p>
      <p>
        Outside the lab, I co-founded <strong>San Diego CTF</strong> and the
        <strong>Quantum Computing Student Association at UCSD</strong>, served as
        <strong>President of ACM Cyber</strong> through COVID lockdown, and built a MERN-stack platform
        serving 2,400 monthly users for <strong>RIT Esports</strong>.
      </p>
      <p>
        I care about making <strong>technical ideas usable and understandable</strong> — whether that
        means translating research-level specifications into working software, or writing documentation
        that lets people solve problems without asking for help.
      </p>
      <div class="bio-contact">
        <a href="mailto:acpeters@ucsd.edu" class="btn"><i class="bi bi-envelope"></i> Email</a>
        <a
          href="https://linkedin.com/in/i-am-andy-peterson"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"><i class="bi bi-linkedin"></i> LinkedIn</a
        >
        <a
          href="https://github.com/andypeterson2"
          class="btn"
          target="_blank"
          rel="noopener noreferrer"><i class="bi bi-github"></i> GitHub</a
        >
        <a href="/resume.pdf" class="btn"><i class="bi bi-file-earmark-text"></i> Resume</a>
        <a href="/cv.pdf" class="btn"><i class="bi bi-file-earmark-person"></i> CV</a>
      </div>
    </div>
  </div>

  <!-- Two-column layout -->
  <div class="about-grid">
    <!-- Left sidebar -->
    <aside class="sidebar">
      <div class="window sidebar-window">
        <div class="title-bar">
    
          <h2 class="title">Education</h2>
    
        </div>
        <div class="window-body">
          <div class="sidebar-entry">
            <div class="sidebar-entry-title">B.S. Computer Science</div>
            <div class="sidebar-entry-sub">UC San Diego</div>
            <div class="sidebar-entry-date">December 2024</div>
          </div>
        </div>
      </div>

      <div class="window sidebar-window">
        <div class="title-bar">
    
          <h2 class="title">Certifications</h2>
    
        </div>
        <div class="window-body">
          <div class="sidebar-entry">
            <div class="sidebar-entry-title">Azure Data Fundamentals (DP-900)</div>
            <div class="sidebar-entry-sub">Microsoft</div>
          </div>
          <div class="sidebar-entry">
            <div class="sidebar-entry-title">ITF+ (IT Fundamentals)</div>
            <div class="sidebar-entry-sub">CompTIA</div>
          </div>
        </div>
      </div>

      <div class="window sidebar-window">
        <div class="title-bar">
    
          <h2 class="title">Skills</h2>
    
        </div>
        <div class="window-body">
          <div class="skill-group">
            <div class="skill-group-label">Languages</div>
            <div class="skill-tags">
              <span class="tag">Python</span>
              <span class="tag">TypeScript</span>
              <span class="tag">C/C++</span>
              <span class="tag">Java</span>
              <span class="tag">SQL</span>
            </div>
          </div>
          <div class="skill-group">
            <div class="skill-group-label">Quantum</div>
            <div class="skill-tags">
              <span class="tag">Qiskit</span>
              <span class="tag">BB84</span>
              <span class="tag">Grover</span>
            </div>
          </div>
          <div class="skill-group">
            <div class="skill-group-label">Infrastructure</div>
            <div class="skill-tags">
              <span class="tag">Docker</span>
              <span class="tag">Kubernetes</span>
              <span class="tag">Terraform</span>
              <span class="tag">AWS</span>
              <span class="tag">Azure</span>
              <span class="tag">Linux</span>
              <span class="tag">CI/CD</span>
            </div>
          </div>
          <div class="skill-group">
            <div class="skill-group-label">AI / ML</div>
            <div class="skill-tags">
              <span class="tag">PyTorch</span>
              <span class="tag">Scikit-Learn</span>
            </div>
          </div>
          <div class="skill-group">
            <div class="skill-group-label">Security</div>
            <div class="skill-tags">
              <span class="tag">Cryptography</span>
              <span class="tag">CTF</span>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Right: Timeline -->
    <div class="window timeline-window">
      <div class="title-bar">
  
        <h2 class="title">Experience</h2>
  
      </div>
      <div class="timeline">
        <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2022 – 2024</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Research Intern</div>
          <div class="timeline-org">Qualcomm Institute (CALIT2) · San Diego, CA</div>
          <ul class="timeline-bullets">
            <li>
              Built a frame-level encryption pipeline for live video with sub-millisecond latency
              overhead, enabling real-time AES-128-GCM encryption (FFmpeg, WebRTC Insertable Streams).
            </li>
            <li>
              Simulated a noisy quantum channel (Poisson photon source, fiber attenuation, detector
              modeling) to validate protocol correctness — used to verify eavesdrop detection via
              error rate anomalies.
            </li>
            <li>
              Presented algorithmic research to IBM's VP of Quantum during campus visit.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2021 – 2024</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Co-Founder / President</div>
          <div class="timeline-org">Quantum Computing at UC, San Diego (QCSD)</div>
          <ul class="timeline-bullets">
            <li>
              Co-founded to fill a gap in undergraduate quantum computing education at UCSD.
              Restructured processes and formalized handoffs before graduating — org survived
              complete leadership turnover and is now nationally chartered as QCSA.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2023</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">President / Competition Committee</div>
          <div class="timeline-org">ACM Cyber at UCSD</div>
          <ul class="timeline-bullets">
            <li>
              As President, maintained org engagement through full COVID lockdown when most student
              orgs lost momentum.
            </li>
            <li>
              Centralized documentation for the 500-member org in Notion with role-based
              least-privilege access controls.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2022</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Web Developer</div>
          <div class="timeline-org">RIT Esports · Remote</div>
          <ul class="timeline-bullets">
            <li>
              Built and deployed a MERN-stack platform via Docker serving 2,400 monthly active
              visitors across 6 varsity esports teams with 99.9% uptime.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2022</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Co-Founder</div>
          <div class="timeline-org">San Diego CTF</div>
          <ul class="timeline-bullets">
            <li>
              Co-founded San Diego's largest annual cybersecurity competition — hundreds of
              competitors across 20+ countries, running for two annual iterations.
            </li>
            <li>
              Built the Discord bot submission interface (Discord.JS) used by all competitors
              across both years — zero onboarding friction.
            </li>
          </ul>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="timeline-meta">
          <div class="timeline-date">2020 – 2021</div>
        </div>
        <div class="timeline-content">
          <div class="timeline-role">Tutor / IT Lead</div>
          <div class="timeline-org">Mathnasium · Southern California</div>
          <ul class="timeline-bullets">
            <li>
              Sole IT resource for transitioning the center to remote operations during COVID-19,
              keeping ~25 client families and ~15 active students connected.
            </li>
          </ul>
        </div>
      </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Reset all margins ── */
  .bio-window,
  .sidebar-window,
  .timeline-window,
  .bio-body p,
  .bio-window .title-bar,
  .sidebar-window .title-bar,
  .timeline-window .title-bar,
  .bio-card.window .title-bar {
    margin: 0;
  }

  /* ── Bio window ── */
  .bio-body {
    font-size: clamp(13px, 1.6vw, 18px);
    line-height: 1.65;
    padding: clamp(4px, 0.6vw, 8px);
  }

  .bio-card.window {
    float: left;
    margin: 0;
    width: clamp(120px, 24%, 170px);
    min-width: 0;
  }

  .bio-card-body {
    padding: clamp(3px, 0.4vw, 5px);
  }

  .bio-headshot {
    width: 100%;
    height: auto;
    display: block;
  }

  .bio-details-bar {
    justify-content: center;
  }

  .bio-contact {
    display: flex;
    justify-content: space-evenly;
    gap: clamp(4px, 0.6vw, 8px);
    clear: both;
    padding-top: clamp(4px, 0.5vw, 7px);
  }

  /* ── Two-column grid ── */
  .about-grid {
    display: grid;
    grid-template-columns: clamp(220px, 30%, 280px) 1fr;
    gap: clamp(8px, 1vw, 12px);
    align-items: start;
    margin-top: 0;
  }

  /* ── Sidebar ── */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: sticky;
    top: clamp(12px, 2vw, 24px);
    z-index: 1;
  }

  .sidebar-window {
    overflow: hidden;
    max-width: 100%;
    min-width: 0;
  }

  .timeline-window {
    z-index: 2;
    position: relative;
  }

  .sidebar-window .window-body {
    padding: clamp(3px, 0.4vw, 5px);
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 5px);
  }

  .timeline-window .timeline {
    padding: clamp(4px, 0.6vw, 8px);
  }

  .sidebar-entry {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-entry + .sidebar-entry {
    margin-top: 0;
  }

  .sidebar-entry-title {
    font-family: var(--font-ui);
    font-size: clamp(10px, 1.3vw, 14px);
    font-weight: 700;
    line-height: 1.3;
  }

  .sidebar-entry-sub,
  .sidebar-entry-date {
    font-size: clamp(9px, 1.1vw, 12px);
    opacity: 0.6;
    line-height: 1.3;
  }

  /* Skills */
  .skill-group {
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 4px);
    margin-top: 0;
  }

  .skill-group:first-of-type {
    margin-top: 0;
  }

  .skill-group-label {
    font-family: var(--font-mono);
    font-size: clamp(8px, 0.9vw, 10px);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(3px, 0.4vw, 4px);
  }

  .tag {
    font-family: var(--font-ui);
    font-size: clamp(9px, 1vw, 11px);
    border: 1px solid #000;
    padding: 1px clamp(4px, 0.5vw, 6px);
    line-height: 1.6;
  }

  /* ── Timeline ── */
  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: clamp(62px, 8vw, 90px);
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: #000;
  }

  .timeline-entry {
    display: grid;
    grid-template-columns: clamp(62px, 8vw, 90px) 1fr;
    gap: clamp(16px, 2.5vw, 28px);
    padding-bottom: clamp(20px, 3vw, 36px);
    position: relative;
  }

  .timeline-entry:last-child {
    padding-bottom: 0;
  }

  .timeline-entry::after {
    content: '';
    position: absolute;
    left: clamp(62px, 8vw, 90px);
    top: 8px;
    width: 7px;
    height: 7px;
    background: #000;
    transform: translateX(-3px);
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-top: 2px;
    padding-right: clamp(6px, 1vw, 12px);
  }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: clamp(9px, 1.1vw, 13px);
    opacity: 0.5;
    text-align: right;
    line-height: 1.4;
    white-space: nowrap;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.3vw, 3px);
  }

  .timeline-role {
    font-family: var(--font-ui);
    font-size: clamp(11px, 1.4vw, 16px);
    font-weight: 700;
    line-height: 1.3;
  }

  .timeline-org {
    font-size: clamp(10px, 1.2vw, 13px);
    opacity: 0.55;
    margin-bottom: 0;
  }

  .timeline-bullets {
    margin: 0;
    padding-left: clamp(14px, 1.8vw, 20px);
    display: flex;
    flex-direction: column;
    gap: clamp(3px, 0.4vw, 5px);
  }

  .timeline-bullets li {
    font-size: clamp(11px, 1.3vw, 15px);
    line-height: 1.55;
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
    }

    .timeline::before {
      display: none;
    }

    .timeline-entry {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .timeline-entry::after {
      display: none;
    }

    .timeline-meta {
      align-items: flex-start;
    }

    .timeline-date {
      text-align: left;
    }
  }
</style>
