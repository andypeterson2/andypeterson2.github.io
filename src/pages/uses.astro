---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="Uses" description="Tools, hardware, and software I use daily.">
  <Breadcrumbs crumbs={[{ label: 'Uses' }]} />
  <section class="page-header">
    <h1>/uses</h1>
    <p class="page-subtitle">Tools, hardware, and software I use daily.</p>
  </section>

  <section class="content-section">
    <SectionLabel label="Editor & Terminal" />
    <div class="standard-dialog uses-list">
      <div class="details-bar"><span>Editor</span><span>VS Code with Gruvbox theme</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Terminal</span><span>iTerm2 + zsh + oh-my-zsh</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Font</span><span>IBM Plex Mono</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>AI</span><span>Claude Code</span></div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Languages & Frameworks" />
    <div class="standard-dialog uses-list">
      <div class="details-bar"><span>Primary</span><span>Python, TypeScript</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Quantum</span><span>Qiskit, PennyLane</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Web</span><span>Astro, React, Flask</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Data</span><span>PyTorch, scikit-learn</span></div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Infrastructure" />
    <div class="standard-dialog uses-list">
      <div class="details-bar"><span>Hosting</span><span>Vercel</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Version control</span><span>Git + GitHub</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>CI/CD</span><span>GitHub Actions</span></div>
      <div class="separator"></div>
      <div class="details-bar"><span>Project management</span><span>OpenProject</span></div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 {
    margin-bottom: var(--space-2);
    font-family: Monaco, ui-monospace, monospace;
  }
  .page-subtitle { font-size: 16px; }
  .content-section {
    padding: var(--space-6) 0;
    max-width: var(--content-width);
  }
  .uses-list { padding: 0; }
  .uses-list .separator { margin: 0; }
</style>
