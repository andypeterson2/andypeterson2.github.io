---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="Contact" description={`Contact ${siteConfig.displayName}`}>
  <div class="contact-intro">
    <p class="subtitle">Open to full-time roles in quantum computing, software engineering, and cybersecurity. Also available for research collaboration.</p>
  </div>

  <div class="contact-section">
    <div class="section-rule"><span>Send a Message</span></div>
    <form class="contact-form" id="contact-form" novalidate>
      <div class="form-field">
        <label for="contact-name">Name</label>
        <input type="text" id="contact-name" name="name" required autocomplete="name" />
        <span class="form-error" data-for="contact-name"></span>
      </div>
      <div class="form-field">
        <label for="contact-email">Email</label>
        <input type="email" id="contact-email" name="email" required autocomplete="email" />
        <span class="form-error" data-for="contact-email"></span>
      </div>
      <div class="form-field">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="6" required></textarea>
        <span class="form-error" data-for="contact-message"></span>
      </div>
      <button type="submit" class="send-btn">Send Message</button>
    </form>
  </div>

  <div class="contact-section">
    <div class="section-rule"><span>Elsewhere</span></div>
    <div class="link-list">
      {siteConfig.email && (
        <a href={`mailto:${siteConfig.email}?subject=Hello`} class="contact-link">
          <img src="/icons/link_light.svg" alt="" class="link-icon" />
          <span class="link-text">Email</span>
          <span class="link-detail">{siteConfig.email}</span>
        </a>
      )}
      {siteConfig.github && (
        <a href={siteConfig.github} class="contact-link" target="_blank" rel="noopener noreferrer">
          <img src="/icons/code.svg" alt="" class="link-icon" />
          <span class="link-text">GitHub</span>
          <span class="link-detail">Source code &amp; contributions</span>
        </a>
      )}
      {siteConfig.linkedin && (
        <a href={siteConfig.linkedin} class="contact-link" target="_blank" rel="noopener noreferrer">
          <img src="/icons/link_light.svg" alt="" class="link-icon" />
          <span class="link-text">LinkedIn</span>
          <span class="link-detail">Professional profile</span>
        </a>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    function showError(fieldId: string, message: string) {
      const errorEl = form!.querySelector(`[data-for="${fieldId}"]`);
      if (errorEl) errorEl.textContent = message;
      document.getElementById(fieldId)?.classList.add('invalid');
    }
    function clearErrors() {
      form!.querySelectorAll('.form-error').forEach(el => el.textContent = '');
      form!.querySelectorAll('.invalid').forEach(el => el.classList.remove('invalid'));
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErrors();
      const name = (form!.querySelector('#contact-name') as HTMLInputElement).value.trim();
      const email = (form!.querySelector('#contact-email') as HTMLInputElement).value.trim();
      const message = (form!.querySelector('#contact-message') as HTMLTextAreaElement).value.trim();
      let valid = true;

      if (!name) { showError('contact-name', 'Name is required'); valid = false; }
      if (!email) { showError('contact-email', 'Email is required'); valid = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError('contact-email', 'Please enter a valid email'); valid = false;
      }
      if (!message) { showError('contact-message', 'Message is required'); valid = false; }

      if (valid) {
        const btn = form!.querySelector('[type="submit"]') as HTMLButtonElement;
        if (btn) { btn.textContent = 'Message sent — thank you!'; btn.disabled = true; }
      }
    });
  }
</script>

<style>
  .contact-intro {
    padding: clamp(16px, 3vw, 40px) 0 clamp(8px, 1.5vw, 20px);
  }
  .subtitle {
    font-size: clamp(12px, 1.78vw, 24px);
    max-width: 55ch;
    line-height: 1.5;
  }

  .contact-section {
    padding: clamp(12px, 2vw, 28px) 0;
  }

  .section-rule {
    display: flex;
    align-items: center;
    gap: clamp(6px, 1vw, 14px);
    margin-bottom: clamp(12px, 2vw, 28px);
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(10px, 1.4vw, 18px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .section-rule::before,
  .section-rule::after {
    content: '';
    flex: 1;
    height: 1px;
    background: #000;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: clamp(10px, 1.5vw, 20px);
    max-width: 50ch;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: clamp(2px, 0.4vw, 6px);
  }
  .form-field label {
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(11px, 1.5vw, 20px);
  }
  .form-field input,
  .form-field textarea {
    font-family: var(--font-sans);
    font-size: clamp(12px, 1.78vw, 24px);
    padding: clamp(4px, 0.5vw, 8px);
    border: 2px solid #000;
    background: #fff;
    outline: none;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    box-shadow: 2px 2px 0 #000;
  }
  .form-field textarea {
    resize: vertical;
  }
  .form-field input.invalid,
  .form-field textarea.invalid {
    border-color: #000;
    background: #eee;
  }
  .form-error {
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(9px, 1.2vw, 16px);
    font-weight: 700;
    min-height: 1.2em;
  }

  .send-btn {
    align-self: flex-start;
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(12px, 1.78vw, 24px);
    padding: clamp(4px, 0.6vw, 10px) clamp(12px, 1.5vw, 24px);
    background: #fff;
    color: #000;
    border: 2px solid #000;
    cursor: pointer;
  }
  .send-btn:hover {
    background: #000;
    color: #fff;
  }
  .send-btn:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* ── Links ── */
  .link-list {
    display: flex;
    flex-direction: column;
    gap: clamp(6px, 1vw, 14px);
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: clamp(8px, 1vw, 16px);
    text-decoration: none;
    color: #000;
    padding: clamp(6px, 0.8vw, 12px) clamp(8px, 1vw, 16px);
    border: 2px solid #000;
    max-width: 50ch;
  }
  .contact-link:hover {
    background: #000;
    color: #fff;
  }
  .contact-link:hover .link-icon {
    filter: invert(1);
  }
  .link-icon {
    width: clamp(20px, 2.5vw, 36px);
    height: clamp(20px, 2.5vw, 36px);
    flex-shrink: 0;
  }
  .link-text {
    font-family: 'Chicago', 'ChicagoFLF', sans-serif;
    font-size: clamp(12px, 1.78vw, 24px);
    flex-shrink: 0;
  }
  .link-detail {
    font-size: clamp(10px, 1.4vw, 18px);
    opacity: 0.6;
    margin-left: auto;
  }
</style>
