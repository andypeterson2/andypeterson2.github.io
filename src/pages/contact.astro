---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import Button from '../components/Button.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout title="Contact" description={`Contact ${siteConfig.displayName}`}>
  <Breadcrumbs crumbs={[{ label: 'Contact' }]} />
  <section class="page-header">
    <h1>Contact</h1>
    <p class="page-subtitle">Get in touch for collaboration, research, or consulting.</p>
  </section>

  <section class="content-section">
    <SectionLabel label="Availability" />
    <div class="standard-dialog availability-badge">
      <span class="status-dot"></span>
      Available for new projects
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Send a Message" />
    <div class="window contact-window">
      <div class="title-bar">
        <button class="close" aria-hidden="true"><span>Close</span></button>
        <h1 class="title">New Message</h1>
        <button class="resize" aria-hidden="true"><span>Resize</span></button>
      </div>
      <div class="window-pane">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="field-row">
            <label for="contact-name">Name *</label>
            <input type="text" id="contact-name" name="name" required autocomplete="name" />
          </div>
          <span class="form-error" data-for="contact-name"></span>
          <div class="field-row">
            <label for="contact-email">Email *</label>
            <input type="email" id="contact-email" name="email" required autocomplete="email" />
          </div>
          <span class="form-error" data-for="contact-email"></span>
          <div class="field-row message-row">
            <label for="contact-message">Message *</label>
            <textarea id="contact-message" name="message" rows="5" required></textarea>
          </div>
          <span class="form-error" data-for="contact-message"></span>
          <div class="field-row">
            <button type="submit" class="btn-default">Send Message</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <section class="content-section">
    <SectionLabel label="Other Ways to Reach Me" />
    <div class="contact-grid">
      {siteConfig.email && (
        <div class="standard-dialog contact-card">
          <strong>Email</strong>
          <p>Best for project inquiries and collaboration.</p>
          <a href={`mailto:${siteConfig.email}?subject=Project%20Inquiry%20from%20Portfolio`} class="btn">Send Email</a>
        </div>
      )}
      {siteConfig.github && (
        <div class="standard-dialog contact-card">
          <strong>GitHub</strong>
          <p>Check out my open-source work and contributions.</p>
          <a href={siteConfig.github} class="btn" target="_blank" rel="noopener noreferrer">View GitHub</a>
        </div>
      )}
      {siteConfig.linkedin && (
        <div class="standard-dialog contact-card">
          <strong>LinkedIn</strong>
          <p>Connect for professional networking.</p>
          <a href={siteConfig.linkedin} class="btn" target="_blank" rel="noopener noreferrer">View LinkedIn</a>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    function showError(fieldId: string, message: string) {
      const errorEl = form!.querySelector(`[data-for="${fieldId}"]`);
      if (errorEl) errorEl.textContent = message;
      document.getElementById(fieldId)?.classList.add('invalid');
    }
    function clearErrors() {
      form!.querySelectorAll('.form-error').forEach(el => el.textContent = '');
      form!.querySelectorAll('.invalid').forEach(el => el.classList.remove('invalid'));
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      clearErrors();
      const name = (form!.querySelector('#contact-name') as HTMLInputElement).value.trim();
      const email = (form!.querySelector('#contact-email') as HTMLInputElement).value.trim();
      const message = (form!.querySelector('#contact-message') as HTMLTextAreaElement).value.trim();
      let valid = true;

      if (!name) { showError('contact-name', 'Name is required'); valid = false; }
      if (!email) { showError('contact-email', 'Email is required'); valid = false; }
      else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError('contact-email', 'Please enter a valid email'); valid = false;
      }
      if (!message) { showError('contact-message', 'Message is required'); valid = false; }

      if (valid) {
        const btn = form!.querySelector('[type="submit"]') as HTMLButtonElement;
        if (btn) { btn.textContent = 'Sent!'; btn.disabled = true; }
      }
    });
  }
</script>

<style>
  .page-header {
    padding: var(--space-8) 0 var(--space-6);
    max-width: var(--content-width);
  }
  .page-header h1 { margin-bottom: var(--space-2); }
  .page-subtitle { font-size: 16px; }
  .content-section { padding: var(--space-6) 0; }
  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    background: #000;
    border: 1px solid #000;
  }
  .contact-window {
    max-width: var(--content-width);
    min-width: 0;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .contact-form .field-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    font-family: var(--font-mono);
    font-size: 16px;
    padding: 4px;
  }
  .contact-form textarea {
    border: 1.5px solid #000;
    resize: vertical;
  }
  .form-error {
    font-family: var(--font-mono);
    font-size: 11px;
    color: #000;
    font-weight: 700;
    min-height: 1em;
  }
  .message-row {
    align-items: flex-start;
  }
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-4);
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .contact-card p {
    font-size: 13px;
    margin-bottom: var(--space-2);
  }
  .contact-card .btn {
    align-self: flex-start;
  }
</style>
