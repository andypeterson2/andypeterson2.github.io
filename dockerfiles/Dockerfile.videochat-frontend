FROM node:20-bookworm AS build

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build:dll 2>/dev/null || true
ENV BROWSER_ONLY=true
RUN npm run build:renderer

# Output stage — just holds the built files for the shared volume
FROM alpine:latest
COPY --from=build /app/release/app/dist/renderer /build
CMD ["echo", "Video chat frontend build complete"]
