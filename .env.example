# Site identity configuration
# Used by src/config/site.ts to populate meta tags, structured data, and navigation
SITE_DISPLAY_NAME="Your Name"
SITE_DOMAIN="example.com"
SITE_EMAIL="you@example.com"
SITE_TITLE="Portfolio"
SITE_DESCRIPTION="Personal portfolio and project showcase"
SITE_GITHUB="https://github.com/username"
SITE_LINKEDIN="https://linkedin.com/in/username"

# Astro dev server port (used by docker-compose.yml)
ASTRO_PORT=4322

# Environment mode (development | production)
# Controls CSP strictness and other build-time behavior
NODE_ENV=development

# Optional: Plausible analytics domain (uncomment to enable)
# PLAUSIBLE_DOMAIN="example.com"

# Optional: mark as preview deploy (adds noindex/nofollow to all pages)
# PREVIEW_DEPLOY="true"
